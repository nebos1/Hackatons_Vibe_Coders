OPENAI_API_KEY=
GOOGLE_MAPS_KEY=
ADMIN_EMAIL=
ADMIN_PASSWORD=
APP_PUBLIC_URL=https://evento.business
GOOGLE_SITE_VERIFICATION=

# Optional. Railway provides DATABASE_URL automatically when the Postgres service is attached.
# For local Docker Compose, appsettings.Development.json already points to localhost:5432.
DATABASE_URL=

# Optional SMTP for account confirmation/password reset emails.
EMAIL_ENABLED=false
BREVO_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Evento
SMTP_ENABLE_SSL=true

# Railway/Gmail alias names are also supported:
# SMTP_USER=
# SMTP_PASS=

# Media storage.
# Local development should stay Local and will store uploads under wwwroot/uploads.
# Railway production should use S3 with a Railway Storage Bucket.
MEDIA_STORAGE=Local

# Railway Storage Bucket / S3-compatible settings.
# Railway exposes BUCKET, ACCESS_KEY_ID, SECRET_ACCESS_KEY, REGION and ENDPOINT
# when you reference a bucket from the app service. You can either keep those exact
# names in Railway or map them to the S3_* names below.
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
S3_FORCE_PATH_STYLE=false
S3_KEY_PREFIX=uploads
S3_SIGNED_URL_MINUTES=30
