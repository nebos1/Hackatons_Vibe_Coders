@model EventsApp.ViewModels.Posts.PostCardViewModel
@{
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var canManage = User.IsInRole(GlobalConstants.Roles.Admin)
        || (!string.IsNullOrWhiteSpace(currentUserId) && Model.OrganizerId == currentUserId);
    var likeAction = Model.CurrentUserLiked ? "Unlike" : "Like";
    var saveAction = Model.CurrentUserSaved ? "Unsave" : "Save";
    var preview = Model.Content.Length > 220 ? Model.Content[..220] + "..." : Model.Content;
    var shareUrl = Url.Action("Details", "Posts", new { id = Model.Id }, Context.Request.Scheme) ?? string.Empty;
    var commentsUrl = Url.Action("Comments", "Posts", new { id = Model.Id }) ?? $"/Posts/Comments/{Model.Id}";
    var initial = string.IsNullOrWhiteSpace(Model.OrganizerName) ? "?" : Model.OrganizerName[..1].ToUpperInvariant();
}

<div class="card h-100 shadow-sm post-card social-post-card" data-post-card data-post-id="@Model.Id">
    @if (!string.IsNullOrWhiteSpace(Model.FirstMediaUrl))
    {
        if (Model.FirstMediaType == EventsApp.Models.PostMediaType.Video)
        {
            <video class="card-img-top card-img-top-fixed bg-dark" controls preload="metadata" muted>
                <source src="@Model.FirstMediaUrl" />
            </video>
        }
        else
        {
            <img src="@Model.FirstMediaUrl" class="card-img-top card-img-top-fixed" alt="Post media" />
        }
    }

    <div class="card-body d-flex flex-column">
        <div class="social-post-card__author">
            @if (Model.OrganizerProfileId.HasValue)
            {
                <a asp-controller="Profiles" asp-action="Page" asp-route-id="@Model.OrganizerProfileId" class="social-author-link">
                    @if (!string.IsNullOrWhiteSpace(Model.AuthorImageUrl))
                    {
                        <img src="@Model.AuthorImageUrl" alt="@Model.OrganizerName" class="social-avatar-xs" />
                    }
                    else
                    {
                        <span class="social-avatar-xs social-avatar-xs--fallback">@initial</span>
                    }
                    <span>
                        <strong>@Model.OrganizerName</strong>
                        <small><i class="bi bi-patch-check-fill"></i> <span data-i18n="profile.public.page">Public page</span></small>
                    </span>
                </a>
            }
            else if (Model.AuthorIsOrganizer)
            {
                <span class="social-author-link social-author-link--static">
                    @if (!string.IsNullOrWhiteSpace(Model.AuthorImageUrl))
                    {
                        <img src="@Model.AuthorImageUrl" alt="@Model.OrganizerName" class="social-avatar-xs" />
                    }
                    else
                    {
                        <span class="social-avatar-xs social-avatar-xs--fallback">@initial</span>
                    }
                    <span>
                        <strong>@Model.OrganizerName</strong>
                        <small><i class="bi bi-patch-check-fill"></i> <span data-i18n="profile.public.page">Public page</span></small>
                    </span>
                </span>
            }
            else
            {
                <a asp-controller="Profiles" asp-action="Details" asp-route-id="@Model.OrganizerId" class="social-author-link">
                    @if (!string.IsNullOrWhiteSpace(Model.AuthorImageUrl))
                    {
                        <img src="@Model.AuthorImageUrl" alt="@Model.OrganizerName" class="social-avatar-xs" />
                    }
                    else
                    {
                        <span class="social-avatar-xs social-avatar-xs--fallback">@initial</span>
                    }
                    <span>
                        <strong>@Model.OrganizerName</strong>
                        @if (Model.AuthorIsOrganizer)
                        {
                            <small><i class="bi bi-patch-check-fill"></i> <span data-i18n="profile.type.organizer">Organizer</span></small>
                        }
                    </span>
                </a>
            }
            <small class="text-muted">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small>
        </div>

        @if (Model.EventId.HasValue)
        {
            <div class="mb-2">
                <a asp-controller="Events" asp-action="Details" asp-route-id="@Model.EventId" class="small">
                    <i class="bi bi-link-45deg"></i> @Model.EventTitle
                </a>
            </div>
        }

        <p class="card-text post-body flex-grow-1" id="post-body-@Model.Id">@preview</p>
        <button class="groove-translate-btn" data-target="#post-body-@Model.Id" onclick="gtTranslate(this)">
            <i class="bi bi-translate"></i> Translate
        </button>

        <div class="social-card-actions mt-auto">
            <div class="social-card-actions__primary">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    var btnClass = Model.CurrentUserLiked ? "btn-danger" : "btn-outline-danger";
                    var iconClass = Model.CurrentUserLiked ? "bi-heart-fill" : "bi-heart";
                    <form asp-controller="Posts" asp-action="@likeAction" asp-route-id="@Model.Id"
                          asp-route-returnUrl="@returnUrl" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-sm @btnClass" type="submit" title="Like" data-post-action="like" data-i18n-title="post.like">
                            <i class="bi @iconClass"></i> @Model.LikesCount
                        </button>
                    </form>

                    var saveClass = Model.CurrentUserSaved ? "btn-dark" : "btn-outline-dark";
                    var saveIcon = Model.CurrentUserSaved ? "bi-bookmark-fill" : "bi-bookmark";
                    <form asp-controller="Posts" asp-action="@saveAction" asp-route-id="@Model.Id"
                          asp-route-returnUrl="@returnUrl" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-sm @saveClass" type="submit" title="Save" data-post-action="save" data-i18n-title="post.save">
                            <i class="bi @saveIcon"></i> @Model.SavesCount
                        </button>
                    </form>
                }
                else
                {
                    <span class="small text-muted"><i class="bi bi-heart"></i> @Model.LikesCount</span>
                    <span class="small text-muted"><i class="bi bi-bookmark"></i> @Model.SavesCount</span>
                }

                <button class="btn btn-sm btn-outline-secondary" type="button" title="Comments" data-i18n-title="social.comments" data-post-comments-open data-comments-url="@commentsUrl" data-post-id="@Model.Id">
                    <i class="bi bi-chat"></i> <span data-post-comment-count>@Model.CommentsCount</span>
                </button>
                <button class="btn btn-sm btn-outline-secondary social-share-button" type="button" data-share-url="@shareUrl" data-share-title="Post by @Model.OrganizerName" title="Share" data-i18n-title="social.share">
                    <i class="bi bi-share"></i>
                </button>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="Messages" asp-action="SharePost" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-secondary" title="Send in chat" data-i18n-title="share.chat" data-chat-share-open>
                        <i class="bi bi-send"></i>
                    </a>
                }
            </div>

            @if (canManage)
            {
                <div class="social-card-actions__manage">
                    <a asp-controller="Posts" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-secondary" title="Edit" data-i18n-title="common.edit">
                        <i class="bi bi-pencil"></i>
                    </a>
                    <a asp-controller="Posts" asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-danger" title="Delete" data-i18n-title="common.delete">
                        <i class="bi bi-trash"></i>
                    </a>
                </div>
            }
        </div>
    </div>
</div>
