@model EventsApp.ViewModels.Events.EventCardViewModel
@{
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
}

<div class="card h-100 shadow-sm event-card" data-event-id="@Model.Id">
    @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
    {
        <img src="@Model.ImageUrl" class="card-img-top card-img-top-fixed" alt="@Model.Title" />
    }
    else
    {
        <div class="card-img-top-fixed d-flex align-items-center justify-content-center text-muted">
            <i class="bi bi-calendar-event" style="font-size: 2rem;"></i>
        </div>
    }
    <div class="card-body d-flex flex-column">
        <div class="mb-2">
            <span class="badge bg-secondary event-genre-badge">@Model.Genre</span>
            @if (!Model.IsApproved)
            {
                <span class="badge bg-warning text-dark event-genre-badge">Pending</span>
            }
        </div>
        <h5 class="card-title">@Model.Title</h5>
        <p class="card-text text-muted mb-1">
            <i class="bi bi-geo-alt"></i> @Model.Address, @Model.City
            <span class="event-card__distance small text-primary ms-1"></span>
        </p>
        <p class="card-text text-muted small mb-2">
            <i class="bi bi-clock"></i> @Model.StartTime.ToString("yyyy-MM-dd HH:mm")
            <a href="#events-map" class="ms-2 text-decoration-none small" data-show-on-map="@Model.Id" title="Show on map">
                <i class="bi bi-pin-map"></i> Show on map
            </a>
        </p>
        <div class="d-flex justify-content-between align-items-center mt-auto">
            <div class="d-flex align-items-center gap-2">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    var likeAction = Model.CurrentUserLiked ? "Unlike" : "Like";
                    var btnClass = Model.CurrentUserLiked ? "btn-danger" : "btn-outline-danger";
                    var iconClass = Model.CurrentUserLiked ? "bi-heart-fill" : "bi-heart";
                    <form asp-controller="Events" asp-action="@likeAction" asp-route-id="@Model.Id"
                          asp-route-returnUrl="@returnUrl" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-sm @btnClass" type="submit" title="@likeAction">
                            <i class="bi @iconClass"></i> @Model.LikesCount
                        </button>
                    </form>
                }
                else
                {
                    <span class="small text-muted"><i class="bi bi-heart"></i> @Model.LikesCount</span>
                }
                <span class="small text-muted"><i class="bi bi-chat"></i> @Model.CommentsCount</span>
            </div>
            <a asp-controller="Events" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary">Details</a>
        </div>
    </div>
</div>
