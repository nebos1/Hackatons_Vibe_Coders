@model EventsApp.ViewModels.Events.EventCardViewModel
@{
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var canManage = User.IsInRole(GlobalConstants.Roles.Admin)
        || (!string.IsNullOrWhiteSpace(currentUserId) && Model.OrganizerId == currentUserId);
    var likeAction = Model.CurrentUserLiked ? "Unlike" : "Like";
    var saveAction = Model.CurrentUserSaved ? "Unsave" : "Save";
    var shareUrl = Url.Action("Details", "Events", new { id = Model.Id }, Context.Request.Scheme) ?? string.Empty;
    var heat = Model.GoingCount * 2 + Model.InterestedCount + Model.LikesCount + Model.CommentsCount + Model.SavesCount;
    var isHot = heat >= 8;
    var organizerInitial = !string.IsNullOrWhiteSpace(Model.OrganizerName) ? Model.OrganizerName.Trim()[..1].ToUpper() : "?";
}

<div class="card event-card evt-card" data-event-id="@Model.Id">
    <div class="evt-card__media">
        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" alt="@Model.Title" />
        }
        else
        {
            <div class="evt-card__media-fallback"><i class="bi bi-calendar-event"></i></div>
        }

        @if (!Model.IsApproved)
        {
            <span class="evt-card__chip evt-card__chip--pending" data-i18n="event.status.pending">Pending</span>
        }
        else if (isHot)
        {
            <span class="evt-card__chip evt-card__chip--hot"><i class="bi bi-fire"></i> Hot</span>
        }
        else
        {
            <span class="evt-card__chip" data-i18n="genre.@Model.Genre">@Model.Genre.GetDisplayName()</span>
        }

        @if (User.Identity?.IsAuthenticated == true)
        {
            var saveOnClass = Model.CurrentUserSaved ? "is-saved" : "";
            var saveIcon = Model.CurrentUserSaved ? "bi-bookmark-fill" : "bi-bookmark";
            <form asp-controller="Events" asp-action="@saveAction" asp-route-id="@Model.Id"
                  asp-route-returnUrl="@returnUrl" method="post" class="m-0">
                @Html.AntiForgeryToken()
                <button class="evt-card__save @saveOnClass" type="submit" title="Save">
                    <i class="bi @saveIcon"></i>
                </button>
            </form>
        }
    </div>

    <div class="evt-card__body">
        <div class="evt-card__heading">
            <h3 class="evt-card__title">
                <a asp-controller="Events" asp-action="Details" asp-route-id="@Model.Id">@Model.Title</a>
            </h3>
            <span class="evt-card__price evt-card__price--free" data-i18n="event.price.free">FREE</span>
        </div>

        <div class="evt-card__meta">
            <span><i class="bi bi-geo-alt"></i> @Model.City</span>
            <span><i class="bi bi-clock"></i> @Model.StartTime.ToString("dd.MM HH:mm")</span>
            @if (heat > 0)
            {
                <span class="evt-card__rating" title="Heat">
                    <i class="bi bi-fire"></i> @heat
                </span>
            }
        </div>

        <a asp-controller="Profiles" asp-action="Details" asp-route-id="@Model.OrganizerId" class="evt-card__organizer">
            <span class="evt-card__organizer-avatar">@organizerInitial</span>
            <span>@Model.OrganizerName</span>
        </a>

        <div class="evt-card__actions">
            @if (User.Identity?.IsAuthenticated == true)
            {
                var likedCls = Model.CurrentUserLiked ? "is-on-liked" : "";
                var likeIcon = Model.CurrentUserLiked ? "bi-heart-fill" : "bi-heart";
                <form asp-controller="Events" asp-action="@likeAction" asp-route-id="@Model.Id"
                      asp-route-returnUrl="@returnUrl" method="post" class="m-0">
                    @Html.AntiForgeryToken()
                    <button class="evt-card__action @likedCls" type="submit" title="Like">
                        <i class="bi @likeIcon"></i> @Model.LikesCount
                    </button>
                </form>

                var goingCls = Model.CurrentUserAttendanceStatus == EventAttendanceStatus.Going ? "is-on-going" : "";
                <form asp-controller="Events" asp-action="Attendance" asp-route-id="@Model.Id"
                      asp-route-status="@EventAttendanceStatus.Going" asp-route-returnUrl="@returnUrl"
                      method="post" class="m-0">
                    @Html.AntiForgeryToken()
                    <button class="evt-card__action @goingCls" type="submit" title="Going">
                        <i class="bi bi-check2-circle"></i> @Model.GoingCount
                    </button>
                </form>

                var interestedCls = Model.CurrentUserAttendanceStatus == EventAttendanceStatus.Interested ? "is-on-interested" : "";
                <form asp-controller="Events" asp-action="Attendance" asp-route-id="@Model.Id"
                      asp-route-status="@EventAttendanceStatus.Interested" asp-route-returnUrl="@returnUrl"
                      method="post" class="m-0">
                    @Html.AntiForgeryToken()
                    <button class="evt-card__action @interestedCls" type="submit" title="Interested">
                        <i class="bi bi-star"></i> @Model.InterestedCount
                    </button>
                </form>
            }
            else
            {
                <span class="evt-card__action"><i class="bi bi-heart"></i> @Model.LikesCount</span>
                <span class="evt-card__action"><i class="bi bi-check2-circle"></i> @Model.GoingCount</span>
            }

            <a asp-controller="Events" asp-action="Details" asp-route-id="@Model.Id" class="evt-card__cta">
                <span data-i18n="event.action.details">Виж</span>
                <i class="bi bi-arrow-right"></i>
            </a>
        </div>

        @if (canManage)
        {
            <div class="evt-card__actions" style="border-top:none;padding-top:0;margin-top:-2px;">
                <span class="text-muted small" style="margin-right:auto;">
                    <i class="bi bi-shield-check"></i> @{ var lbl = "Управление"; }<span data-i18n="card.manage">@lbl</span>
                </span>
                <div class="evt-card__manage">
                    <a asp-controller="Events" asp-action="Edit" asp-route-id="@Model.Id" title="Edit"><i class="bi bi-pencil"></i></a>
                    <a asp-controller="Tickets" asp-action="Manage" asp-route-id="@Model.Id" title="Tickets"><i class="bi bi-ticket-perforated"></i></a>
                    <a asp-controller="Events" asp-action="Delete" asp-route-id="@Model.Id" class="is-danger" title="Delete"><i class="bi bi-trash"></i></a>
                </div>
            </div>
        }
    </div>
</div>
