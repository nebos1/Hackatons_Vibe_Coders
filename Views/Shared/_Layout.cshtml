@using EventsApp.Common
<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="x-app-lang" content="bg" />
    <title>@ViewData["Title"] - GrooveOn</title>

    <script>
        (function () {
            var lang = localStorage.getItem('appLang') || 'bg';
            var exp = 'expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;';
            if (lang === 'en') {
                document.cookie = 'googtrans=/bg/en; path=/;';
                document.cookie = 'googtrans=/bg/en; path=/; domain=.' + location.hostname;
            } else {
                document.cookie = 'googtrans=; ' + exp;
                document.cookie = 'googtrans=; ' + exp + ' domain=' + location.hostname + ';';
                document.cookie = 'googtrans=; ' + exp + ' domain=.' + location.hostname + ';';
            }
            // Set button label immediately (no flash)
            document.addEventListener('DOMContentLoaded', function () {
                var btn = document.getElementById('app-lang-btn');
                if (btn) btn.textContent = lang === 'en' ? '🇧🇬 BG' : '🇬🇧 EN';
                if (lang === 'en') {
                    document.querySelectorAll('.groove-translate-btn').forEach(function (b) {
                        b.style.display = 'inline-block';
                    });
                }
            });
        })();
    </script>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .goog-te-banner-frame { display: none !important; }
        .goog-te-balloon-frame { display: none !important; }
        #goog-gt-tt { display: none !important; }
        .goog-tooltip { display: none !important; }
        body { top: 0 !important; }
        .skiptranslate iframe { display: none !important; }
        .groove-translate-btn {
            display: none;
            background: none;
            border: 1px solid #0f766e55;
            border-radius: 4px;
            color: #0f766e;
            font-size: 11px;
            font-weight: 600;
            cursor: pointer;
            padding: 2px 8px;
            margin-top: 4px;
            opacity: 0.8;
            transition: opacity .15s;
        }
        .groove-translate-btn:hover { opacity: 1; }
    </style>
</head>
<body>
    <header class="site-header">
        <nav class="navbar navbar-expand-md navbar-dark border-bottom shadow-sm site-navbar">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold d-inline-flex align-items-center gap-2 site-brand"
                   asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/img/logo.png" alt="GrooveOn" class="site-brand__logo" />
                    <span class="site-brand__name">GrooveOn</span>
                </a>

                <button id="app-lang-btn" type="button" onclick="toggleAppLang()"
                        style="background:#f5c842;color:#111;border:none;border-radius:6px;font-weight:700;font-size:13px;padding:5px 12px;cursor:pointer;white-space:nowrap;">
                    🇬🇧 EN
                </button>
                <div id="google_translate_element" style="display:none;"></div>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Навигация">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    @{
                        var isAuthed = User.Identity?.IsAuthenticated == true;
                        var isAdmin = User.IsInRole(GlobalConstants.Roles.Admin);
                        var isOrganizer = User.IsInRole(GlobalConstants.Roles.Organizer);
                        var isStaff = isAdmin || isOrganizer;
                    }
                    <ul class="navbar-nav me-auto mb-2 mb-md-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Начало</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Posts" asp-action="Index">Поток</a>
                        </li>
                        @if (isStaff)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Events" asp-action="Index">Събития</a>
                            </li>
                        }
                        @if (isAuthed)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Events" asp-action="Recommended">
                                    <i class="bi bi-stars"></i> Препоръчани
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Tickets" asp-action="MyTickets">
                                    <i class="bi bi-ticket-perforated"></i> Моите билети
                                </a>
                            </li>
                        }
                        @if (isStaff)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Tickets" asp-action="Validate">
                                    <i class="bi bi-qr-code-scan"></i> Валидиране
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Organizer" asp-action="Dashboard">
                                    <i class="bi bi-person-badge"></i> Организатор
                                </a>
                            </li>
                        }
                        @if (isAdmin)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-warning" asp-controller="Admin" asp-action="Index">
                                    <i class="bi bi-shield-check"></i> Админ
                                </a>
                            </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container site-content pb-5">
        @if (TempData["StatusMessage"] is string statusMessage && !string.IsNullOrEmpty(statusMessage))
        {
            <div class="alert alert-info alert-dismissible fade show" role="alert">
                @statusMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Затвори"></button>
            </div>
        }
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-light">
        <div class="container text-center py-2">
            &copy; @DateTime.UtcNow.Year GrooveOn
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // GT initializer — no extra logic needed, cookie already set in <head>
        function googleTranslateElementInit() {
            new google.translate.TranslateElement({
                pageLanguage: 'bg',
                includedLanguages: 'en',
                autoDisplay: false
            }, 'google_translate_element');
        }
        window.googleTranslateElementInit = googleTranslateElementInit;

        function toggleAppLang() {
            var current = localStorage.getItem('appLang') || 'bg';
            var next = current === 'en' ? 'bg' : 'en';
            localStorage.setItem('appLang', next);

            var exp = 'expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;';
            if (next === 'en') {
                document.cookie = 'googtrans=/bg/en; path=/;';
                document.cookie = 'googtrans=/bg/en; path=/; domain=.' + location.hostname;
            } else {
                document.cookie = 'googtrans=; ' + exp;
                document.cookie = 'googtrans=; ' + exp + ' domain=' + location.hostname + ';';
                document.cookie = 'googtrans=; ' + exp + ' domain=.' + location.hostname + ';';
            }
            location.reload();
        }

        // On-demand translate button (MyMemory free API, bg→en)
        function gtTranslate(btn) {
            var target = document.querySelector(btn.dataset.target);
            if (!target) return;

            if (btn.dataset.state === '1') {
                target.textContent = btn.dataset.orig;
                btn.dataset.state = '0';
                btn.innerHTML = '<i class="bi bi-translate"></i> Translate';
                return;
            }

            var text = target.textContent.trim();
            if (!text) return;
            btn.innerHTML = '⏳';

            fetch('https://api.mymemory.translated.net/get?q=' + encodeURIComponent(text.substring(0, 500)) + '&langpair=bg|en')
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    if (data.responseStatus === 200) {
                        btn.dataset.orig = text;
                        target.textContent = data.responseData.translatedText;
                        btn.dataset.state = '1';
                        btn.innerHTML = '<i class="bi bi-arrow-counterclockwise"></i> Original';
                    } else {
                        btn.innerHTML = '❌ Error';
                    }
                })
                .catch(function () { btn.innerHTML = '❌ Error'; });
        }
    </script>
    <script src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit" async></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
