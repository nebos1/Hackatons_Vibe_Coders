@using EventsApp.Common
<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="x-app-lang" content="bg" />
    <title>@ViewData["Title"] - Evento</title>

    <script>
        (function () {
            var theme = localStorage.getItem('appTheme') || 'light';
            document.documentElement.setAttribute('data-theme', theme);
        })();
    </script>

    <script>
        (function () {
            var lang = localStorage.getItem('appLang') || 'bg';
            document.documentElement.lang = lang;
            var meta = document.querySelector('meta[name="x-app-lang"]');
            if (meta) meta.setAttribute('content', lang);
            var exp = 'expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;';
            if (lang === 'en') {
                document.cookie = 'googtrans=/bg/en; path=/;';
                document.cookie = 'googtrans=/bg/en; path=/; domain=.' + location.hostname;
            } else {
                document.cookie = 'googtrans=; ' + exp;
                document.cookie = 'googtrans=; ' + exp + ' domain=' + location.hostname + ';';
                document.cookie = 'googtrans=; ' + exp + ' domain=.' + location.hostname + ';';
            }
            // Set button label immediately (no flash)
            document.addEventListener('DOMContentLoaded', function () {
                var btn = document.getElementById('app-lang-btn');
                if (btn) btn.textContent = lang === 'en' ? '🇧🇬 BG' : '🇬🇧 EN';
                if (btn) btn.textContent = lang === 'en' ? 'BG' : 'EN';
                // groove-translate-btn visibility is handled by i18n.js
            });
        })();
    </script>

    <link rel="icon" href="~/img/logo.svg" type="image/svg+xml" />
    <link rel="manifest" href="~/manifest.webmanifest" />
    <meta name="theme-color" content="#6c5ce7" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="Evento" />
    <link rel="apple-touch-icon" href="~/img/logo.svg" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Head", required: false)
    <style>
        .goog-te-banner-frame { display: none !important; }
        .goog-te-balloon-frame { display: none !important; }
        #goog-gt-tt { display: none !important; }
        .goog-tooltip { display: none !important; }
        body { top: 0 !important; }
        .skiptranslate iframe { display: none !important; }
        .groove-translate-btn {
            display: none;
            background: none;
            border: 1px solid #0f766e55;
            border-radius: 4px;
            color: #0f766e;
            font-size: 11px;
            font-weight: 600;
            cursor: pointer;
            padding: 2px 8px;
            margin-top: 4px;
            opacity: 0.8;
            transition: opacity .15s;
        }
        .groove-translate-btn:hover { opacity: 1; }
    </style>
</head>
<body>
    <header class="site-header">
        <nav class="navbar navbar-expand-md navbar-dark border-bottom shadow-sm site-navbar">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold d-inline-flex align-items-center gap-2 site-brand"
                   asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/img/logo.svg" alt="Evento" class="site-brand__logo" />
                    <span class="site-brand__name notranslate" translate="no">Evento</span>
                </a>

                <button id="app-theme-btn" type="button" onclick="toggleAppTheme()"
                        title="Светла / Тъмна тема"
                        style="background:transparent;border:1px solid #e5e7ef;border-radius:999px;font-size:14px;padding:5px 10px;cursor:pointer;white-space:nowrap;color:#0d1424;">
                    <i class="bi bi-moon-stars"></i>
                </button>
                <button id="app-lang-btn" type="button" onclick="toggleAppLang()"
                        style="background:#0d1424;color:#fff;border:none;border-radius:999px;font-weight:700;font-size:13px;padding:5px 12px;cursor:pointer;white-space:nowrap;">
                    🇬🇧 EN
                </button>
                <div id="google_translate_element" style="display:none;"></div>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Навигация">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    @{
                        var isAuthed = User.Identity?.IsAuthenticated == true;
                        var isAdmin = User.IsInRole(GlobalConstants.Roles.Admin);
                        var isOrganizer = User.IsInRole(GlobalConstants.Roles.Organizer);
                        var isValidator = User.IsInRole(GlobalConstants.Roles.Validator);
                    }
                    <ul class="navbar-nav me-auto mb-2 mb-md-0 site-navbar__primary">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-search"></i> <span data-i18n="nav.discover">Открий</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Posts" asp-action="Index">
                                <i class="bi bi-compass"></i> <span data-i18n="nav.feed">Поток</span>
                            </a>
                        </li>
                        @if (isAuthed)
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-link--with-badge" asp-controller="Messages" asp-action="Index">
                                    <i class="bi bi-chat-dots"></i> <span data-i18n="nav.messages">Съобщения</span>
                                    @await Component.InvokeAsync("UnreadMessages")
                                </a>
                            </li>
                        }
                        @if (isAdmin)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Index">
                                    <i class="bi bi-shield-check"></i> <span data-i18n="nav.admin">Admin Panel</span>
                                </a>
                            </li>
                        }
                        else if (isOrganizer)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Organizer" asp-action="Dashboard">
                                    <i class="bi bi-speedometer2"></i> <span data-i18n="nav.organizer.panel">Organizer Panel</span>
                                </a>
                            </li>
                        }
                        else if (isValidator)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Tickets" asp-action="Validate">
                                    <i class="bi bi-qr-code-scan"></i> <span data-i18n="nav.validate">Validate tickets</span>
                                </a>
                            </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container site-content pb-5">
        @if (TempData["StatusMessage"] is string statusMessage && !string.IsNullOrEmpty(statusMessage))
        {
            <div class="alert alert-info alert-dismissible fade show" role="alert">
                @statusMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Затвори"></button>
            </div>
        }
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-light">
        <div class="container text-center py-2">
            &copy; @DateTime.UtcNow.Year Evento
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/i18n.js" asp-append-version="true"></script>
    <script src="~/js/event-actions.js" asp-append-version="true"></script>

    <script>
        function toggleAppTheme() {
            var current = document.documentElement.getAttribute('data-theme') || 'light';
            var next = current === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            localStorage.setItem('appTheme', next);
            var btn = document.getElementById('app-theme-btn');
            if (btn) btn.innerHTML = next === 'dark'
                ? '<i class="bi bi-sun"></i>'
                : '<i class="bi bi-moon-stars"></i>';
        }
        document.addEventListener('DOMContentLoaded', function () {
            var btn = document.getElementById('app-theme-btn');
            var theme = document.documentElement.getAttribute('data-theme');
            if (btn) btn.innerHTML = theme === 'dark'
                ? '<i class="bi bi-sun"></i>'
                : '<i class="bi bi-moon-stars"></i>';
        });
    </script>

    <script>
        // GT initializer — no extra logic needed, cookie already set in <head>
        function toggleAppLang() {
            var current = localStorage.getItem('appLang') || 'bg';
            var next = current === 'en' ? 'bg' : 'en';
            localStorage.setItem('appLang', next);
            var exp = 'expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;';
            if (next === 'en') {
                document.cookie = 'googtrans=/bg/en; path=/;';
                document.cookie = 'googtrans=/bg/en; path=/; domain=.' + location.hostname;
            } else {
                document.cookie = 'googtrans=; ' + exp;
                document.cookie = 'googtrans=; ' + exp + ' domain=' + location.hostname + ';';
                document.cookie = 'googtrans=; ' + exp + ' domain=.' + location.hostname + ';';
            }
            location.reload();
        }

        // On-demand translate button (MyMemory free API, bg→en)
        function gtTranslate(btn) {
            var target = document.querySelector(btn.dataset.target);
            if (!target) return;

            if (btn.dataset.state === '1') {
                target.textContent = btn.dataset.orig;
                btn.dataset.state = '0';
                btn.innerHTML = '<i class="bi bi-translate"></i> Translate';
                return;
            }

            var text = target.textContent.trim();
            if (!text) return;
            btn.innerHTML = '⏳';

            fetch('https://api.mymemory.translated.net/get?q=' + encodeURIComponent(text.substring(0, 500)) + '&langpair=bg|en')
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    if (data.responseStatus === 200) {
                        btn.dataset.orig = text;
                        target.textContent = data.responseData.translatedText;
                        btn.dataset.state = '1';
                        btn.innerHTML = '<i class="bi bi-arrow-counterclockwise"></i> Original';
                    } else {
                        btn.innerHTML = '❌ Error';
                    }
                })
                .catch(function () { btn.innerHTML = '❌ Error'; });
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        function googleTranslateElementInit() {
            new google.translate.TranslateElement({
                pageLanguage: 'bg',
                includedLanguages: 'en',
                autoDisplay: false
            }, 'google_translate_element');
            window.setTimeout(function () {
                if (window.GrooveHomeMapRefresh) {
                    window.GrooveHomeMapRefresh();
                } else if (window.GrooveHomeStartMap) {
                    window.GrooveHomeStartMap();
                }
            }, 1500);
        }
        window.googleTranslateElementInit = googleTranslateElementInit;
    </script>
    <script src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit" async defer></script>

    <partial name="_MobileNav" />

    <!-- PWA install banner -->
    <div id="evt-pwa-banner" hidden class="evt-pwa-banner">
        <button id="evt-pwa-close-btn" type="button" class="evt-pwa-banner__close" aria-label="Затвори">
            <i class="bi bi-x-lg"></i>
        </button>
        <div class="evt-pwa-banner__main">
            <img src="/img/logo.svg" alt="Evento" class="evt-pwa-banner__logo" />
            <div class="evt-pwa-banner__text">
                <strong>Инсталирай Evento</strong>
                <span>Добави към началния екран за по-добро изживяване</span>
            </div>
        </div>
        <!-- Step 1: choose platform -->
        <div id="evt-pwa-choose" class="evt-pwa-banner__choose">
            <button id="evt-pwa-android-btn" type="button" class="evt-pwa-banner__platform-btn">
                <i class="bi bi-android2"></i> Android
            </button>
            <button id="evt-pwa-ios-btn" type="button" class="evt-pwa-banner__platform-btn">
                <i class="bi bi-apple"></i> iOS
            </button>
        </div>
        <!-- Step 2a: Android instructions (shown only when deferred prompt unavailable) -->
        <div id="evt-pwa-android-steps" hidden class="evt-pwa-banner__steps">
            <ol>
                <li>Натисни <i class="bi bi-three-dots-vertical"></i> менюто на браузъра</li>
                <li>Избери <strong>"Добави към началния екран"</strong></li>
            </ol>
        </div>
        <!-- Step 2b: iOS instructions -->
        <div id="evt-pwa-ios-steps" hidden class="evt-pwa-banner__steps">
            <ol>
                <li>Натисни <i class="bi bi-box-arrow-up"></i> бутона за споделяне</li>
                <li>Избери <strong>"Добави към началния екран"</strong></li>
            </ol>
        </div>
    </div>
    <script>
        (function () {
            if (window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone === true) return;

            if ('serviceWorker' in navigator) {
                window.addEventListener('load', function () {
                    navigator.serviceWorker.register('/sw.js').catch(function () { });
                });
            }

            var dismissed = localStorage.getItem('evt_pwa_dismissed');
            if (dismissed && Date.now() - parseInt(dismissed, 10) < 7 * 24 * 3600 * 1000) return;

            var isMobile = /Mobi|Android|iPhone|iPad|iPod/i.test(navigator.userAgent);
            if (!isMobile) return;

            var isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;
            var deferred = null;
            var banner = document.getElementById('evt-pwa-banner');
            var choose = document.getElementById('evt-pwa-choose');
            var androidSteps = document.getElementById('evt-pwa-android-steps');
            var iosSteps = document.getElementById('evt-pwa-ios-steps');

            window.addEventListener('beforeinstallprompt', function (e) {
                e.preventDefault();
                deferred = e;
            });

            function dismiss() {
                banner.hidden = true;
                localStorage.setItem('evt_pwa_dismissed', String(Date.now()));
            }

            document.getElementById('evt-pwa-close-btn').addEventListener('click', dismiss);

            document.getElementById('evt-pwa-android-btn').addEventListener('click', function () {
                if (deferred) {
                    deferred.prompt();
                    deferred.userChoice.finally(function () { deferred = null; dismiss(); });
                } else {
                    choose.hidden = true;
                    androidSteps.hidden = false;
                }
            });

            document.getElementById('evt-pwa-ios-btn').addEventListener('click', function () {
                choose.hidden = true;
                iosSteps.hidden = false;
            });

            window.addEventListener('appinstalled', dismiss);

            setTimeout(function () {
                if (isIOS || deferred || isMobile) banner.hidden = false;
            }, 4000);
        })();
    </script>
</body>
</html>
