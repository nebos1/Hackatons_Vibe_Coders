@model MessagesIndexViewModel
@{
    ViewData["Title"] = "Messages";
}

<section class="groove-app-page social-messages-page" data-messages-index>
    <div class="groove-page-hero">
        <div class="groove-page-hero__copy">
            <span class="groove-stamp groove-stamp-teal" data-i18n="nav.messages">Messages</span>
            <h1 data-i18n-html="messages.index.title">Direct <span>messages</span>.</h1>
            <p data-i18n="messages.index.desc">Personal chats stay personal. Page inboxes are separated for organizers.</p>
        </div>
    </div>

    <div class="messages-search-bar" data-message-search>
        <i class="bi bi-search"></i>
        <input type="search"
               autocomplete="off"
               inputmode="search"
               placeholder="Търси човек, страница или последно съобщение..."
               data-i18n-placeholder="messages.search.placeholder"
               data-message-search-input />
        <button type="button" data-message-search-clear hidden>
            <i class="bi bi-x-lg"></i>
            <span data-i18n="common.clear">Изчисти</span>
        </button>
    </div>
    <div class="messages-search-empty" data-message-search-empty hidden>
        <i class="bi bi-chat-square-text"></i>
        <span data-i18n="messages.search.empty">Няма разговори по това търсене.</span>
    </div>

    <div class="social-message-board">
        @if (Model.RequestConversations.Any())
        {
            <section class="social-message-panel social-message-panel--requests">
                <div class="social-message-panel__head">
                    <span class="groove-kicker" data-i18n="messages.requests.panel">Requests</span>
                    <h2 data-i18n="messages.requests.title">Needs approval</h2>
                </div>

                <div class="social-message-list social-message-list--compact" data-message-list="requests">
                    @foreach (var conversation in Model.RequestConversations)
                    {
                        var initial = string.IsNullOrWhiteSpace(conversation.OtherUserName) ? "?" : conversation.OtherUserName[..1].ToUpperInvariant();
                        <a asp-action="Details" asp-route-token="@conversation.Token" class="social-conversation-row is-request" data-conversation-row data-token="@conversation.Token" data-list-key="requests" data-unseen="@conversation.UnseenCount">
                            @if (!string.IsNullOrWhiteSpace(conversation.OtherUserImageUrl))
                            {
                                <img src="@conversation.OtherUserImageUrl" alt="@conversation.OtherUserName" />
                            }
                            else
                            {
                                <span class="social-conversation-row__fallback">@initial</span>
                            }
                            <div>
                                <strong data-conversation-name>@conversation.OtherUserName</strong>
                                <small data-conversation-last>
                                    <span data-i18n="messages.request.incoming">New message request</span>
                                    @if (!string.IsNullOrWhiteSpace(conversation.LastMessage))
                                    {
                                        <span> - @conversation.LastMessage</span>
                                    }
                                </small>
                            </div>
                            <time data-conversation-time>@conversation.UpdatedAt.ToString("dd.MM HH:mm")</time>
                            @if (conversation.UnseenCount > 0)
                            {
                                <b data-conversation-badge>@conversation.UnseenCount</b>
                            }
                        </a>
                    }
                </div>
            </section>
        }

        <section class="social-message-panel">
            <div class="social-message-panel__head">
                <span class="groove-kicker" data-i18n="messages.personal.panel">Personal</span>
                <h2 data-i18n="messages.personal.title">Personal messages</h2>
            </div>

            <div class="social-message-list" data-message-list="personal">
                @if (!Model.PersonalConversations.Any())
                {
                    <div class="social-empty-panel" data-message-empty>
                        <i class="bi bi-chat-dots"></i>
                        <span data-i18n="messages.empty">No conversations yet. Open a profile and start a message.</span>
                    </div>
                }
                else
                {
                    @foreach (var conversation in Model.PersonalConversations)
                    {
                        var initial = string.IsNullOrWhiteSpace(conversation.OtherUserName) ? "?" : conversation.OtherUserName[..1].ToUpperInvariant();
                        <a asp-action="Details" asp-route-token="@conversation.Token" class="social-conversation-row" data-conversation-row data-token="@conversation.Token" data-list-key="personal" data-unseen="@conversation.UnseenCount">
                            @if (!string.IsNullOrWhiteSpace(conversation.OtherUserImageUrl))
                            {
                                <img src="@conversation.OtherUserImageUrl" alt="@conversation.OtherUserName" />
                            }
                            else
                            {
                                <span class="social-conversation-row__fallback">@initial</span>
                            }
                            <div>
                                <strong data-conversation-name>@conversation.OtherUserName</strong>
                                <small data-conversation-last>
                                    @if (conversation.Status == ConversationStatus.Pending)
                                    {
                                        if (conversation.IsRequestedByCurrentUser && !conversation.HasMessages)
                                        {
                                            <span data-i18n="messages.request.draft">Write first message</span>
                                        }
                                        else if (conversation.IsRequestedByCurrentUser)
                                        {
                                            <span data-i18n="messages.request.sent">Request waiting for approval</span>
                                        }
                                    }
                                    else if (conversation.Status == ConversationStatus.Declined)
                                    {
                                        <span data-i18n="messages.request.declined">Request declined</span>
                                    }
                                    else if (string.IsNullOrWhiteSpace(conversation.LastMessage))
                                    {
                                        <span data-i18n="messages.none">No messages yet</span>
                                    }
                                    else
                                    {
                                        @conversation.LastMessage
                                    }
                                </small>
                            </div>
                            <time data-conversation-time>@conversation.UpdatedAt.ToString("dd.MM HH:mm")</time>
                            @if (conversation.UnseenCount > 0)
                            {
                                <b data-conversation-badge>@conversation.UnseenCount</b>
                            }
                        </a>
                    }
                }
            </div>
        </section>

        @if (Model.HasOrganizerPages || Model.PageConversations.Any())
        {
            <section class="social-message-panel social-message-panel--page">
                <div class="social-message-panel__head">
                    <span class="groove-kicker" data-i18n="messages.pages.panel">Page inbox</span>
                    <h2 data-i18n="messages.pages.title">Messages to your public pages</h2>
                </div>

                <div class="social-message-list" data-message-list="page">
                    @if (!Model.PageConversations.Any())
                    {
                        <div class="social-empty-panel" data-message-empty>
                            <i class="bi bi-building"></i>
                            <span data-i18n="messages.pages.empty">No one has written to your pages yet.</span>
                        </div>
                    }
                    else
                    {
                        @foreach (var conversation in Model.PageConversations)
                        {
                            var initial = string.IsNullOrWhiteSpace(conversation.OtherUserName) ? "?" : conversation.OtherUserName[..1].ToUpperInvariant();
                            <a asp-action="Details" asp-route-token="@conversation.Token" class="social-conversation-row" data-conversation-row data-token="@conversation.Token" data-list-key="page" data-unseen="@conversation.UnseenCount">
                                @if (!string.IsNullOrWhiteSpace(conversation.OtherUserImageUrl))
                                {
                                    <img src="@conversation.OtherUserImageUrl" alt="@conversation.OtherUserName" />
                                }
                                else
                                {
                                    <span class="social-conversation-row__fallback">@initial</span>
                                }
                                <div>
                                    <strong data-conversation-name>@conversation.OtherUserName</strong>
                                    <small data-conversation-last>
                                        @if (conversation.CurrentUserOwnsPage)
                                        {
                                            <span><span data-i18n="messages.scope.page.inbox">Page inbox</span>: @conversation.PageName</span>
                                        }
                                        else
                                        {
                                            <span><span data-i18n="messages.scope.to.page">To page</span>: @conversation.PageName</span>
                                        }
                                        @if (conversation.Status == ConversationStatus.Pending && conversation.IsRequestedByCurrentUser && !conversation.HasMessages)
                                        {
                                            <span> - <span data-i18n="messages.request.draft">Write first message</span></span>
                                        }
                                        else if (!string.IsNullOrWhiteSpace(conversation.LastMessage))
                                        {
                                            <span> - @conversation.LastMessage</span>
                                        }
                                    </small>
                                </div>
                                <time data-conversation-time>@conversation.UpdatedAt.ToString("dd.MM HH:mm")</time>
                                @if (conversation.UnseenCount > 0)
                                {
                                    <b data-conversation-badge>@conversation.UnseenCount</b>
                                }
                            </a>
                        }
                    }
                </div>
            </section>
        }
    </div>
</section>
