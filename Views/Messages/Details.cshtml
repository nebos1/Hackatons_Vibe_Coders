@model ConversationDetailsViewModel
@{
    ViewData["Title"] = Model.OtherUserName;
    var initial = string.IsNullOrWhiteSpace(Model.OtherUserName) ? "?" : Model.OtherUserName[..1].ToUpperInvariant();
}

<section class="groove-app-page social-messages-page social-messages-page--chat">
    <div class="social-chat-shell" data-current-conversation-token="@Model.Token">
        <header class="social-chat-header">
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary" title="Back" data-i18n-title="common.back">
                <i class="bi bi-arrow-left"></i>
            </a>

            @if (Model.IsPageConversation && !Model.CurrentUserOwnsPage)
            {
                <div class="social-author-link">
                    @if (!string.IsNullOrWhiteSpace(Model.OtherUserImageUrl))
                    {
                        <img src="@Model.OtherUserImageUrl" alt="@Model.OtherUserName" class="social-avatar-xs" />
                    }
                    else
                    {
                        <span class="social-avatar-xs social-avatar-xs--fallback">@initial</span>
                    }
                    <span>
                        <strong>@Model.OtherUserName</strong>
                        <small data-i18n="messages.page.thread">Page conversation</small>
                    </span>
                </div>
            }
            else
            {
                <a asp-controller="Profiles" asp-action="Details" asp-route-id="@Model.OtherUserId" class="social-author-link">
                    @if (!string.IsNullOrWhiteSpace(Model.OtherUserImageUrl))
                    {
                        <img src="@Model.OtherUserImageUrl" alt="@Model.OtherUserName" class="social-avatar-xs" />
                    }
                    else
                    {
                        <span class="social-avatar-xs social-avatar-xs--fallback">@initial</span>
                    }
                    <span>
                        <strong>@Model.OtherUserName</strong>
                        @if (Model.IsPageConversation && Model.CurrentUserOwnsPage)
                        {
                            <small><span data-i18n="messages.replying.for.page">Replying for</span> @Model.PageName</small>
                        }
                    </span>
                </a>
            }
        </header>

        <div class="social-chat-thread">
            @if (Model.Status == ConversationStatus.Pending)
            {
                <div class="social-message-request @(Model.CanRespondToRequest ? "is-actionable" : "")">
                    @if (Model.CanSendInitialRequestMessage)
                    {
                        <strong data-i18n="messages.request.first.title">Send the first message</strong>
                        <p data-i18n="messages.request.first.desc">This will create a request. The other person can read it once and approve the chat before you continue.</p>
                    }
                    else if (Model.CanRespondToRequest)
                    {
                        <strong data-i18n="messages.request.title">Message request</strong>
                        <p data-i18n="messages.request.desc">Approve the request before the conversation can continue.</p>
                        <div class="groove-cta-row">
                            <form asp-action="Approve" asp-route-token="@Model.Token" method="post">
                                @Html.AntiForgeryToken()
                                <button class="groove-button groove-button-dark" type="submit">
                                    <i class="bi bi-check2"></i> <span data-i18n="messages.approve">Approve</span>
                                </button>
                            </form>
                            <form asp-action="Decline" asp-route-token="@Model.Token" method="post">
                                @Html.AntiForgeryToken()
                                <button class="groove-button groove-button-paper" type="submit">
                                    <i class="bi bi-x-lg"></i> <span data-i18n="messages.decline">Decline</span>
                                </button>
                            </form>
                        </div>
                    }
                    else if (Model.IsWaitingForApproval)
                    {
                        <strong data-i18n="messages.request.waiting">Request sent</strong>
                        <p data-i18n="messages.request.waiting.desc">You can continue after the request is approved.</p>
                    }
                    else
                    {
                        <strong data-i18n="messages.request.empty.title">Waiting for a first message</strong>
                        <p data-i18n="messages.request.empty.desc">This request will appear once the first message is sent.</p>
                    }
                </div>
            }
            else if (Model.Status == ConversationStatus.Declined)
            {
                <div class="social-message-request">
                    <strong data-i18n="messages.request.declined">Request declined</strong>
                    <p data-i18n="messages.request.declined.desc">This conversation is not active.</p>
                </div>
            }

            @foreach (var message in Model.Messages)
            {
                var canEditOrDelete = message.IsMine && !message.IsDeleted
                    && !message.SharedEventId.HasValue && !message.SharedPostId.HasValue;
                var replyPreview = string.IsNullOrWhiteSpace(message.Content)
                    ? message.ReplyToSharedLabel ?? "Съобщение"
                    : (message.Content.Length > 96 ? message.Content[..96] + "..." : message.Content);
                <article class="social-message-bubble @(message.IsMine ? "is-mine" : "") @(message.IsDeleted ? "is-deleted" : "") @(message.HasSharedCard ? "has-shared-card" : "")"
                         id="message-@message.Id"
                         data-message-id="@message.Id"
                         data-message-sender="@message.SenderName"
                         data-message-preview="@replyPreview"
                         data-message-shared-label="@(message.SharedEventId.HasValue ? "Споделено събитие" : message.SharedPostId.HasValue ? "Споделен пост" : "")">
                    <div class="social-message-bubble__head">
                        @if (!string.IsNullOrWhiteSpace(message.SenderImageUrl))
                        {
                            <img src="@message.SenderImageUrl" alt="@message.SenderName" class="social-avatar-xs" />
                        }
                        <strong class="small">@message.SenderName</strong>
                        <span class="groove-badge" data-i18n="@message.SenderBadgeKey">@message.SenderBadgeText</span>

                        @if (canEditOrDelete)
                        {
                            <div class="social-message-bubble__menu">
                                <button type="button" class="social-message-bubble__menu-trigger" data-bubble-menu-trigger title="Опции">
                                    <i class="bi bi-three-dots"></i>
                                </button>
                                <div class="social-message-bubble__menu-pop" data-bubble-menu-pop hidden>
                                    <button type="button" class="social-message-bubble__menu-item" data-bubble-edit data-content="@message.Content">
                                        <i class="bi bi-pencil"></i> Редактирай
                                    </button>
                                    <form asp-action="DeleteMessage" asp-route-id="@message.Id" method="post" onsubmit="return confirm('Изтриване на това съобщение?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="social-message-bubble__menu-item social-message-bubble__menu-item--danger">
                                            <i class="bi bi-trash"></i> Изтрий
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>

                    @if (message.IsDeleted)
                    {
                        <p class="social-message-bubble__deleted">
                            <i class="bi bi-slash-circle"></i>
                            <em>Това съобщение беше изтрито</em>
                        </p>
                    }
                    else
                    {
                        @if (message.ReplyToMessageId.HasValue)
                        {
                            <a href="#message-@message.ReplyToMessageId.Value" class="social-message-reply-context">
                                <i class="bi bi-reply"></i>
                                <span>
                                    <strong>@message.ReplyToSenderName</strong>
                                    @if (!string.IsNullOrWhiteSpace(message.ReplyToSharedLabel))
                                    {
                                        <em>@message.ReplyToSharedLabel</em>
                                    }
                                    <small>@message.ReplyToPreview</small>
                                </span>
                            </a>
                        }

                        @if (message.SharedEventId.HasValue)
                        {
                            <a asp-controller="Events" asp-action="Details" asp-route-id="@message.SharedEventId.Value" class="social-message-share-card social-message-share-card--event">
                                @if (!string.IsNullOrWhiteSpace(message.SharedEventImageUrl))
                                {
                                    <img src="@message.SharedEventImageUrl" alt="@message.SharedEventTitle" />
                                }
                                else
                                {
                                    <span class="social-message-share-card__fallback"><i class="bi bi-calendar-event"></i></span>
                                }
                                <span>
                                    <em data-i18n="share.card.event">Event</em>
                                    <strong>@message.SharedEventTitle</strong>
                                    <small>@message.SharedEventMeta</small>
                                </span>
                                <i class="bi bi-arrow-up-right"></i>
                            </a>
                        }

                        @if (message.SharedPostId.HasValue)
                        {
                            <a asp-controller="Posts" asp-action="Details" asp-route-id="@message.SharedPostId.Value" class="social-message-share-card social-message-share-card--post">
                                @if (!string.IsNullOrWhiteSpace(message.SharedPostImageUrl))
                                {
                                    <img src="@message.SharedPostImageUrl" alt="@message.SharedPostTitle" />
                                }
                                else
                                {
                                    <span class="social-message-share-card__fallback"><i class="bi bi-file-richtext"></i></span>
                                }
                                <span>
                                    <em data-i18n="share.card.post">Post</em>
                                    <strong>@message.SharedPostTitle</strong>
                                    <small>@message.SharedPostMeta</small>
                                </span>
                                <i class="bi bi-arrow-up-right"></i>
                            </a>
                        }

                        <p data-bubble-content>@EventsApp.Common.MentionRenderer.RenderWithMentions(message.Content)</p>

                        @if (canEditOrDelete)
                        {
                            <form asp-action="EditMessage" asp-route-id="@message.Id" method="post" class="social-message-bubble__edit" data-bubble-edit-form hidden>
                                @Html.AntiForgeryToken()
                                <textarea name="content" maxlength="2000" rows="2" required>@message.Content</textarea>
                                <div class="social-message-bubble__edit-actions">
                                    <button type="button" class="groove-button groove-button-paper" data-bubble-edit-cancel>Отказ</button>
                                    <button type="submit" class="groove-button groove-button-dark"><i class="bi bi-check2"></i> Запази</button>
                                </div>
                            </form>
                        }
                    }

                    <small class="social-message-bubble__meta">
                        <span><i class="bi bi-clock"></i> <span data-i18n="messages.sent">Sent</span> @message.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                        @if (message.EditedAt.HasValue && !message.IsDeleted)
                        {
                            <span title="@message.EditedAt.Value.ToString("dd.MM.yyyy HH:mm")"><i class="bi bi-pencil"></i> редактирано</span>
                        }
                        @if (message.IsMine && !message.IsDeleted)
                        {
                            @if (message.SeenAt.HasValue)
                            {
                                <span><i class="bi bi-check2-all"></i> <span data-i18n="messages.seen">Seen</span> @message.SeenAt.Value.ToString("dd.MM HH:mm")</span>
                            }
                            else
                            {
                                <span><i class="bi bi-check2"></i> <span data-i18n="messages.delivered">Delivered</span></span>
                            }
                        }
                        @if (!message.IsDeleted)
                        {
                            <button type="button" class="social-message-reply-button" data-message-reply>
                                <i class="bi bi-reply"></i>
                                <span data-i18n="messages.reply">Reply</span>
                            </button>
                            <form asp-action="ToggleLike" asp-route-id="@message.Id" method="post" class="social-message-like-form" data-message-like-form>
                                @Html.AntiForgeryToken()
                                <button type="submit" class="social-message-like @(message.CurrentUserLiked ? "is-liked" : "")" title="Like">
                                    <i class="bi @(message.CurrentUserLiked ? "bi-heart-fill" : "bi-heart")"></i>
                                    <span data-message-like-count>@message.LikesCount</span>
                                </button>
                            </form>
                        }
                    </small>
                </article>
            }
        </div>

        @if (Model.CanSendMessage && Model.ActingIdentities.Count > 0)
        {
            <form asp-action="Send" asp-route-token="@Model.Token" method="post" class="social-chat-compose">
                @Html.AntiForgeryToken()
                <input type="hidden" name="actingIdentityKey" value="@Model.ActingIdentities[0].Key" />
                <input type="hidden" name="replyToMessageId" value="" data-reply-to-message-id />
                <div class="social-chat-reply-preview" data-reply-preview hidden>
                    <i class="bi bi-reply"></i>
                    <span>
                        <strong data-reply-sender></strong>
                        <small data-reply-text></small>
                    </span>
                    <button type="button" data-reply-clear title="Clear reply"><i class="bi bi-x-lg"></i></button>
                </div>
                <span class="small text-muted"><span data-i18n="identity.replying.as">Replying as</span>: @Model.ActingIdentities[0].DisplayName</span>
                <input type="text" name="content" maxlength="2000" placeholder="Write a message..." data-i18n-placeholder="messages.placeholder" data-mentions required />
                <button type="submit" class="groove-button groove-button-dark">
                    <i class="bi bi-send"></i>
                    <span data-i18n="@(Model.CanSendInitialRequestMessage ? "messages.send.request" : "common.send")">Send</span>
                </button>
            </form>
        }
        else if (Model.CanSendMessage)
        {
            <div class="social-chat-compose">
                <span class="text-muted" data-i18n="messages.identity.unavailable">This page identity is no longer available for your account.</span>
            </div>
        }
    </div>
</section>

@if (Model.Status == ConversationStatus.Accepted)
{
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@7.0.5/dist/browser/signalr.min.js"></script>
    <script>
    (function () {
        var conversationToken = '@Model.Token';
        var currentUserId = '@(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "")';
        var thread = document.querySelector('.social-chat-thread');
        var lastId = @(Model.Messages.Count > 0 ? Model.Messages[^1].Id : 0);
        var pollTimer = null;
        var currentDelay = 1500;
        var DEFAULT_DELAY = 1500;
        var HIDDEN_DELAY = 10000;
        var MAX_DELAY = 15000;

        function scrollBottom() {
            if (thread) thread.scrollTop = thread.scrollHeight;
        }
        scrollBottom();
        window.addEventListener('load', scrollBottom);
        var lastImg = thread ? thread.querySelector('.social-message-bubble:last-of-type img') : null;
        if (lastImg && !lastImg.complete) lastImg.addEventListener('load', scrollBottom);

        function escapeHtml(s) {
            return String(s).replace(/[&<>"']/g, function (c) {
                return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
            });
        }
        function renderMentions(text) {
            return escapeHtml(text).replace(/(^|\s)@@([A-Za-z0-9._]{3,30})/g, function (_m, lead, name) {
                return lead + '<a class="evt-mention" href="/Profiles/ByName/' +
                    encodeURIComponent(name) + '" data-mention="' + escapeHtml(name) + '">@@' +
                    escapeHtml(name) + '</a>';
            });
        }
        function getToken() {
            var token = document.querySelector('input[name="__RequestVerificationToken"]');
            return token ? token.value : '';
        }
        function firstText() {
            for (var i = 0; i < arguments.length; i += 1) {
                if (arguments[i]) return arguments[i];
            }
            return '';
        }
        function buildReplyContext(m) {
            if (!m.replyToMessageId) return null;
            var link = document.createElement('a');
            link.href = '#message-' + m.replyToMessageId;
            link.className = 'social-message-reply-context';
            link.innerHTML = '<i class="bi bi-reply"></i><span><strong>' +
                escapeHtml(m.replyToSenderName || '') + '</strong>' +
                (m.replyToSharedLabel ? '<em>' + escapeHtml(m.replyToSharedLabel) + '</em>' : '') +
                '<small>' + escapeHtml(m.replyToPreview || '') + '</small></span>';
            return link;
        }
        function buildSharedCard(m) {
            var isEvent = !!m.sharedEventId;
            var isPost = !!m.sharedPostId;
            if (!isEvent && !isPost) return null;

            var href = isEvent ? '/e/' + m.sharedEventId : '/flow/p/' + m.sharedPostId;
            var image = firstText(isEvent ? m.sharedEventImageUrl : m.sharedPostImageUrl);
            var title = firstText(isEvent ? m.sharedEventTitle : m.sharedPostTitle, isEvent ? 'Event' : 'Post');
            var meta = firstText(isEvent ? m.sharedEventMeta : m.sharedPostMeta);
            var label = isEvent ? 'Event' : 'Post';
            var icon = isEvent ? 'bi-calendar-event' : 'bi-file-richtext';

            var card = document.createElement('a');
            card.href = href;
            card.className = 'social-message-share-card ' + (isEvent ? 'social-message-share-card--event' : 'social-message-share-card--post');
            card.innerHTML = (image
                ? '<img src="' + escapeHtml(image) + '" alt="' + escapeHtml(title) + '" />'
                : '<span class="social-message-share-card__fallback"><i class="bi ' + icon + '"></i></span>') +
                '<span><em>' + label + '</em><strong>' + escapeHtml(title) + '</strong><small>' +
                escapeHtml(meta) + '</small></span><i class="bi bi-arrow-up-right"></i>';
            return card;
        }

        function buildBubble(m) {
            var article = document.createElement('article');
            article.id = 'message-' + m.id;
            article.className = 'social-message-bubble' + (m.isMine ? ' is-mine' : '') +
                ((m.sharedEventId || m.sharedPostId) ? ' has-shared-card' : '');
            article.setAttribute('data-message-id', m.id);
            article.setAttribute('data-message-sender', m.senderName || '');
            article.setAttribute('data-message-preview', m.content || (m.sharedEventId ? 'Споделено събитие' : m.sharedPostId ? 'Споделен пост' : 'Съобщение'));
            article.setAttribute('data-message-shared-label', m.sharedEventId ? 'Споделено събитие' : m.sharedPostId ? 'Споделен пост' : '');

            var head = document.createElement('div');
            head.className = 'social-message-bubble__head';
            if (m.senderImageUrl) {
                var img = document.createElement('img');
                img.src = m.senderImageUrl;
                img.alt = m.senderName;
                img.className = 'social-avatar-xs';
                head.appendChild(img);
            }
            var name = document.createElement('strong');
            name.className = 'small';
            name.textContent = m.senderName;
            head.appendChild(name);
            if (m.senderBadgeText) {
                var badge = document.createElement('span');
                badge.className = 'groove-badge';
                badge.textContent = m.senderBadgeText;
                head.appendChild(badge);
            }
            article.appendChild(head);

            var replyContext = buildReplyContext(m);
            if (replyContext) article.appendChild(replyContext);

            var sharedCard = buildSharedCard(m);
            if (sharedCard) article.appendChild(sharedCard);

            var p = document.createElement('p');
            p.setAttribute('data-bubble-content', '');
            p.innerHTML = renderMentions(m.content || '');
            article.appendChild(p);

            var meta = document.createElement('small');
            meta.className = 'social-message-bubble__meta';
            meta.innerHTML = '<span><i class="bi bi-clock"></i> ' + m.createdAt + '</span>';
            if (m.isMine) {
                meta.innerHTML += '<span><i class="bi bi-check2"></i> Delivered</span>';
            }
            meta.innerHTML += '<button type="button" class="social-message-reply-button" data-message-reply>' +
                '<i class="bi bi-reply"></i><span>Reply</span></button>' +
                '<form action="/Messages/ToggleLike/' + m.id + '" method="post" class="social-message-like-form" data-message-like-form>' +
                (getToken() ? '<input name="__RequestVerificationToken" type="hidden" value="' + escapeHtml(getToken()) + '" />' : '') +
                '<button type="submit" class="social-message-like' + (m.currentUserLiked ? ' is-liked' : '') + '" title="Like">' +
                '<i class="bi ' + (m.currentUserLiked ? 'bi-heart-fill' : 'bi-heart') + '"></i>' +
                '<span data-message-like-count>' + (m.likesCount || 0) + '</span></button></form>';
            article.appendChild(meta);
            return article;
        }

        try {
            if (window.signalR) {
                var connection = new signalR.HubConnectionBuilder()
                    .withUrl('/hubs/chat')
                    .withAutomaticReconnect()
                    .build();

                connection.on('NewMessage', function (m) {
                    if (!m || !m.id || m.id <= lastId) return;
                    var wasAtBottom = thread.scrollHeight - thread.scrollTop - thread.clientHeight < 80;
                    m.isMine = m.senderId === currentUserId;
                    thread.appendChild(buildBubble(m));
                    lastId = m.id;
                    if (wasAtBottom) scrollBottom();
                });

                function joinConversation() {
                    connection.invoke('JoinConversation', conversationToken).catch(function () { });
                }

                connection.on('MessageLikeUpdated', function (update) {
                    if (!update || String(update.conversationToken || '').toLowerCase() !== String(conversationToken).toLowerCase()) return;
                    if (window.evtApplyMessageLikeUpdate) {
                        window.evtApplyMessageLikeUpdate(update, {
                            toast: !!update.liked && update.actorUserId !== currentUserId
                        });
                    }
                });

                connection.onreconnected(joinConversation);

                connection.start().then(joinConversation).catch(function (err) { if (console && console.error) console.error(err); });

                window.addEventListener('beforeunload', function () {
                    try { connection.invoke('LeaveConversation', conversationToken); } catch (e) { }
                });
                window.addEventListener('pagehide', function () {
                    try { connection.invoke('LeaveConversation', conversationToken); } catch (e) { }
                });
            }
        } catch (e) {
            if (console && console.error) console.error(e);
        }

        function schedule(delay) {
            if (pollTimer) clearTimeout(pollTimer);
            pollTimer = window.setTimeout(poll, delay);
        }

        function poll() {
            fetch('/inbox/poll/' + conversationToken + '?afterId=' + lastId, {
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                credentials: 'same-origin',
                cache: 'no-store'
            })
            .then(function (r) {
                if (r.status === 429) {
                    currentDelay = Math.min(MAX_DELAY, Math.max(currentDelay * 2, 5000));
                    return null;
                }
                if (!r.ok) {
                    currentDelay = Math.min(MAX_DELAY, currentDelay * 2);
                    return null;
                }
                currentDelay = DEFAULT_DELAY;
                return r.json();
            })
            .then(function (data) {
                if (!data || !data.messages || data.messages.length === 0) return;
                var wasAtBottom = thread.scrollHeight - thread.scrollTop - thread.clientHeight < 80;
                data.messages.forEach(function (m) {
                    thread.appendChild(buildBubble(m));
                    lastId = m.id;
                });
                if (wasAtBottom) scrollBottom();
            })
            .catch(function () {
                currentDelay = Math.min(MAX_DELAY, currentDelay * 2);
            })
            .finally(function () {
                // If the page is hidden, increase the delay but keep polling.
                var nextDelay = document.hidden ? Math.max(currentDelay, HIDDEN_DELAY) : currentDelay;
                schedule(nextDelay);
            });
        }

        // Start polling immediately
        schedule(currentDelay);

        // When page becomes visible, fetch immediately and reset delay
        document.addEventListener('visibilitychange', function () {
            if (!document.hidden) {
                currentDelay = DEFAULT_DELAY;
                // do an immediate poll to catch up
                if (pollTimer) clearTimeout(pollTimer);
                poll();
            }
        });
    })();
    </script>
}

<script>
    (function () {
        var page = document.querySelector('.social-messages-page--chat');
        var thread = document.querySelector('.social-chat-thread');
        if (!page || !thread) return;

        document.documentElement.classList.add('chat-thread-locked');
        document.body.classList.add('chat-thread-locked');

        function isThreadScroll(target) {
            return !!(target && target.closest && target.closest('.social-chat-thread'));
        }

        function preventOutsideChat(e) {
            if (!isThreadScroll(e.target)) {
                e.preventDefault();
            }
        }

        document.addEventListener('touchmove', preventOutsideChat, { passive: false });
        document.addEventListener('wheel', preventOutsideChat, { passive: false });

        function cleanup() {
            document.removeEventListener('touchmove', preventOutsideChat);
            document.removeEventListener('wheel', preventOutsideChat);
            document.documentElement.classList.remove('chat-thread-locked');
            document.body.classList.remove('chat-thread-locked');
        }

        window.addEventListener('pagehide', cleanup, { once: true });
        window.addEventListener('beforeunload', cleanup, { once: true });
    })();
</script>

<script>
    (function () {
        function showChatToast(message) {
            if (!message) return;
            var toast = document.createElement('div');
            toast.className = 'groove-toast';
            toast.textContent = message;
            document.body.appendChild(toast);
            requestAnimationFrame(function () { toast.classList.add('is-visible'); });
            window.setTimeout(function () {
                toast.classList.remove('is-visible');
                window.setTimeout(function () { toast.remove(); }, 220);
            }, 1700);
        }

        function applyMessageLikeUpdate(data, options) {
            if (!data || !data.messageId) return;
            var bubble = document.querySelector('.social-message-bubble[data-message-id="' + data.messageId + '"]');
            if (!bubble) return;
            var button = bubble.querySelector('.social-message-like');
            var count = bubble.querySelector('[data-message-like-count]');
            var icon = button ? button.querySelector('i') : null;
            var currentUserLiked = !!data.currentUserLiked;
            if (count) count.textContent = data.likesCount || 0;
            if (button) {
                button.classList.toggle('is-liked', currentUserLiked);
                button.classList.remove('ui-pop');
                void button.offsetWidth;
                button.classList.add('ui-pop');
                window.setTimeout(function () { button.classList.remove('ui-pop'); }, 320);
            }
            if (icon) {
                icon.className = 'bi ' + (currentUserLiked ? 'bi-heart-fill' : 'bi-heart');
            }
            if (options && options.toast) {
                showChatToast((data.actorName || 'Някой') + ' хареса съобщение');
            }
        }

        window.evtShowChatToast = showChatToast;
        window.evtApplyMessageLikeUpdate = applyMessageLikeUpdate;

        function closeAllMenus() {
            document.querySelectorAll('[data-bubble-menu-pop]').forEach(function (m) { m.hidden = true; });
        }
        document.addEventListener('click', function (e) {
            var trigger = e.target.closest('[data-bubble-menu-trigger]');
            if (trigger) {
                e.preventDefault();
                e.stopPropagation();
                var pop = trigger.parentElement.querySelector('[data-bubble-menu-pop]');
                var wasOpen = pop && !pop.hidden;
                closeAllMenus();
                if (pop && !wasOpen) pop.hidden = false;
                return;
            }
            if (!e.target.closest('[data-bubble-menu-pop]')) {
                closeAllMenus();
            }
        });

        document.addEventListener('click', function (e) {
            var editBtn = e.target.closest('[data-bubble-edit]');
            if (!editBtn) return;
            e.preventDefault();
            var bubble = editBtn.closest('.social-message-bubble');
            if (!bubble) return;
            closeAllMenus();
            var content = bubble.querySelector('[data-bubble-content]');
            var form = bubble.querySelector('[data-bubble-edit-form]');
            if (content) content.hidden = true;
            if (form) {
                form.hidden = false;
                var ta = form.querySelector('textarea');
                if (ta) { ta.focus(); ta.setSelectionRange(ta.value.length, ta.value.length); }
            }
        });

        document.addEventListener('click', function (e) {
            var cancelBtn = e.target.closest('[data-bubble-edit-cancel]');
            if (!cancelBtn) return;
            e.preventDefault();
            var bubble = cancelBtn.closest('.social-message-bubble');
            if (!bubble) return;
            var content = bubble.querySelector('[data-bubble-content]');
            var form = bubble.querySelector('[data-bubble-edit-form]');
            if (content) content.hidden = false;
            if (form) form.hidden = true;
        });

        function getMessageInfo(bubble) {
            return {
                id: bubble.getAttribute('data-message-id'),
                sender: bubble.getAttribute('data-message-sender') || '',
                preview: bubble.getAttribute('data-message-preview') || '',
                shared: bubble.getAttribute('data-message-shared-label') || ''
            };
        }

        function setReplyTarget(bubble) {
            var compose = document.querySelector('.social-chat-compose');
            if (!compose || !bubble) return;
            var info = getMessageInfo(bubble);
            var idInput = compose.querySelector('[data-reply-to-message-id]');
            var preview = compose.querySelector('[data-reply-preview]');
            var sender = compose.querySelector('[data-reply-sender]');
            var text = compose.querySelector('[data-reply-text]');
            var messageInput = compose.querySelector('input[name="content"]');
            if (idInput) idInput.value = info.id || '';
            if (sender) sender.textContent = info.sender;
            if (text) text.textContent = info.shared ? info.shared + ' · ' + info.preview : info.preview;
            if (preview) preview.hidden = false;
            if (messageInput) messageInput.focus();
        }

        document.addEventListener('click', function (e) {
            var reply = e.target.closest('[data-message-reply]');
            if (!reply) return;
            e.preventDefault();
            setReplyTarget(reply.closest('.social-message-bubble'));
        });

        document.addEventListener('click', function (e) {
            var clear = e.target.closest('[data-reply-clear]');
            if (!clear) return;
            e.preventDefault();
            var compose = clear.closest('.social-chat-compose');
            if (!compose) return;
            var idInput = compose.querySelector('[data-reply-to-message-id]');
            var preview = compose.querySelector('[data-reply-preview]');
            if (idInput) idInput.value = '';
            if (preview) preview.hidden = true;
        });

        document.addEventListener('submit', function (e) {
            var form = e.target.closest('[data-message-like-form]');
            if (!form) return;
            e.preventDefault();
            var button = form.querySelector('.social-message-like');
            if (button) button.disabled = true;
            fetch(form.action, {
                method: 'POST',
                body: new FormData(form),
                headers: { 'X-Requested-With': 'XMLHttpRequest', 'Accept': 'application/json' },
                credentials: 'same-origin'
            })
                .then(function (resp) {
                    if (!resp.ok) throw new Error('HTTP ' + resp.status);
                    return resp.json();
                })
                .then(function (data) {
                    var bubble = form.closest('.social-message-bubble');
                    if (bubble) {
                        data.messageId = bubble.getAttribute('data-message-id');
                    }
                    applyMessageLikeUpdate(data);
                    if (data.liked) {
                        showChatToast('Съобщението е харесано');
                    }
                })
                .catch(function () { form.submit(); })
                .finally(function () { if (button) button.disabled = false; });
        });

        document.addEventListener('dblclick', function (e) {
            if (e.target.closest('a, button, input, textarea, select, form')) return;
            var bubble = e.target.closest('.social-message-bubble:not(.is-deleted)');
            if (!bubble) return;
            var form = bubble.querySelector('[data-message-like-form]');
            if (form) {
                e.preventDefault();
                form.dispatchEvent(new Event('submit', { bubbles: true, cancelable: true }));
            }
        });
    })();
</script>
