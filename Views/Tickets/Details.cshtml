@model UserTicketDetailsViewModel
@{
    ViewData["Title"] = "Ticket Details";
    var qrUrl = $"https://api.qrserver.com/v1/create-qr-code/?size=240x240&data={Uri.EscapeDataString(Model.QrCode)}";
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <h1 class="h3"><i class="bi bi-ticket-perforated"></i> Ticket</h1>
    <div class="d-flex gap-2">
        <a asp-action="MyTickets" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> My Tickets
        </a>
        <a asp-action="DownloadPdf" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">
            <i class="bi bi-file-earmark-pdf"></i> Download PDF
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <h2 class="h4 mb-0">@Model.EventTitle</h2>
                    @if (Model.IsUsed)
                    {
                        <span class="badge bg-secondary fs-6">Used</span>
                    }
                    else
                    {
                        <span class="badge bg-success fs-6">Valid</span>
                    }
                </div>
                <div class="text-muted mb-3">@Model.TicketName</div>

                <dl class="row mb-0 small">
                    <dt class="col-sm-4">Location</dt>
                    <dd class="col-sm-8">@Model.Address, @Model.City</dd>
                    <dt class="col-sm-4">Starts</dt>
                    <dd class="col-sm-8">@Model.StartTime.ToString("yyyy-MM-dd HH:mm")</dd>
                    <dt class="col-sm-4">Price</dt>
                    <dd class="col-sm-8">@Model.Price.ToString("0.00")</dd>
                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-info">@Model.TransactionStatus</span>
                        <span class="badge bg-warning text-dark ms-1">Demo purchase</span>
                    </dd>
                    <dt class="col-sm-4">Holder</dt>
                    <dd class="col-sm-8">@Model.OwnerUserName (@Model.OwnerEmail)</dd>
                    <dt class="col-sm-4">Purchased</dt>
                    <dd class="col-sm-8">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
                    @if (Model.IsUsed && Model.UsedAt.HasValue)
                    {
                        <dt class="col-sm-4">Used at</dt>
                        <dd class="col-sm-8">@Model.UsedAt?.ToString("yyyy-MM-dd HH:mm")</dd>
                        @if (!string.IsNullOrEmpty(Model.UsedByOrganizerName))
                        {
                            <dt class="col-sm-4">Checked in by</dt>
                            <dd class="col-sm-8">@Model.UsedByOrganizerName</dd>
                        }
                    }
                </dl>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card shadow-sm text-center">
            <div class="card-body">
                <h5 class="card-title mb-3"><i class="bi bi-qr-code"></i> Entry QR</h5>
                <img src="@qrUrl" alt="QR" class="img-fluid mb-2 border rounded" style="max-width:240px;" />
                <div class="small text-muted text-break">@Model.QrCode</div>
                <div class="small text-muted mt-2">Show this QR at the entrance.</div>
            </div>
        </div>
    </div>
</div>
