@model UserTicketDetailsViewModel
@{
    ViewData["Title"] = "Детайли за билет";
    var qrUrl = Url.Action("Qr", "Tickets", new { id = Model.Id }) ?? string.Empty;
    var isAdmin = User.IsInRole(GlobalConstants.Roles.Admin);
    var isOwner = string.Equals(User.Identity?.Name, Model.OwnerUserName, StringComparison.OrdinalIgnoreCase);
    var backAction = isOwner ? "MyTickets" : isAdmin ? "Index" : "Dashboard";
    var backController = isOwner ? "Tickets" : isAdmin ? "Admin" : "Organizer";
    var backLabel = isOwner ? "Моите билети" : isAdmin ? "Админ" : "Организатор";
    var statusClass = Model.IsUsed ? "groove-status-badge-muted" : "groove-status-badge-success";
    var statusText = Model.IsUsed ? "Използван" : "Валиден";
}

<section class="groove-app-page">
    <div class="groove-page-hero">
        <div class="groove-page-hero__copy">
            <span class="groove-stamp groove-stamp-teal">Билет</span>
            <h1>@Model.EventTitle</h1>
            <p>@Model.TicketName</p>
        </div>
        <div class="groove-page-actions">
            <a asp-controller="@backController" asp-action="@backAction" class="groove-button groove-button-paper">
                <i class="bi bi-arrow-left"></i> Към @backLabel
            </a>
            <a asp-action="DownloadPdf" asp-route-id="@Model.Id" class="groove-button groove-button-dark">
                <i class="bi bi-file-earmark-pdf"></i> Изтегли PDF
            </a>
        </div>
    </div>

    <div class="groove-split">
        <div class="groove-info-card">
            <div class="d-flex justify-content-between align-items-start gap-2">
                <h2 class="groove-panel-title">@Model.TicketName</h2>
                <span class="groove-status-badge @statusClass">@statusText</span>
            </div>

            <dl class="groove-data-list mt-4">
                <dt>Локация</dt>
                <dd>@Model.Address, @Model.City</dd>

                <dt>Начало</dt>
                <dd>@Model.StartTime.ToString("dd.MM.yyyy HH:mm")</dd>

                @if (Model.EndTime.HasValue)
                {
                    <dt data-i18n="ticket.end">Край</dt>
                    <dd>@Model.EndTime.Value.ToString("dd.MM.yyyy HH:mm")</dd>
                }

                @if (!string.IsNullOrWhiteSpace(Model.SeatLabel))
                {
                    <dt data-i18n="ticket.seat">Място</dt>
                    <dd>@Model.SeatLabel</dd>
                }

                @if (!string.IsNullOrWhiteSpace(Model.AttendeeName))
                {
                    <dt>Име на билета</dt>
                    <dd>@Model.AttendeeName</dd>
                }

                @if (Model.PurchaseGroupId != Guid.Empty)
                {
                    <dt>Група</dt>
                    <dd>@(Model.IsPrimaryInPurchase ? "Основен билет" : "Допълнителен билет")</dd>
                }

                <dt>Цена</dt>
                <dd>@Model.Price.ToTicketPriceDisplay()</dd>

                <dt>Транзакция</dt>
                <dd>@Model.TransactionStatus.ToTransactionStatusDisplay()</dd>

                <dt>Притежател</dt>
                <dd>@Model.OwnerUserName (@Model.OwnerEmail)</dd>

                <dt>Купен</dt>
                <dd>@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</dd>

                @if (Model.IsUsed && Model.UsedAt.HasValue)
                {
                    <dt>Използван</dt>
                    <dd>@Model.UsedAt?.ToString("dd.MM.yyyy HH:mm")</dd>

                    @if (!string.IsNullOrEmpty(Model.UsedByOrganizerName))
                    {
                        <dt>Проверен от</dt>
                        <dd>@Model.UsedByOrganizerName</dd>
                    }
                }
            </dl>
        </div>

        <div class="groove-info-card groove-qr-card">
            <span class="groove-kicker">Вход</span>
            <h2 class="groove-panel-title">Твоят <span>QR код</span>.</h2>
            <img src="@qrUrl" alt="QR код за вход" class="img-fluid mt-3" />
            <div class="groove-code">@Model.QrCode</div>
            <p class="groove-panel-intro mt-3 mb-0">Покажи този код на входа за валидиране.</p>
        </div>
    </div>
</section>
