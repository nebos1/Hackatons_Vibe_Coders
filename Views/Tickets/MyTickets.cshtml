@model MyTicketsViewModel
@{
    ViewData["Title"] = "Моите билети";
}

<section class="groove-app-page">
    <div class="groove-page-hero">
        <div class="groove-page-hero__copy">
            <span class="groove-stamp groove-stamp-red">Билети</span>
            <h1>Твоите <span>запазени</span> места.</h1>
            <p>
                Всички купени билети са тук, заедно с QR кода и бърз достъп до PDF версията.
            </p>
        </div>
        <div class="groove-page-actions">
            <a asp-controller="Home" asp-action="Index" class="groove-button groove-button-paper">
                <i class="bi bi-calendar2-event"></i> Разгледай събития
            </a>
        </div>
    </div>

    @if (Model.Tickets.Count == 0)
    {
        <div class="groove-empty-card">
            <i class="bi bi-ticket-perforated"></i>
            <h2 class="groove-panel-title">Още нямаш <span>купени билети</span>.</h2>
            <p class="groove-panel-intro">
                Когато вземеш билет за събитие, той ще се появи тук с всички детайли за вход.
            </p>
            <div class="groove-form-actions justify-content-center">
                <a asp-controller="Home" asp-action="Index" class="groove-button groove-button-dark">
                    <i class="bi bi-search"></i> Намери събитие
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="groove-ticket-grid">
            @foreach (var t in Model.Tickets)
            {
                var statusClass = t.IsUsed ? "groove-status-badge-muted" : "groove-status-badge-success";
                var statusText = t.IsUsed ? "Използван" : "Валиден";

                <article class="groove-ticket-card">
                    <div class="d-flex justify-content-between align-items-start gap-2">
                        <span class="groove-ticket-meta">Купен на @t.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                        <span class="groove-status-badge @statusClass">@statusText</span>
                    </div>

                    <h3 class="mt-3">@t.EventTitle</h3>
                    <p>@t.TicketName</p>

                    <dl class="groove-data-list mt-3">
                        <dt>Локация</dt>
                        <dd>@t.Address, @t.City</dd>

                        <dt>Начало</dt>
                        <dd>@t.StartTime.ToString("dd.MM.yyyy HH:mm")</dd>

                        @if (!string.IsNullOrWhiteSpace(t.SeatLabel))
                        {
                            <dt data-i18n="ticket.seat">Място</dt>
                            <dd>@t.SeatLabel</dd>
                        }

                        <dt>Цена</dt>
                        <dd>@t.Price.ToTicketPriceDisplay()</dd>
                    </dl>

                    <div class="groove-ticket-footer">
                        <span class="groove-price">@t.Price.ToTicketPriceDisplay()</span>
                        <div class="groove-list-actions">
                            <a asp-action="Details" asp-route-id="@t.Id" class="groove-button groove-button-dark">
                                <i class="bi bi-eye"></i> Детайли
                            </a>
                            <a asp-action="DownloadPdf" asp-route-id="@t.Id" class="groove-button groove-button-paper">
                                <i class="bi bi-file-earmark-pdf"></i> PDF
                            </a>
                        </div>
                    </div>
                </article>
            }
        </div>
    }
</section>
