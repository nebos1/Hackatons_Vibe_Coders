@model TicketManageViewModel
@{
    ViewData["Title"] = $"Билети · {Model.EventTitle}";
}

<section class="groove-app-page">
    <div class="groove-page-hero">
        <div class="groove-page-hero__copy">
            <span class="groove-stamp groove-stamp-yellow">Билети</span>
            <h1>@Model.EventTitle</h1>
            <p>Управлявай типовете билети, наличностите и статуса на продажба за това събитие.</p>
        </div>
        <div class="groove-page-actions">
            <a asp-controller="Events" asp-action="Details" asp-route-id="@Model.EventId" class="groove-button groove-button-paper">
                <i class="bi bi-arrow-left"></i> Към събитието
            </a>
            <a asp-action="Create" asp-route-id="@Model.EventId" class="groove-button groove-button-dark">
                <i class="bi bi-plus-lg"></i> Нов тип билет
            </a>
        </div>
    </div>

    @if (Model.Tickets.Count == 0)
    {
        <div class="groove-empty-card">
            <i class="bi bi-ticket-perforated"></i>
            <h2 class="groove-panel-title">Още няма <span>типове билети</span>.</h2>
            <p class="groove-panel-intro">Добави първия билет, за да активираш продажбите за това събитие.</p>
        </div>
    }
    else
    {
        <div class="groove-table-card">
            <div class="groove-table-wrap">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Име</th>
                            <th>Цена</th>
                            <th>Общо</th>
                            <th>Остават</th>
                            <th>Продадени</th>
                            <th>Използвани</th>
                            <th>Статус</th>
                            <th>Names</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model.Tickets)
                        {
                            var statusClass = !t.IsActive ? "groove-status-badge-muted"
                                : t.QuantityRemaining <= 0 ? "groove-status-badge-danger"
                                : "groove-status-badge-success";
                            var statusText = !t.IsActive ? "Изключен"
                                : t.QuantityRemaining <= 0 ? "Разпродаден"
                                : "Активен";

                            <tr>
                                <td><strong>@t.Name</strong></td>
                                <td>@t.Price.ToTicketPriceDisplay()</td>
                                <td>@t.QuantityTotal</td>
                                <td>@t.QuantityRemaining</td>
                                <td>@t.Sold</td>
                                <td>@t.Used</td>
                                <td><span class="groove-status-badge @statusClass">@statusText</span></td>
                                <td>
                                    @if (t.RequiresAttendeeNames)
                                    {
                                        <span class="groove-status-badge groove-status-badge-muted">Required</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Optional</span>
                                    }
                                </td>
                                <td>
                                    <div class="groove-list-actions">
                                        <a asp-action="Edit" asp-route-id="@t.Id" class="groove-button groove-button-paper">
                                            <i class="bi bi-pencil"></i> Редакция
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@t.Id" class="groove-button groove-button-paper">
                                            <i class="bi bi-slash-circle"></i> Изключи
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</section>
