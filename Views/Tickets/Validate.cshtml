@model TicketValidationViewModel
@{
    ViewData["Title"] = "Валидиране на билет";
    var result = ViewBag.Result as TicketValidationResultViewModel;
    var dashboardController = User.IsInRole(GlobalConstants.Roles.Admin) ? "Admin" : (User.IsInRole(GlobalConstants.Roles.Organizer) ? "Organizer" : "Account");
    var dashboardAction = dashboardController == "Organizer" ? "Dashboard" : "Index";
    var dashboardLabel = dashboardController == "Account" ? "Профил" : (dashboardController == "Organizer" ? "Организатор" : "Админ");
}

<section class="groove-app-page ticket-validator-page">
    <div class="groove-page-hero">
        <div class="groove-page-hero__copy">
            <span class="groove-stamp groove-stamp-yellow">Вход</span>
            <h1>Сканирай QR кода и потвърди билета.</h1>
            <p>
                Сканирането само отваря информацията за билета. Валидирането става чак след натискане на бутона за потвърждение.
            </p>
        </div>
        <div class="groove-page-actions">
            <a asp-controller="@dashboardController" asp-action="@dashboardAction" class="groove-button groove-button-paper">
                <i class="bi bi-arrow-left"></i> Към @dashboardLabel
            </a>
        </div>
    </div>

    <div class="ticket-validator-grid">
        <div class="groove-form-panel groove-highlight-card ticket-scan-panel">
            <span class="groove-kicker">Проверка</span>
            <h2 class="groove-panel-title">Камера или ръчен код.</h2>
            <p class="groove-panel-intro">Отвори камерата на телефона или постави QR стойността ръчно.</p>

            <div class="ticket-camera-box" aria-live="polite">
                <video id="ticket-qr-video" playsinline muted></video>
                <div class="ticket-camera-placeholder">
                    <i class="bi bi-qr-code-scan"></i>
                    <span id="ticket-camera-status">Камерата е изключена.</span>
                </div>
            </div>

            <div class="ticket-camera-actions">
                <button type="button" id="ticket-camera-start" class="groove-button groove-button-dark">
                    <i class="bi bi-camera-video"></i> Отвори камера
                </button>
                <button type="button" id="ticket-camera-stop" class="groove-button groove-button-paper" hidden>
                    <i class="bi bi-camera-video-off"></i> Спри
                </button>
            </div>

            <form asp-action="Validate" method="post" id="ticket-validate-form" class="mt-4">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Confirm" value="false" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="QrCode" class="form-label">QR код</label>
                    <input asp-for="QrCode" class="form-control" autocomplete="off" autofocus />
                    <span asp-validation-for="QrCode" class="text-danger"></span>
                </div>

                <div class="groove-form-actions">
                    <button type="submit" class="groove-button groove-button-dark">
                        <i class="bi bi-search"></i> Провери билета
                    </button>
                </div>
            </form>
        </div>

        <div class="ticket-validation-card">
            @if (result == null)
            {
                <span class="groove-kicker">Резултат</span>
                <h2 class="groove-panel-title">Очаквам сканиране.</h2>
                <p class="groove-panel-intro">Тук ще се появи карта с данните за билета, преди да бъде маркиран като използван.</p>
            }
            else
            {
                var statusClass = result.Valid ? "groove-status-badge-success"
                    : result.RequiresConfirmation ? "groove-status-badge-muted"
                    : result.AlreadyUsed || result.NotAllowed ? "groove-status-badge-warning"
                    : "groove-status-badge-danger";

                <span class="groove-status-badge @statusClass">@result.Message</span>

                @if (result.Ticket != null)
                {
                    var qrUrl = Url.Action("Qr", "Tickets", new { id = result.Ticket.Id }) ?? string.Empty;

                    <div class="ticket-validation-card__body">
                        <div>
                            <span class="groove-kicker">Билет</span>
                            <h2 class="groove-panel-title">@result.Ticket.EventTitle</h2>
                            <p class="groove-muted-copy">@result.Ticket.TicketName</p>
                        </div>

                        <img class="ticket-validation-card__qr" src="@qrUrl" alt="QR код" />

                        <dl class="groove-data-list ticket-validation-data">
                            <dt>Притежател</dt>
                            <dd>@result.Ticket.OwnerUserName</dd>

                            <dt>Имейл</dt>
                            <dd>@result.Ticket.OwnerEmail</dd>

                            @if (!string.IsNullOrWhiteSpace(result.Ticket.AttendeeName))
                            {
                                <dt>Име на билет</dt>
                                <dd>@result.Ticket.AttendeeName</dd>
                            }

                            <dt>Дата</dt>
                            <dd>@result.Ticket.StartTime.ToString("dd.MM.yyyy HH:mm") - @(result.Ticket.EndTime?.ToString("HH:mm") ?? "")</dd>

                            <dt>Място</dt>
                            <dd>@result.Ticket.City, @result.Ticket.Address</dd>

                            @if (!string.IsNullOrWhiteSpace(result.Ticket.SeatLabel))
                            {
                                <dt>Седалка</dt>
                                <dd>@result.Ticket.SeatLabel</dd>
                            }

                            <dt>Плащане</dt>
                            <dd>@result.Ticket.TransactionStatus.ToTransactionStatusDisplay()</dd>

                            <dt>QR</dt>
                            <dd class="ticket-validation-code">@result.Ticket.QrCode</dd>

                            @if (result.Ticket.IsUsed && result.Ticket.UsedAt.HasValue)
                            {
                                <dt>Използван</dt>
                                <dd>@result.Ticket.UsedAt?.ToString("dd.MM.yyyy HH:mm")</dd>
                            }
                        </dl>

                        @if (result.RequiresConfirmation)
                        {
                            <form asp-action="Validate" method="post" class="ticket-confirm-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="QrCode" value="@result.Ticket.QrCode" />
                                <input type="hidden" name="Confirm" value="true" />
                                <button type="submit" class="groove-button groove-button-dark">
                                    <i class="bi bi-check2-circle"></i> Валидирай билета
                                </button>
                            </form>
                        }
                    </div>
                }
            }
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.min.js"></script>
    <script>
        (function () {
            var startButton = document.getElementById('ticket-camera-start');
            var stopButton = document.getElementById('ticket-camera-stop');
            var video = document.getElementById('ticket-qr-video');
            var cameraBox = video ? video.closest('.ticket-camera-box') : null;
            var status = document.getElementById('ticket-camera-status');
            var form = document.getElementById('ticket-validate-form');
            var qrInput = document.getElementById('QrCode');
            var stream = null;
            var scanning = false;
            var detector = null;
            var canvas = document.createElement('canvas');
            var canvasContext = canvas.getContext('2d', { willReadFrequently: true });

            function setStatus(text) {
                if (status) status.textContent = text;
            }

            function stopCamera() {
                scanning = false;
                if (stream) {
                    stream.getTracks().forEach(function (track) { track.stop(); });
                    stream = null;
                }
                if (video) video.srcObject = null;
                if (cameraBox) cameraBox.classList.remove('is-active');
                if (startButton) startButton.hidden = false;
                if (stopButton) stopButton.hidden = true;
                setStatus('Камерата е изключена.');
            }

            async function scanFrame() {
                if (!scanning || !video || video.readyState < 2) {
                    if (scanning) requestAnimationFrame(scanFrame);
                    return;
                }

                try {
                    var value = '';
                    if (detector) {
                        var codes = await detector.detect(video);
                        if (codes && codes.length > 0 && codes[0].rawValue) {
                            value = codes[0].rawValue;
                        }
                    } else if (window.jsQR && canvasContext) {
                        canvas.width = video.videoWidth || 640;
                        canvas.height = video.videoHeight || 480;
                        canvasContext.drawImage(video, 0, 0, canvas.width, canvas.height);
                        var imageData = canvasContext.getImageData(0, 0, canvas.width, canvas.height);
                        var code = window.jsQR(imageData.data, imageData.width, imageData.height, { inversionAttempts: 'dontInvert' });
                        if (code && code.data) {
                            value = code.data;
                        }
                    }

                    if (value) {
                        qrInput.value = value.trim();
                        setStatus('QR кодът е намерен. Отварям данните.');
                        stopCamera();
                        form.submit();
                        return;
                    }
                } catch (error) {
                    setStatus('Не успях да прочета кадъра. Опитай пак.');
                }

                requestAnimationFrame(scanFrame);
            }

            async function startCamera() {
                if (!window.isSecureContext) {
                    setStatus('Камерата работи само през HTTPS или localhost.');
                    return;
                }
                if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
                    setStatus('Браузърът няма достъп до камера.');
                    return;
                }
                try {
                    detector = null;
                    if ('BarcodeDetector' in window) {
                        try {
                            detector = new BarcodeDetector({ formats: ['qr_code'] });
                        } catch (error) {
                            detector = null;
                        }
                    }

                    if (!detector && !window.jsQR) {
                        setStatus('Зареждам QR четеца. Опитай отново след секунда.');
                        return;
                    }

                    try {
                        stream = await navigator.mediaDevices.getUserMedia({
                            video: { facingMode: { ideal: 'environment' } },
                            audio: false
                        });
                    } catch (error) {
                        stream = await navigator.mediaDevices.getUserMedia({ video: true, audio: false });
                    }

                    video.srcObject = stream;
                    await video.play();
                    scanning = true;
                    if (cameraBox) cameraBox.classList.add('is-active');
                    startButton.hidden = true;
                    stopButton.hidden = false;
                    setStatus('Насочи камерата към QR кода.');
                    requestAnimationFrame(scanFrame);
                } catch (error) {
                    setStatus('Камерата не може да се отвори. Провери разрешението в браузъра.');
                }
            }

            if (startButton) startButton.addEventListener('click', startCamera);
            if (stopButton) stopButton.addEventListener('click', stopCamera);
            window.addEventListener('beforeunload', stopCamera);
        })();
    </script>
}
