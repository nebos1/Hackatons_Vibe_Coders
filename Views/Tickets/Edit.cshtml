@model TicketCreateEditViewModel
@{
    ViewData["Title"] = "Редакция на билет";
}

<section class="groove-app-page groove-form-shell groove-form-shell-narrow">
    <div class="groove-page-hero">
        <div class="groove-page-hero__copy">
            <span class="groove-stamp groove-stamp-red">Билет</span>
            <h1>Редактирай типа <span>билет</span>.</h1>
            <p>Събитие: <strong>@Model.EventTitle</strong></p>
        </div>
        <div class="groove-page-actions">
            <a asp-action="Manage" asp-route-id="@Model.EventId" class="groove-button groove-button-paper">
                <i class="bi bi-arrow-left"></i> Назад към билетите
            </a>
        </div>
    </div>

    <div class="groove-form-panel">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="EventId" />
            <input type="hidden" asp-for="EventTitle" />

            <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="groove-form-grid groove-form-grid-3">
                <div class="mb-3">
                    <label asp-for="Price" class="form-label"></label>
                    <input asp-for="Price" id="Price" class="form-control" type="number" step="0.01" min="0" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                    <div class="form-check mt-2">
                        <input asp-for="IsFree" id="IsFree" class="form-check-input" />
                        <label asp-for="IsFree" class="form-check-label"></label>
                    </div>
                    <div class="form-text">Стойност 0 или отметка „Безплатен билет“ ще се показва като безплатен билет.</div>
                </div>
                <div class="mb-3">
                    <label asp-for="QuantityTotal" class="form-label"></label>
                    <input asp-for="QuantityTotal" class="form-control" type="number" min="0" />
                    <span asp-validation-for="QuantityTotal" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="QuantityRemaining" class="form-label"></label>
                    <input asp-for="QuantityRemaining" class="form-control" type="number" min="0" />
                    <span asp-validation-for="QuantityRemaining" class="text-danger"></span>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
            {
                <div class="mb-3">
                    <label class="form-label">Текуща снимка</label>
                    <div><img src="@Model.ImageUrl" alt="Текущ билет" style="max-height:140px;border-radius:6px;" /></div>
                    <input asp-for="ImageUrl" type="hidden" />
                </div>
            }

            <div class="mb-3">
                <label asp-for="ImageFile" class="form-label"></label>
                <input asp-for="ImageFile" class="form-control" type="file" accept="image/jpeg,image/png,image/webp,image/gif" />
                <span asp-validation-for="ImageFile" class="text-danger"></span>
            </div>

            <div class="form-check mb-3">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label"></label>
            </div>

            <div class="form-check mb-3">
                <input asp-for="RequiresAttendeeNames" class="form-check-input" />
                <label asp-for="RequiresAttendeeNames" class="form-check-label"></label>
                <div class="form-text">Когато е включено, купувачът попълва име за всеки билет.</div>
            </div>

            <div class="groove-form-actions">
                <button type="submit" class="groove-button groove-button-dark">
                    <i class="bi bi-check-lg"></i> Запази
                </button>
                <a asp-action="Manage" asp-route-id="@Model.EventId" class="groove-button groove-button-paper">Отказ</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_TicketPriceToggleScript" />
}
