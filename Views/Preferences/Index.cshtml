@model PreferencesViewModel?
@{
    ViewData["Title"] = "My Preferences";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0"><i class="bi bi-sliders"></i> My Preferences</h1>
    <div class="d-flex gap-2">
        <a asp-action="Edit" class="btn btn-primary"><i class="bi bi-pencil"></i> Edit</a>
        <a asp-controller="Events" asp-action="Recommended" class="btn btn-outline-secondary">
            <i class="bi bi-stars"></i> Recommended events
        </a>
    </div>
</div>

@if (Model == null)
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-sliders" style="font-size:2.5rem;"></i>
        <p class="mt-3 lead">You haven't set preferences yet.</p>
        <a asp-action="Edit" class="btn btn-primary mt-2"><i class="bi bi-plus-lg"></i> Set preferences</a>
    </div>
}
else
{
    <div class="card" style="max-width:480px;">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-5">Preferred genre</dt>
                <dd class="col-sm-7">@(Model.PreferredGenre.HasValue ? Model.PreferredGenre.ToString() : "—")</dd>

                <dt class="col-sm-5">Preferred city</dt>
                <dd class="col-sm-7">@(string.IsNullOrWhiteSpace(Model.PreferredCity) ? "—" : Model.PreferredCity)</dd>

                <dt class="col-sm-5">Minimum age</dt>
                <dd class="col-sm-7">@(Model.MinAge.HasValue ? Model.MinAge.ToString() : "—")</dd>

                <dt class="col-sm-5">Max distance (km)</dt>
                <dd class="col-sm-7">@(Model.MaxDistanceKm.HasValue ? Model.MaxDistanceKm.ToString() + " km" : "—")</dd>
            </dl>
        </div>
    </div>

    <form asp-action="Delete" method="post" class="mt-3">
        @Html.AntiForgeryToken()
        <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Clear all preferences?')">
            <i class="bi bi-x-circle"></i> Clear preferences
        </button>
    </form>
}
