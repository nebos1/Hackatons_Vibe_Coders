@using EventsApp.ViewModels.Account
@model ApplyOrganizerViewModel
@{
    ViewData["Title"] = "Редакция на кандидатура";
}

<section class="groove-app-page groove-form-shell">
    <div class="groove-page-hero">
        <div class="groove-page-hero__copy">
            <span class="groove-stamp groove-stamp-yellow">Кандидатура</span>
            <h1>Редактирай своята <span>заявка</span>.</h1>
            <p>Промените ще се виждат веднага от администраторите, докато кандидатурата чака преглед.</p>
        </div>
        <div class="groove-page-actions">
            <a asp-action="Index" class="groove-button groove-button-paper">
                <i class="bi bi-arrow-left"></i> Към профила
            </a>
        </div>
    </div>

    <div class="groove-alert groove-alert-warning mb-4">
        <strong>Статус:</strong> кандидатурата все още чака преглед.
    </div>

    <div class="groove-form-panel">
        <form asp-action="EditApplication" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="OrganizationName" class="form-label"></label>
                <input asp-for="OrganizationName" class="form-control" />
                <span asp-validation-for="OrganizationName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="groove-form-grid">
                <div class="mb-3">
                    <label asp-for="PhoneNumber" class="form-label"></label>
                    <input asp-for="PhoneNumber" class="form-control" />
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="City" class="form-label"></label>
                    <input asp-for="City" class="form-control" />
                    <span asp-validation-for="City" class="text-danger small"></span>
                </div>
            </div>

            <div class="groove-form-grid">
                <div class="mb-3">
                    <label asp-for="Country" class="form-label"></label>
                    <select asp-for="Country" class="form-select">
                        <option value="Bulgaria">Bulgaria</option>
                        <option value="Romania">Romania</option>
                        <option value="Greece">Greece</option>
                        <option value="Serbia">Serbia</option>
                        <option value="North Macedonia">North Macedonia</option>
                        <option value="Turkey">Turkey</option>
                        <option value="Other">Other</option>
                    </select>
                    <span asp-validation-for="Country" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="CompanyNumber" class="form-label"></label>
                    <input asp-for="CompanyNumber" class="form-control" />
                    <span asp-validation-for="CompanyNumber" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-4">
                <label asp-for="Website" class="form-label"></label>
                <input asp-for="Website" class="form-control" placeholder="https://..." />
                <span asp-validation-for="Website" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ReferralSource" class="form-label"></label>
                <select asp-for="ReferralSource" class="form-select">
                    <option value="">Избери</option>
                    <option value="Google">Google</option>
                    <option value="Instagram">Instagram</option>
                    <option value="Facebook">Facebook</option>
                    <option value="TikTok">TikTok</option>
                    <option value="Friend">Препоръка</option>
                    <option value="Event">От събитие</option>
                    <option value="Other">Друго</option>
                </select>
                <span asp-validation-for="ReferralSource" class="text-danger small"></span>
            </div>

            <div class="groove-form-actions">
                <button type="submit" class="groove-button groove-button-dark">
                    <i class="bi bi-check-lg"></i> Запази промените
                </button>
                <a asp-action="Index" class="groove-button groove-button-paper">Отказ</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
