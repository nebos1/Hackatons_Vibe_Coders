@using EventsApp.ViewModels.Account
@model ApplyOrganizerViewModel
@{
    ViewData["Title"] = "Кандидатствай като организатор";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="text-center mb-4">
            <i class="bi bi-person-badge-fill text-primary" style="font-size:3rem;"></i>
            <h1 class="h3 mt-2">Кандидатствай като организатор</h1>
            <p class="text-muted">Попълни данните за своята организация. Администратор ще прегледа заявката и ще получиш известие след одобрение.</p>
        </div>

        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Apply" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="OrganizationName" class="form-label fw-semibold"></label>
                        <input asp-for="OrganizationName" class="form-control" placeholder="напр. Sound Factory Events" />
                        <span asp-validation-for="OrganizationName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold"></label>
                        <textarea asp-for="Description" class="form-control" rows="4"
                                  placeholder="Опиши организацията си и какви събития организираш…"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="PhoneNumber" class="form-label fw-semibold"></label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="+359 88 123 4567" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="City" class="form-label fw-semibold"></label>
                            <input asp-for="City" class="form-control" placeholder="София" />
                            <span asp-validation-for="City" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Country" class="form-label fw-semibold"></label>
                            <select asp-for="Country" class="form-select">
                                <option value="Bulgaria">Bulgaria</option>
                                <option value="Romania">Romania</option>
                                <option value="Greece">Greece</option>
                                <option value="Serbia">Serbia</option>
                                <option value="North Macedonia">North Macedonia</option>
                                <option value="Turkey">Turkey</option>
                                <option value="Other">Other</option>
                            </select>
                            <span asp-validation-for="Country" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="CompanyNumber" class="form-label fw-semibold"></label>
                            <input asp-for="CompanyNumber" class="form-control" placeholder="123456789" />
                            <span asp-validation-for="CompanyNumber" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Website" class="form-label fw-semibold"></label>
                        <input asp-for="Website" class="form-control" placeholder="https://yourwebsite.com" />
                        <span asp-validation-for="Website" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ReferralSource" class="form-label fw-semibold"></label>
                        <select asp-for="ReferralSource" class="form-select">
                            <option value="">Избери</option>
                            <option value="Google">Google</option>
                            <option value="Instagram">Instagram</option>
                            <option value="Facebook">Facebook</option>
                            <option value="TikTok">TikTok</option>
                            <option value="Friend">Препоръка</option>
                            <option value="Event">От събитие</option>
                            <option value="Other">Друго</option>
                        </select>
                        <span asp-validation-for="ReferralSource" class="text-danger small"></span>
                    </div>

                    <div class="alert alert-info small mb-4">
                        <i class="bi bi-info-circle"></i>
                        С изпращането на тази заявка се съгласяваш данните за организацията да бъдат прегледани от нашия екип.
                        Само полето <strong>Име на организацията</strong> е задължително, а всички останали са по избор.
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-send"></i> Изпрати заявката
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Отказ</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
