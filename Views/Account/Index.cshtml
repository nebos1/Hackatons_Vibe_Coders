@using EventsApp.ViewModels.Account
@model AccountOverviewViewModel
@{
    ViewData["Title"] = "Account overview";
    var isAdmin = Model.Role == GlobalConstants.Roles.Admin;
    var isOrganizer = Model.Role == GlobalConstants.Roles.Organizer;
    var displayName = !string.IsNullOrWhiteSpace(Model.UserName) ? Model.UserName : Model.Email;
    var initial = string.IsNullOrWhiteSpace(displayName) ? "?" : displayName[..1].ToUpperInvariant();
    var roleClass = isAdmin ? "groove-status-badge-danger"
        : isOrganizer ? "groove-status-badge-success"
        : "groove-status-badge-muted";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<section class="groove-app-page account-overview-page">
    <article class="account-overview-hero">
        <div class="account-overview-hero__identity">
            <div class="groove-avatar">
                @if (!string.IsNullOrWhiteSpace(Model.ProfileImageUrl))
                {
                    <img src="@Model.ProfileImageUrl" alt="@displayName" />
                }
                else
                {
                    <span>@initial</span>
                }
            </div>
            <div>
                <span class="groove-stamp groove-stamp-red">Account</span>
                <h1>@displayName</h1>
                <p>@Model.Email</p>
                <div class="groove-inline-actions">
                    <span class="groove-status-badge @roleClass">@Model.Role.ToRoleDisplay()</span>
                    <span class="groove-badge"><i class="bi bi-calendar-check"></i> Since @Model.CreatedAt.ToString("MMMM yyyy")</span>
                </div>
            </div>
        </div>
        <div class="account-overview-hero__actions">
            <a asp-action="EditProfile" class="groove-button groove-button-dark">
                <i class="bi bi-person-gear"></i> Edit profile
            </a>
            @if (!string.IsNullOrWhiteSpace(currentUserId))
            {
                <a asp-controller="Profiles" asp-action="Details" asp-route-id="@currentUserId" class="groove-button groove-button-paper">
                    <i class="bi bi-person-lines-fill"></i> Public profile
                </a>
            }
            <a asp-controller="Posts" asp-action="Create" class="groove-button groove-button-paper">
                <i class="bi bi-plus-square"></i> New post
            </a>
            <a asp-controller="Preferences" asp-action="Index" class="groove-button groove-button-paper">
                <i class="bi bi-sliders"></i> Preferences
            </a>
        </div>
    </article>

    <section class="account-stat-strip">
        <a asp-controller="Profiles" asp-action="Followers" asp-route-id="@currentUserId">
            <strong>@Model.FollowersCount</strong>
            <span>Followers</span>
        </a>
        <a asp-controller="Profiles" asp-action="Following" asp-route-id="@currentUserId">
            <strong>@Model.FollowingCount</strong>
            <span>Following</span>
        </a>
        <span>
            <strong>@Model.PostsCount</strong>
            <span>Posts</span>
        </span>
        <span>
            <strong>@Model.SavedPostsCount</strong>
            <span>Saved posts</span>
        </span>
        <span>
            <strong>@Model.SavedEventsCount</strong>
            <span>Saved events</span>
        </span>
        <span>
            <strong>@Model.PurchasedTicketsCount</strong>
            <span>Tickets</span>
        </span>
    </section>

    <div class="account-overview-grid">
        <main class="account-overview-main">
            <section class="groove-page-section">
                <div class="groove-section-bar">
                    <div>
                        <span class="groove-kicker">Your posts</span>
                        <h2>What you have <span>published</span>.</h2>
                    </div>
                    <a asp-controller="Posts" asp-action="Create" class="groove-link">Create</a>
                </div>
                @if (Model.MyPosts.Any())
                {
                    <div class="social-post-list">
                        @foreach (var post in Model.MyPosts)
                        {
                            <partial name="_PostCard" model="post" />
                        }
                    </div>
                }
                else
                {
                    <div class="social-empty-panel">
                        <i class="bi bi-journal-plus"></i>
                        <span>You have not posted yet.</span>
                    </div>
                }
            </section>

            <section class="groove-page-section">
                <div class="groove-section-bar">
                    <div>
                        <span class="groove-kicker">Saved</span>
                        <h2>Posts you want to <span>keep</span>.</h2>
                    </div>
                </div>
                @if (Model.SavedPosts.Any())
                {
                    <div class="social-post-list">
                        @foreach (var post in Model.SavedPosts)
                        {
                            <partial name="_PostCard" model="post" />
                        }
                    </div>
                }
                else
                {
                    <div class="social-empty-panel">
                        <i class="bi bi-bookmark"></i>
                        <span>Saved posts will appear here.</span>
                    </div>
                }
            </section>
        </main>

        <aside class="account-overview-side">
            <section class="social-side-panel">
                <span class="groove-kicker">Quick actions</span>
                <div class="account-link-list">
                    <a asp-controller="Home" asp-action="Index"><i class="bi bi-house-door"></i> Home</a>
                    <a asp-controller="Posts" asp-action="Index"><i class="bi bi-grid"></i> Feed</a>
                    <a asp-controller="Messages" asp-action="Index"><i class="bi bi-chat-dots"></i> Messages</a>
                    <a asp-controller="Tickets" asp-action="MyTickets"><i class="bi bi-ticket-perforated"></i> My tickets</a>
                    <a asp-controller="Events" asp-action="Recommended"><i class="bi bi-stars"></i> Recommended events</a>
                </div>
            </section>

            @if (isAdmin || isOrganizer)
            {
                <section class="social-side-panel">
                    <span class="groove-kicker">Work tools</span>
                    <div class="account-link-list">
                        @if (isOrganizer)
                        {
                            <a asp-controller="Organizer" asp-action="Dashboard"><i class="bi bi-speedometer2"></i> Organizer dashboard</a>
                            <a asp-controller="Organizer" asp-action="Profiles"><i class="bi bi-person-badge"></i> Public organizer pages</a>
                        }
                        <a asp-controller="Tickets" asp-action="Validate"><i class="bi bi-qr-code-scan"></i> Validate tickets</a>
                        @if (isAdmin)
                        {
                            <a asp-controller="Admin" asp-action="Index"><i class="bi bi-shield-check"></i> Admin panel</a>
                            <a asp-controller="Admin" asp-action="Users"><i class="bi bi-people"></i> Users</a>
                        }
                    </div>
                </section>
            }
            else if (!Model.HasApplied)
            {
                <section class="social-side-panel account-promo-panel">
                    <span class="groove-kicker">Organizer</span>
                    <h3>Start publishing events.</h3>
                    <p>Apply when you are ready to sell tickets and manage events through GrooveOn.</p>
                    <a asp-action="Apply" class="groove-button groove-button-dark">
                        <i class="bi bi-send"></i> Apply
                    </a>
                </section>
            }
            else
            {
                <section class="social-side-panel account-promo-panel">
                    <span class="groove-kicker">Application</span>
                    <h3>Pending review.</h3>
                    <p>@Model.OrganizationName</p>
                    <a asp-action="EditApplication" class="groove-link">Edit application</a>
                </section>
            }

            <section class="social-side-panel">
                <div class="social-side-panel__head">
                    <span class="groove-kicker">Saved events</span>
                    <a asp-controller="Home" asp-action="Index" class="groove-link">Explore</a>
                </div>
                @if (Model.SavedEvents.Any())
                {
                    @foreach (var ev in Model.SavedEvents)
                    {
                        <a asp-controller="Events" asp-action="Details" asp-route-id="@ev.Id" class="social-event-mini">
                            <span>@ev.StartTime.ToString("dd MMM")</span>
                            <strong>@ev.Title</strong>
                            <small>@ev.City</small>
                        </a>
                    }
                }
                else
                {
                    <div class="social-empty-inline">Saved events will appear here.</div>
                }
            </section>

            <section class="social-side-panel">
                <div class="social-side-panel__head">
                    <span class="groove-kicker">Tickets</span>
                    <a asp-controller="Tickets" asp-action="MyTickets" class="groove-link">All</a>
                </div>
                @if (Model.RecentTickets.Count == 0)
                {
                    <div class="social-empty-inline">No purchased tickets yet.</div>
                }
                else
                {
                    <div class="account-ticket-list">
                        @foreach (var t in Model.RecentTickets)
                        {
                            <a asp-controller="Tickets" asp-action="Details" asp-route-id="@t.Id">
                                <strong>@t.EventTitle</strong>
                                <small>@t.StartTime.ToString("dd.MM.yyyy HH:mm") · @t.City</small>
                            </a>
                        }
                    </div>
                }
            </section>
        </aside>
    </div>
</section>
