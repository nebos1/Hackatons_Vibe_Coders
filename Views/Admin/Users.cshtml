@model IReadOnlyList<(EventsApp.Models.ApplicationUser User, IList<string> Roles)>
@{
    ViewData["Title"] = "Manage Users";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0"><i class="bi bi-people"></i> Users</h1>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i> Dashboard</a>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Username</th>
                <th>Email</th>
                <th>Current role</th>
                <th>Set role</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var (user, roles) in Model)
            {
                var currentRole = roles.FirstOrDefault() ?? "—";
                <tr>
                    <td><strong>@user.UserName</strong></td>
                    <td>@user.Email</td>
                    <td>
                        @if (currentRole == GlobalConstants.Roles.Admin)
                        {
                            <span class="badge bg-danger">Admin</span>
                        }
                        else if (currentRole == GlobalConstants.Roles.Organizer)
                        {
                            <span class="badge bg-primary">Organizer</span>
                        }
                        else if (currentRole == GlobalConstants.Roles.User)
                        {
                            <span class="badge bg-secondary">User</span>
                        }
                        else
                        {
                            <span class="badge bg-light text-dark">No role</span>
                        }
                    </td>
                    <td>
                        <form asp-action="SetRole" method="post" class="d-flex gap-1">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="userId" value="@user.Id" />
                            <select name="role" class="form-select form-select-sm" style="width:140px;">
                                <option value="@GlobalConstants.Roles.User" selected="@(currentRole == GlobalConstants.Roles.User)">User</option>
                                <option value="@GlobalConstants.Roles.Organizer" selected="@(currentRole == GlobalConstants.Roles.Organizer)">Organizer</option>
                                <option value="@GlobalConstants.Roles.Admin" selected="@(currentRole == GlobalConstants.Roles.Admin)">Admin</option>
                            </select>
                            <button type="submit" class="btn btn-sm btn-primary">Set</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
