@model IReadOnlyList<(EventsApp.Models.ApplicationUser User, IList<string> Roles)>
@{
    ViewData["Title"] = "Потребители";
}

<section class="groove-app-page">
    <div class="groove-page-hero">
        <div class="groove-page-hero__copy">
            <span class="groove-stamp groove-stamp-yellow">Роли</span>
            <h1>Управление на <span>потребители</span>.</h1>
            <p>Променяй роли и редактирай профили от едно място.</p>
        </div>
        <div class="groove-page-actions">
            <a asp-action="Index" class="groove-button groove-button-paper">
                <i class="bi bi-arrow-left"></i> Към админ
            </a>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="groove-empty-card">
            <i class="bi bi-people"></i>
            <h2 class="groove-panel-title">Няма <span>потребители</span>.</h2>
            <p class="groove-panel-intro">След като се регистрират акаунти, ще се появят тук.</p>
        </div>
    }
    else
    {
        <div class="groove-table-card">
            <div class="groove-table-wrap">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Потребител</th>
                            <th>Имейл</th>
                            <th>Текуща роля</th>
                            <th>Нова роля</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var (user, roles) in Model)
                        {
                            var currentRole = roles.FirstOrDefault();
                            var roleDisplay = currentRole.ToRoleDisplay();
                            var roleClass = currentRole == GlobalConstants.Roles.Admin ? "groove-status-badge-danger"
                                : currentRole == GlobalConstants.Roles.Organizer ? "groove-status-badge-success"
                                : "groove-status-badge-muted";

                            <tr>
                                <td><strong>@user.UserName</strong></td>
                                <td>@user.Email</td>
                                <td><span class="groove-status-badge @roleClass">@roleDisplay</span></td>
                                <td>
                                    <form asp-action="SetRole" method="post" class="d-flex flex-wrap gap-2">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <select name="role" class="form-select form-select-sm" style="max-width: 180px;">
                                            <option value="@GlobalConstants.Roles.User" selected="@(currentRole == GlobalConstants.Roles.User)">Потребител</option>
                                            <option value="@GlobalConstants.Roles.Organizer" selected="@(currentRole == GlobalConstants.Roles.Organizer)">Организатор</option>
                                            <option value="@GlobalConstants.Roles.Admin" selected="@(currentRole == GlobalConstants.Roles.Admin)">Админ</option>
                                        </select>
                                        <button type="submit" class="groove-button groove-button-dark">
                                            <i class="bi bi-check2"></i> Запази
                                        </button>
                                    </form>
                                </td>
                                <td>
                                    <form asp-action="DeleteUser" method="post"
                                          onsubmit="return confirm('Сигурен ли си? Това ще изтрие потребителя и свързаните му данни от базата.');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <button type="submit" class="groove-button groove-button-paper text-danger">
                                            <i class="bi bi-trash"></i> Изтрий
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</section>
