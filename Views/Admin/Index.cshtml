@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Panel";
}

<h1 class="h3 mb-4"><i class="bi bi-shield-check text-warning"></i> Admin Panel</h1>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 bg-light text-center">
            <div class="card-body">
                <div class="display-6 fw-bold text-primary">@Model.UsersCount</div>
                <div class="text-muted">Users</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 bg-light text-center">
            <div class="card-body">
                <div class="display-6 fw-bold text-primary">@Model.OrganizersCount</div>
                <div class="text-muted">Organizers</div>
                @if (Model.PendingOrganizersCount > 0)
                {
                    <span class="badge bg-warning text-dark">@Model.PendingOrganizersCount pending</span>
                }
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 bg-light text-center">
            <div class="card-body">
                <div class="display-6 fw-bold text-primary">@Model.VenuesCount</div>
                <div class="text-muted">Venues</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 bg-light text-center">
            <div class="card-body">
                <div class="display-6 fw-bold text-primary">@Model.EventsCount</div>
                <div class="text-muted">Events</div>
                @if (Model.PendingEventsCount > 0)
                {
                    <span class="badge bg-warning text-dark">@Model.PendingEventsCount pending</span>
                }
            </div>
        </div>
    </div>
</div>

<div class="d-flex flex-wrap gap-2 mb-4">
    <a asp-action="Organizers" class="btn btn-outline-primary">
        <i class="bi bi-person-badge"></i> Manage organizers
        @if (Model.PendingOrganizersCount > 0)
        {
            <span class="badge bg-warning text-dark ms-1">@Model.PendingOrganizersCount</span>
        }
    </a>
    <a asp-action="Events" class="btn btn-outline-primary">
        <i class="bi bi-calendar2-event"></i> Manage events
        @if (Model.PendingEventsCount > 0)
        {
            <span class="badge bg-warning text-dark ms-1">@Model.PendingEventsCount</span>
        }
    </a>
    <a asp-action="Posts" class="btn btn-outline-primary">
        <i class="bi bi-chat-square-text"></i> Manage posts
    </a>
    <a asp-action="Users" class="btn btn-outline-secondary">
        <i class="bi bi-people"></i> Manage users &amp; roles
    </a>
</div>

@if (Model.RecentPosts.Count > 0)
{
    <h2 class="h5 mb-3">Recent posts</h2>
    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-3">
        @foreach (var post in Model.RecentPosts)
        {
            <div class="col"><partial name="_PostCard" model="post" /></div>
        }
    </div>
}
