@model EventsApp.ViewModels.Wrapped.WrappedViewModel
@{
    ViewData["Title"] = $"Wrapped {Model.Year}";
    Layout = "_Layout";
}

<section class="evt-wrapped">
    <div class="evt-wrapped__nav">
        <span class="evt-wrapped__year">@Model.Year · WRAPPED</span>
        <a asp-controller="Profiles" asp-action="Details" asp-route-id="@User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier)" class="evt-wrapped__back">
            <i class="bi bi-x-lg"></i>
        </a>
    </div>

    <div class="evt-wrapped__deck">

        @if (Model.TotalEventsAttended == 0)
        {
            <article class="evt-wrap-slide is-cover">
                <span class="evt-wrap-slide__kicker">@Model.Year</span>
                <h1>Все още няма какво да обвием.</h1>
                <p>Иди на 1-2 събития през @Model.Year и се върни — ще ти направим красив ретроспектив.</p>
                <a asp-controller="Home" asp-action="Index" class="evt-btn evt-btn-primary">Намери събитие</a>
            </article>
        }
        else
        {
            <article class="evt-wrap-slide is-cover">
                <span class="evt-wrap-slide__kicker">@Model.Year</span>
                <h1>Здравей, <em>@Model.DisplayName</em>.</h1>
                <p>Това е твоята година във Evento.</p>
                <span class="evt-wrap-slide__hint"><i class="bi bi-arrow-down"></i> Скролни</span>
            </article>

            <article class="evt-wrap-slide is-purple">
                <span class="evt-wrap-slide__kicker">Брой събития</span>
                <h2 class="evt-wrap-slide__big">@Model.TotalEventsAttended</h2>
                <p>живи нощи прекара през @Model.Year.</p>
            </article>

            @if (Model.TopGenre != null)
            {
                <article class="evt-wrap-slide is-orange">
                    <span class="evt-wrap-slide__kicker">Топ жанр</span>
                    <h2>@Model.TopGenre</h2>
                    <p>@Model.TopGenreCount събития от този жанр — явно ти е до сърце.</p>
                </article>
            }

            @if (Model.TopCity != null)
            {
                <article class="evt-wrap-slide is-teal">
                    <span class="evt-wrap-slide__kicker">Любим град</span>
                    <h2>@Model.TopCity</h2>
                    <p>Това беше твоят дом за @Model.TopCityCount нощи.</p>
                </article>
            }

            <article class="evt-wrap-slide is-pink">
                <span class="evt-wrap-slide__kicker">На сцената</span>
                <h2 class="evt-wrap-slide__big">@Model.TotalHoursOnScene<sub>часа</sub></h2>
                <p>@Model.CitiesVisited @(Model.CitiesVisited == 1 ? "град" : "града") изпробва.</p>
            </article>

            @if (Model.TopOrganizer != null)
            {
                <article class="evt-wrap-slide is-indigo">
                    <span class="evt-wrap-slide__kicker">Топ организатор</span>
                    <h2>@Model.TopOrganizer</h2>
                    <p>@Model.TopOrganizerCount събития на тази сцена.</p>
                </article>
            }

            @if (Model.BusiestMonth != null)
            {
                <article class="evt-wrap-slide is-blue">
                    <span class="evt-wrap-slide__kicker">Най-натоварен месец</span>
                    <h2 style="text-transform:capitalize;">@Model.BusiestMonth</h2>
                    <p>@Model.BusiestMonthCount събития само за един месец.</p>
                </article>
            }

            @if (Model.TopEvents.Count > 0)
            {
                <article class="evt-wrap-slide is-green">
                    <span class="evt-wrap-slide__kicker">Топ моменти</span>
                    <h2>Твоите фаворити</h2>
                    <div class="evt-wrap-top">
                        @foreach (var ev in Model.TopEvents)
                        {
                            <a asp-controller="Events" asp-action="Details" asp-route-id="@ev.Id" class="evt-wrap-top__item">
                                @if (!string.IsNullOrWhiteSpace(ev.ImageUrl))
                                {
                                    <img src="@ev.ImageUrl" alt="@ev.Title" />
                                }
                                else
                                {
                                    <span class="evt-wrap-top__placeholder"><i class="bi bi-music-note-beamed"></i></span>
                                }
                                <strong>@ev.Title</strong>
                                <small>@ev.City · @ev.StartTime.ToString("dd.MM")</small>
                            </a>
                        }
                    </div>
                </article>
            }

            <article class="evt-wrap-slide is-mini">
                <div class="evt-wrap-grid">
                    <div>
                        <span class="evt-wrap-slide__kicker">Харесвания</span>
                        <h3>@Model.LikesGiven</h3>
                    </div>
                    <div>
                        <span class="evt-wrap-slide__kicker">Коментари</span>
                        <h3>@Model.CommentsPosted</h3>
                    </div>
                    <div>
                        <span class="evt-wrap-slide__kicker">Нови организатори</span>
                        <h3>@Model.OrganizersFollowed</h3>
                    </div>
                </div>
            </article>

            @if (!string.IsNullOrWhiteSpace(Model.AiSummary))
            {
                <article class="evt-wrap-slide is-cover">
                    <span class="evt-wrap-slide__kicker"><i class="bi bi-stars"></i> Сирма ти казва</span>
                    <p class="evt-wrap-quote">@Model.AiSummary</p>
                </article>
            }

            <article class="evt-wrap-slide is-cover">
                <span class="evt-wrap-slide__kicker">@Model.Year</span>
                <h2>Това беше твоята година.</h2>
                <p>Споделяй, запомняй, продължавай.</p>
                <div style="display:flex;gap:8px;margin-top:18px;flex-wrap:wrap;justify-content:center;">
                    <button type="button" class="evt-btn evt-btn-primary" onclick="window.print()">
                        <i class="bi bi-printer"></i> Запази
                    </button>
                    <a asp-controller="Home" asp-action="Index" class="evt-btn evt-btn-ghost" style="background:rgba(255,255,255,.15);color:#fff;border-color:rgba(255,255,255,.3);">
                        <i class="bi bi-house"></i> Към началото
                    </a>
                </div>
            </article>
        }
    </div>
</section>
