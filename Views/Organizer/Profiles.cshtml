@model OrganizerProfileListViewModel
@{
    ViewData["Title"] = "Публични организаторски страници";
}

<section class="groove-app-page account-overview-page">
    <div class="groove-page-hero">
        <div class="groove-page-hero__copy">
            <span class="groove-stamp groove-stamp-teal" data-i18n="organizer.pages.kicker">Организаторски страници</span>
            <h1 data-i18n-html="organizer.pages.title">Сменяй между <span>публични идентичности</span>.</h1>
            <p data-i18n="organizer.profiles.desc">Създавай отделни страници за брандове, зали, регулярни вечери или колективи. Избираш страница при публикуване на събитие.</p>
        </div>
        <div class="groove-page-actions">
            <a asp-action="Profile" class="groove-button groove-button-dark">
                <i class="bi bi-plus-lg"></i> <span data-i18n="organizer.pages.new">Нова страница</span>
            </a>
            <a asp-action="Dashboard" class="groove-button groove-button-paper">
                <i class="bi bi-speedometer2"></i> <span data-i18n="organizer.dashboard">Организаторско табло</span>
            </a>
        </div>
    </div>

    @if (!Model.Profiles.Any())
    {
            <div class="groove-empty-card">
                <i class="bi bi-person-badge"></i>
                <h2 class="groove-panel-title" data-i18n="organizer.pages.empty.title">Създай първата си публична страница.</h2>
                <p class="groove-panel-intro" data-i18n="organizer.pages.empty.desc">Трябва да имаш поне една страница преди да създаваш събития.</p>
                <a asp-action="Profile" class="groove-button groove-button-dark">
                    <i class="bi bi-plus-lg"></i> <span data-i18n="organizer.pages.create">Създай страница</span>
                </a>
        </div>
    }
    else
    {
        <div class="organizer-profile-grid">
            @foreach (var profile in Model.Profiles)
            {
                var initial = string.IsNullOrWhiteSpace(profile.DisplayName) ? "?" : profile.DisplayName[..1].ToUpperInvariant();
                <article class="organizer-profile-card">
                    <div class="organizer-profile-card__cover" style="@(string.IsNullOrWhiteSpace(profile.CoverImageUrl) ? "" : $"background-image:url('{profile.CoverImageUrl}')")">
                        @if (profile.IsDefault)
                        {
                            <span class="groove-status-badge groove-status-badge-success" data-i18n="organizer.pages.default">Основна</span>
                        }
                        @if (!profile.IsActive)
                        {
                            <span class="groove-status-badge groove-status-badge-muted" data-i18n="status.layout.Archived">Архивирана</span>
                        }
                    </div>
                    <div class="organizer-profile-card__body">
                        <div class="organizer-profile-card__avatar">
                            @if (!string.IsNullOrWhiteSpace(profile.AvatarImageUrl))
                            {
                                <img src="@profile.AvatarImageUrl" alt="@profile.DisplayName" />
                            }
                            else
                            {
                                <span>@initial</span>
                            }
                        </div>
                        <h2>@profile.DisplayName</h2>
                        @if (!string.IsNullOrWhiteSpace(profile.Tagline))
                        {
                            <p>@profile.Tagline</p>
                        }
                        <div class="organizer-profile-card__meta">
                            @if (!string.IsNullOrWhiteSpace(profile.City))
                            {
                                <span><i class="bi bi-geo-alt"></i> @profile.City</span>
                            }
                            <span><i class="bi bi-calendar-event"></i> @profile.EventsCount <span data-i18n="profile.events">събития</span></span>
                        </div>
                        <div class="groove-form-actions">
                            <a asp-action="Profile" asp-route-id="@profile.Id" class="groove-button groove-button-paper">
                                <i class="bi bi-pencil"></i> <span data-i18n="org.btn.edit">Редакция</span>
                            </a>
                            @if (!profile.IsDefault && profile.IsActive)
                            {
                                <form asp-action="SetDefaultProfile" asp-route-id="@profile.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="groove-button groove-button-paper">
                                        <i class="bi bi-pin-angle"></i> <span data-i18n="organizer.pages.make.default">Направи основна</span>
                                    </button>
                                </form>
                            }
                            <form asp-action="DeleteProfile" asp-route-id="@profile.Id" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="groove-button groove-button-paper">
                                    <i class="bi bi-trash"></i>
                                    @if (profile.EventsCount > 0)
                                    {
                                        <span data-i18n="organizer.pages.archive">Архивирай</span>
                                    }
                                    else
                                    {
                                        <span data-i18n="organizer.pages.delete">Изтрий</span>
                                    }
                                </button>
                            </form>
                        </div>
                    </div>
                </article>
            }
        </div>
    }
</section>
