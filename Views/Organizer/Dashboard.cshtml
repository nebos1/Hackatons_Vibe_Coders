@model OrganizerDashboardViewModel
@{
    ViewData["Title"] = "Organizer Dashboard";
}

@if (!Model.HasProfile)
{
    <div class="alert alert-warning">
        You don't have an organizer profile yet.
        <a asp-action="Profile" class="alert-link">Create your profile</a> to get started.
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="h3 mb-1">@Model.OrganizationName</h1>
            @if (!Model.Approved)
            {
                <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split"></i> Pending approval</span>
            }
            else
            {
                <span class="badge bg-success"><i class="bi bi-check-circle-fill"></i> Approved</span>
            }
        </div>
        <a asp-action="Profile" class="btn btn-outline-secondary btn-sm"><i class="bi bi-pencil"></i> Edit profile</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Description))
    {
        <p class="text-muted mb-4">@Model.Description</p>
    }

    <div class="row g-3 mb-4">
        <div class="col-sm-4">
            <div class="card text-center border-0 bg-light">
                <div class="card-body">
                    <div class="display-6 fw-bold text-primary">@Model.VenuesCount</div>
                    <div class="text-muted">Venues</div>
                </div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card text-center border-0 bg-light">
                <div class="card-body">
                    <div class="display-6 fw-bold text-primary">@Model.EventsCount</div>
                    <div class="text-muted">Events</div>
                </div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card text-center border-0 bg-light">
                <div class="card-body">
                    <div class="display-6 fw-bold text-primary">@Model.PostsCount</div>
                    <div class="text-muted">Posts</div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex flex-wrap gap-2 mb-4">
        <a asp-controller="Venues" asp-action="Create" class="btn btn-outline-primary"><i class="bi bi-building-add"></i> New venue</a>
        <a asp-controller="Events" asp-action="Create" class="btn btn-outline-primary"><i class="bi bi-calendar-plus"></i> New event</a>
        <a asp-controller="Posts" asp-action="Create" class="btn btn-outline-primary"><i class="bi bi-pencil-square"></i> New post</a>
    </div>

    @if (Model.RecentEvents.Count > 0)
    {
        <h2 class="h5 mb-3"><i class="bi bi-calendar2-event"></i> Recent events</h2>
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-3 mb-4">
            @foreach (var ev in Model.RecentEvents)
            {
                <div class="col"><partial name="_EventCard" model="ev" /></div>
            }
        </div>
    }

    @if (Model.RecentPosts.Count > 0)
    {
        <h2 class="h5 mb-3"><i class="bi bi-chat-square-text"></i> Recent posts</h2>
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-3">
            @foreach (var post in Model.RecentPosts)
            {
                <div class="col"><partial name="_PostCard" model="post" /></div>
            }
        </div>
    }
}
