@model OrganizerEventsViewModel
@{
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
    var boostedEventIdRaw = TempData["BoostedEventId"]?.ToString();
    var boostedEventId = int.TryParse(boostedEventIdRaw, out var parsedBoostedEventId)
        ? parsedBoostedEventId
        : (int?)null;

    ViewData["Title"] = "Моите събития";
}

<section class="groove-app-page">
    <div class="groove-page-hero">
        <div class="groove-page-hero__copy">
            <span class="groove-stamp groove-stamp-teal">Организатор</span>
            <h1>Моите събития.</h1>
            <p>Редактирай събития, управлявай билетите и следи кои промени чакат одобрение.</p>
        </div>
        <div class="groove-page-actions">
            <a asp-controller="Events" asp-action="Create" class="groove-button groove-button-dark">
                <i class="bi bi-plus-lg"></i> Създай събитие
            </a>
            <a asp-action="Dashboard" class="groove-button groove-button-paper">
                <i class="bi bi-arrow-left"></i> Табло
            </a>
        </div>
    </div>

    <section class="groove-table-card mb-4" style="padding:1rem;">
        <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
            <div>
                <span class="groove-kicker">VIP boost</span>
                <h2 class="h5 mb-1">Буустове за събития.</h2>
                <p class="text-muted mb-0">
                    Налични: <strong>@Model.VipBoostCreditsAvailable</strong>
                    · Използвани: <strong>@Model.VipBoostCreditsUsed</strong>.
                    VIP събитията получават по-силен ranking в Home и препоръките.
                </p>
            </div>
            <form asp-action="BuyVipBoostCredits" method="post" class="d-flex gap-2 flex-wrap">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@returnUrl" />
                <input type="number" name="quantity" value="1" min="1" max="20" class="form-control" style="max-width:88px;" />
                <button class="groove-button groove-button-dark organizer-vip-button" type="submit">
                    <i class="bi bi-stars"></i> Тестова покупка
                </button>
            </form>
        </div>
    </section>

    @if (Model.Events.Count == 0)
    {
        <div class="groove-empty-card">
            <i class="bi bi-calendar2-event"></i>
            <h2 class="groove-panel-title">Още няма събития.</h2>
            <p class="text-muted">Когато създадеш първото си събитие, ще можеш да го редактираш оттук.</p>
        </div>
    }
    else
    {
        <div class="groove-table-card">
            <div class="groove-table-wrap">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Събитие</th>
                            <th>Страница</th>
                            <th>Дата</th>
                            <th>Билети</th>
                            <th>Статус</th>
                            <th>VIP</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ev in Model.Events)
                        {
                            var isVipBoosted = ev.VipBoostScore > 0;
                            var isJustBoosted = boostedEventId == ev.Id;

                            <tr class="organizer-event-row @(isVipBoosted ? "is-vip-boosted" : "") @(isJustBoosted ? "is-vip-just-boosted" : "")">
                                <td>
                                    <strong>@ev.Title</strong>
                                    <span class="text-muted small d-block">@ev.City</span>
                                </td>
                                <td>@ev.OrganizerPageName</td>
                                <td>@ev.StartTime.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>
                                    @ev.TicketsCount вида
                                    <span class="text-muted small d-block">@ev.SoldTicketsCount продадени</span>
                                </td>
                                <td>
                                    @if (ev.HasPendingChanges)
                                    {
                                        <span class="groove-status-badge groove-status-badge-warning">Чака промени</span>
                                    }
                                    else if (ev.IsApproved)
                                    {
                                        <span class="groove-status-badge groove-status-badge-success">Публикувано</span>
                                    }
                                    else
                                    {
                                        <span class="groove-status-badge groove-status-badge-warning">Чака одобрение</span>
                                    }
                                </td>
                                <td>
                                    @if (isVipBoosted)
                                    {
                                        <span class="evt-card__chip evt-card__chip--vip organizer-vip-badge" style="position:static;">
                                            <i class="bi bi-stars"></i> VIP x@ev.VipBoostScore
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">-</span>
                                    }
                                </td>
                                <td>
                                    <div class="groove-list-actions">
                                        <a asp-controller="Events" asp-action="Details" asp-route-id="@ev.Id" class="groove-button groove-button-paper">
                                            <i class="bi bi-eye"></i> Преглед
                                        </a>
                                        <a asp-controller="Events" asp-action="Edit" asp-route-id="@ev.Id" class="groove-button groove-button-paper">
                                            <i class="bi bi-pencil"></i> Редакция
                                        </a>
                                        <a asp-controller="Tickets" asp-action="Manage" asp-route-id="@ev.Id" class="groove-button groove-button-paper">
                                            <i class="bi bi-ticket-perforated"></i> Билети
                                        </a>
                                        <a asp-controller="Events" asp-action="Delete" asp-route-id="@ev.Id" class="groove-button groove-button-paper">
                                            <i class="bi bi-trash"></i> Изтрий
                                        </a>
                                        @if (ev.IsApproved)
                                        {
                                            <form asp-action="BoostEvent" method="post" class="m-0">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="eventId" value="@ev.Id" />
                                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                                <button class="groove-button groove-button-dark organizer-vip-button" type="submit" @(Model.VipBoostCreditsAvailable <= 0 ? "disabled" : "")>
                                                    <i class="bi bi-stars"></i> VIP
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</section>
