@model OrganizerProfileViewModel
@{
    ViewData["Title"] = Model.Id.HasValue ? "Редакция на публична организаторска страница" : "Нова публична организаторска страница";
    var badgeClass = Model.Approved ? "groove-status-badge-success" : "groove-status-badge-warning";
    var badgeText = Model.Approved ? "Одобрен организатор" : "Чака одобрение";
    var badgeKey = Model.Approved ? "org.approved" : "org.pending";
    var actionKey = Model.Id.HasValue ? "org.btn.edit" : "home.events.create";
    var actionText = Model.Id.HasValue ? "Редактирай" : "Създай";
}

<section class="groove-app-page groove-form-shell">
    <div class="groove-page-hero">
        <div class="groove-page-hero__copy">
            <span class="groove-stamp groove-stamp-yellow" data-i18n="organizer.pages.public">Публична страница</span>
            <h1><span data-i18n="@actionKey">@actionText</span> <span data-i18n="organizer.pages.singular">организаторска страница</span>.</h1>
            <p data-i18n="organizer.pages.form.desc">Това е публичната идентичност, която хората виждат в събитията. Можеш да имаш няколко страници и да избираш една при публикуване.</p>
        </div>
        <div class="groove-page-actions">
            <span class="groove-status-badge @badgeClass" data-i18n="@badgeKey">@badgeText</span>
            <a asp-action="Profiles" class="groove-button groove-button-paper">
                <i class="bi bi-arrow-left"></i> <span data-i18n="organizer.pages.all">Всички страници</span>
            </a>
        </div>
    </div>

    <div class="groove-form-panel">
        <form asp-action="Profile" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <input asp-for="CurrentAvatarUrl" type="hidden" />
            <input asp-for="CurrentCoverUrl" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="groove-form-grid">
                <div class="mb-3">
                    <label asp-for="OrganizationName" class="form-label"></label>
                    <input asp-for="OrganizationName" class="form-control" placeholder="Име на клуб, колектив, промоутър..." data-i18n-placeholder="organizer.pages.name.placeholder" />
                    <span asp-validation-for="OrganizationName" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="City" class="form-label"></label>
                    <input asp-for="City" class="form-control" placeholder="София, Пловдив..." data-i18n-placeholder="organizer.pages.city.placeholder" />
                    <span asp-validation-for="City" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Tagline" class="form-label"></label>
                <input asp-for="Tagline" class="form-control" placeholder="Ъндърграунд техно вечери, live jazz сесии..." data-i18n-placeholder="organizer.pages.tagline.placeholder" />
                <span asp-validation-for="Tagline" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="groove-form-grid">
                <div class="mb-3">
                    <label asp-for="AvatarFile" class="form-label"></label>
                    @if (!string.IsNullOrWhiteSpace(Model.CurrentAvatarUrl))
                    {
                        <div class="mb-2"><img src="@Model.CurrentAvatarUrl" alt="Текущ профил" style="width:88px;height:88px;object-fit:cover;border-radius:50%;" /></div>
                    }
                    <input asp-for="AvatarFile" class="form-control" type="file" accept="image/jpeg,image/png,image/webp,image/gif" />
                    <span asp-validation-for="AvatarFile" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="CoverFile" class="form-label"></label>
                    @if (!string.IsNullOrWhiteSpace(Model.CurrentCoverUrl))
                    {
                        <div class="mb-2"><img src="@Model.CurrentCoverUrl" alt="Текуща корица" style="width:100%;max-height:120px;object-fit:cover;border-radius:6px;" /></div>
                    }
                    <input asp-for="CoverFile" class="form-control" type="file" accept="image/jpeg,image/png,image/webp,image/gif" />
                    <span asp-validation-for="CoverFile" class="text-danger small"></span>
                </div>
            </div>

            <div class="groove-form-grid">
                <div class="mb-3">
                    <label asp-for="PhoneNumber" class="form-label"></label>
                    <input asp-for="PhoneNumber" class="form-control" />
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="ContactEmail" class="form-label"></label>
                    <input asp-for="ContactEmail" class="form-control" />
                    <span asp-validation-for="ContactEmail" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Website" class="form-label"></label>
                <input asp-for="Website" class="form-control" placeholder="https://..." />
                <span asp-validation-for="Website" class="text-danger small"></span>
            </div>

            <div class="groove-form-grid groove-form-grid-3">
                <div class="mb-3">
                    <label asp-for="InstagramUrl" class="form-label"></label>
                    <input asp-for="InstagramUrl" class="form-control" placeholder="https://..." />
                    <span asp-validation-for="InstagramUrl" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="FacebookUrl" class="form-label"></label>
                    <input asp-for="FacebookUrl" class="form-control" placeholder="https://..." />
                    <span asp-validation-for="FacebookUrl" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="TikTokUrl" class="form-label"></label>
                    <input asp-for="TikTokUrl" class="form-control" placeholder="https://..." />
                    <span asp-validation-for="TikTokUrl" class="text-danger small"></span>
                </div>
            </div>

            <div class="groove-form-grid">
                <div class="mb-3">
                    <label asp-for="BrandColor" class="form-label"></label>
                    <input asp-for="BrandColor" class="form-control" type="color" value="@(string.IsNullOrWhiteSpace(Model.BrandColor) ? "#0f766e" : Model.BrandColor)" />
                    <span asp-validation-for="BrandColor" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="CompanyNumber" class="form-label"></label>
                    <input asp-for="CompanyNumber" class="form-control" />
                    <span asp-validation-for="CompanyNumber" class="text-danger small"></span>
                </div>
            </div>

            <div class="groove-form-grid">
                <label class="form-check">
                    <input asp-for="IsDefault" class="form-check-input" />
                    <span class="form-check-label" data-i18n="organizer.pages.use.default">Използвай като основна страница</span>
                </label>
                <label class="form-check">
                    <input asp-for="IsActive" class="form-check-input" />
                    <span class="form-check-label" data-i18n="organizer.pages.active.selectable">Активна и избираема</span>
                </label>
            </div>

            <div class="groove-note my-3">
                <strong data-i18n="organizer.pages.required">Задължително</strong>
                <span data-i18n="organizer.pages.required.desc">Нужна е поне една активна публична страница, преди организатор да създава събития.</span>
            </div>

            <div class="groove-form-actions">
                <button type="submit" class="groove-button groove-button-dark">
                    <i class="bi bi-check-lg"></i> <span data-i18n="organizer.pages.save">Запази страницата</span>
                </button>
                <a asp-action="Profiles" class="groove-button groove-button-paper" data-i18n="common.cancel">Отказ</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
