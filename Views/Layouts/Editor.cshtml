@model VenueLayoutEditorViewModel
@{
    var readOnly = ViewBag.ReadOnly as bool? == true;
    var actionText = readOnly ? "Преглед" : (Model.Id.HasValue ? "Редакция" : "Нов");
    var actionKey = readOnly ? "layout.preview" : (Model.Id.HasValue ? "org.btn.edit" : "layout.create.short");
    ViewData["Title"] = readOnly ? "Преглед на layout" : (Model.Id.HasValue ? "Редакция на layout" : "Нов layout");
}

<section class="groove-app-page layout-page">
    <div class="groove-page-hero">
        <div class="groove-page-hero__copy">
            <span class="groove-stamp groove-stamp-teal" data-i18n="layout.editor.kicker">Редактор на зала</span>
            <h1><span data-i18n="@actionKey">@actionText</span> <span data-i18n="layout.editor.seatmap">seat map</span>.</h1>
            <p data-i18n="layout.editor.desc">Създай преизползваема карта със етажи, секции, редове, правостоящи зони, VIP места и маси.</p>
        </div>
        <div class="groove-page-actions">
            <a asp-action="Index" class="groove-button groove-button-paper">
                <i class="bi bi-arrow-left"></i> <span data-i18n="layout.my">My layouts</span>
            </a>
        </div>
    </div>

    @if (Model.IsInUseWithSoldSeats)
    {
        <div class="groove-alert groove-alert-warning mb-3">
            <span data-i18n="layout.version.warning">This layout already has sold seats. Saving creates a new version instead of changing the active one.</span>
        </div>
    }

    <form method="post" class="layout-editor-form">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="layout-pro-meta">
            <label>
                <span asp-validation-for="VenueName" class="text-danger small"></span>
                <span data-i18n="layout.venue.name">Venue</span>
                <input asp-for="VenueName" class="form-control" readonly="@readOnly" />
            </label>
            <label>
                <span asp-validation-for="Name" class="text-danger small"></span>
                <span data-i18n="layout.name">Layout name</span>
                <input asp-for="Name" class="form-control" readonly="@readOnly" />
            </label>
            <label>
                <span>Статус</span>
                <select asp-for="Status" asp-items="Html.GetEnumSelectList<VenueLayoutStatus>()" class="form-select" disabled="@readOnly"></select>
            </label>
        </div>

        @if (!readOnly)
        {
            <section class="layout-ai-card">
                <div class="layout-ai-card__copy">
                    <span class="groove-kicker">AI старт</span>
                    <h2>Генерирай първа схема с AI от описание или снимка.</h2>
                    <p>Опиши залата с нормални думи, например: “2 етажа, 12 маси по 6 души, VIP зона отпред и 8 реда по 14 места”. Ако качиш снимка, AI ще опита да подреди схема по нея, а снимката остава като фон за донагласяне.</p>
                </div>
                <div class="layout-ai-card__controls">
                    <textarea data-ai-description rows="3" placeholder="Пример: театър с 2 етажа, партер 10 реда по 12 места, балкон 6 реда по 10 места, 8 VIP маси по 4 души отпред"></textarea>
                    <div class="layout-ai-card__actions">
                        <label class="layout-ai-upload">
                            <i class="bi bi-image"></i>
                            <span>Качи снимка</span>
                            <input type="file" accept="image/*" data-ai-image />
                        </label>
                        <button type="button" class="groove-button groove-button-dark" data-ai-generate>
                            <i class="bi bi-magic"></i> Генерирай
                        </button>
                        <button type="button" class="groove-button groove-button-paper" data-ai-clear-image>
                            <i class="bi bi-x-lg"></i> Махни снимката
                        </button>
                        <button type="button" class="groove-button groove-button-paper" data-layout-tutorial>
                            <i class="bi bi-play-circle"></i> Туториал
                        </button>
                    </div>
                    <span class="layout-ai-status" data-ai-status></span>
                </div>
            </section>
        }

        <div class="layout-pro-shell" data-layout-editor data-readonly="@(readOnly ? "true" : "false")">
            <aside class="layout-pro-toolbar">
                <button type="button" data-layout-add-floor disabled="@readOnly">
                    <i class="bi bi-layers"></i><span data-i18n="layout.floor.add">Етаж</span>
                </button>
                <button type="button" data-layout-add-section disabled="@readOnly">
                    <i class="bi bi-bounding-box"></i><span data-i18n="layout.section">Секция</span>
                </button>
                <button type="button" data-layout-add-standing disabled="@readOnly">
                    <i class="bi bi-people"></i><span data-i18n="layout.standing">Правостоящи</span>
                </button>
                <button type="button" data-layout-add-table disabled="@readOnly">
                    <i class="bi bi-record-circle"></i><span data-i18n="layout.table">Маса</span>
                </button>
                <button type="button" data-layout-generate-rows disabled="@readOnly">
                    <i class="bi bi-grid-3x3"></i><span data-i18n="layout.generate.rows">Редове</span>
                </button>
                <button type="button" data-layout-generate-table disabled="@readOnly">
                    <i class="bi bi-circle"></i><span data-i18n="layout.generate.table">Места около маса</span>
                </button>
                <button type="button" data-layout-undo disabled="@readOnly">
                    <i class="bi bi-arrow-counterclockwise"></i><span>Назад</span>
                </button>
                <button type="button" data-layout-redo disabled="@readOnly">
                    <i class="bi bi-arrow-clockwise"></i><span>Напред</span>
                </button>
                <button type="button" data-layout-duplicate disabled="@readOnly">
                    <i class="bi bi-copy"></i><span data-i18n="layout.duplicate.item">Дублирай</span>
                </button>
                <button type="button" class="is-danger" data-layout-delete disabled="@readOnly">
                    <i class="bi bi-trash"></i><span data-i18n="layout.delete.item">Изтрий</span>
                </button>
            </aside>

            <main class="layout-pro-workspace">
                <div class="layout-pro-floorbar">
                    <div class="layout-pro-floor-tabs" data-layout-floors></div>
                    <label class="layout-pro-floor-name">
                        <span data-i18n="layout.floor.name">Име на етаж</span>
                        <input type="text" data-layout-floor-name disabled="@readOnly" />
                    </label>
                </div>
                <div class="layout-pro-stage-scroll">
                    <div class="layout-pro-stage" data-layout-stage>
                        <div class="layout-pro-stage__label">СЦЕНА</div>
                    </div>
                </div>
            </main>

            <aside class="layout-pro-panel">
                <div>
                    <span class="groove-kicker" data-i18n="layout.selected">Избрано</span>
                    <h2 data-layout-selected-title>Нищо не е избрано</h2>
                </div>

                <div class="layout-pro-panel__group" data-layout-section-panel>
                    <label>
                        <span data-i18n="layout.section.name">Име на секция</span>
                        <input type="text" data-section-name disabled="@readOnly" />
                    </label>
                    <label>
                        <span data-i18n="layout.section.type">Тип</span>
                        <select data-section-type disabled="@readOnly">
                            <option value="Seated">Седящи места</option>
                            <option value="Standing">Правостоящи</option>
                            <option value="VIP">VIP</option>
                            <option value="Table">Маси</option>
                        </select>
                    </label>
                    <label>
                        <span data-i18n="layout.section.shape">Форма</span>
                        <select data-section-shape disabled="@readOnly">
                            <option value="Rectangle">Правоъгълник</option>
                            <option value="Rounded">Заоблена</option>
                            <option value="Circle">Кръг</option>
                            <option value="Stage">Сцена</option>
                        </select>
                    </label>
                    <label>
                        <span data-i18n="layout.price.modifier">Добавка към цена</span>
                        <input type="number" step="0.01" data-section-price disabled="@readOnly" />
                    </label>
                    <div class="layout-pro-grid-2">
                        <label><span>X</span><input type="number" data-section-x disabled="@readOnly" /></label>
                        <label><span>Y</span><input type="number" data-section-y disabled="@readOnly" /></label>
                        <label><span>W</span><input type="number" data-section-width disabled="@readOnly" /></label>
                        <label><span>H</span><input type="number" data-section-height disabled="@readOnly" /></label>
                    </div>
                    <label>
                        <span data-i18n="layout.rotation">Завъртане</span>
                        <input type="range" min="-45" max="45" step="1" data-section-rotation disabled="@readOnly" />
                    </label>
                </div>

                <div class="layout-pro-panel__group" data-layout-seat-panel>
                    <label>
                        <span data-i18n="ticket.seat">Име на място / маса</span>
                        <input type="text" data-seat-label disabled="@readOnly" />
                    </label>
                    <div class="layout-pro-grid-2">
                        <label><span>Ред</span><input type="text" data-seat-row disabled="@readOnly" /></label>
                        <label><span>Номер</span><input type="text" data-seat-number disabled="@readOnly" /></label>
                    </div>
                    <label>
                        <span data-i18n="layout.seat.type">Тип място</span>
                        <select data-seat-type disabled="@readOnly">
                            <option value="Standard">Стандартно</option>
                            <option value="Accessible">Достъпно</option>
                            <option value="VIP">VIP</option>
                            <option value="Table">Маса</option>
                        </select>
                    </label>
                    <label>
                        <span data-i18n="layout.seat.status">Статус</span>
                        <select data-seat-status disabled="@readOnly">
                            <option value="Active">Активно</option>
                            <option value="Blocked">Блокирано</option>
                        </select>
                    </label>
                    <div class="layout-pro-grid-2">
                        <label><span>X</span><input type="number" data-seat-x disabled="@readOnly" /></label>
                        <label><span>Y</span><input type="number" data-seat-y disabled="@readOnly" /></label>
                        <label><span>Размер</span><input type="number" data-seat-radius disabled="@readOnly" /></label>
                        <label><span>Хора</span><input type="number" min="1" max="100" data-seat-capacity disabled="@readOnly" /></label>
                    </div>
                    <label class="layout-pro-check">
                        <input type="checkbox" data-seat-unlimited disabled="@readOnly" />
                        <span>Без лимит за група</span>
                    </label>
                </div>

                <div class="layout-pro-panel__group">
                    <span class="groove-kicker" data-i18n="layout.quick.generate">Бързо генериране</span>
                    <div class="layout-pro-grid-2">
                        <label><span>Редове</span><input type="number" min="1" value="5" data-rows-count disabled="@readOnly" /></label>
                        <label><span>В ред</span><input type="number" min="1" value="10" data-rows-size disabled="@readOnly" /></label>
                        <label><span>Около маса</span><input type="number" min="2" value="6" data-table-size disabled="@readOnly" /></label>
                        <label><span>Кап. маса</span><input type="number" min="1" value="4" data-table-capacity disabled="@readOnly" /></label>
                    </div>
                </div>
            </aside>
        </div>

        <div class="layout-tutorial" data-layout-tutorial-panel hidden>
            <div class="layout-tutorial__dialog">
                <button type="button" class="layout-tutorial__close" data-layout-tutorial-close aria-label="Затвори">
                    <i class="bi bi-x-lg"></i>
                </button>
                <span class="groove-kicker">Туториал</span>
                <h2>Как да направиш схема за 2 минути</h2>
                <ol>
                    <li><strong>AI старт:</strong> опиши залата или качи снимка като фон.</li>
                    <li><strong>Етажи:</strong> добави партер, балкон или VIP ниво.</li>
                    <li><strong>Секции:</strong> създай редове, правостоящи зони или маси.</li>
                    <li><strong>Drag & drop:</strong> мести секции и места директно върху сцената.</li>
                    <li><strong>Маси:</strong> капацитетът е за една група. Ако е без лимит, масата пак се продава само веднъж.</li>
                    <li><strong>Undo:</strong> Ctrl+Z или бутона “Назад” връща последната промяна.</li>
                </ol>
            </div>
        </div>

        <input asp-for="LayoutJson" type="hidden" data-layout-json />

        @if (!readOnly)
        {
            <div class="groove-form-actions mt-3">
                <button type="submit" class="groove-button groove-button-dark">
                    <i class="bi bi-check-lg"></i> <span data-i18n="layout.save">Запази layout</span>
                </button>
                <a asp-action="Index" class="groove-button groove-button-paper" data-i18n="common.cancel">Отказ</a>
            </div>
        }
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/layout-editor.js" asp-append-version="true"></script>
}
