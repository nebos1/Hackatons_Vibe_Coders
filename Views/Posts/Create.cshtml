@model PostCreateEditViewModel
@{
    ViewData["Title"] = "Нова публикация";
}

<section class="groove-app-page groove-form-shell">
    <div class="groove-page-hero">
        <div class="groove-page-hero__copy">
            <span class="groove-stamp groove-stamp-teal">Поток</span>
            <h1>Нова <span>публикация</span>.</h1>
            <p>Сподели новина, настроение или ъпдейт около събитие с добавена снимка или видео.</p>
        </div>
        <div class="groove-page-actions">
            <a asp-action="Index" class="groove-button groove-button-paper">
                <i class="bi bi-arrow-left"></i> Към потока
            </a>
        </div>
    </div>

    <div class="groove-form-panel">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="groove-note mb-3">
                <strong data-i18n="workspace.publish.context">Publishing context</strong>
                <span>
                    <span data-i18n="workspace.publish.as">Publishing as</span>: @Model.ActivePageName
                    · <span data-i18n="workspace.feed.visible">Visible in Discover</span>
                    · <span data-i18n="workspace.payments.to">Payments go to</span>: @Model.ActiveWorkspaceName
                </span>
            </div>

            <div class="mb-3">
                <label asp-for="Content" class="form-label"></label>
                <textarea asp-for="Content" class="form-control" rows="6" placeholder="Напиши нещо... (@@username за тагване)" data-mentions></textarea>
                <span asp-validation-for="Content" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="EventId" class="form-label"></label>
                <select asp-for="EventId" asp-items="Model.Events" class="form-select">
                    <option value="">Без свързано събитие</option>
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="MediaFile" class="form-label"></label>
                <input asp-for="MediaFile" class="form-control" type="file"
                       accept="image/jpeg,image/png,image/gif,image/webp,video/mp4,video/webm,video/quicktime" />
                <div class="form-text">Снимка до 5 MB · Видео до 100 MB. Поддържани: jpg, png, gif, webp, mp4, webm, mov.</div>
                <span asp-validation-for="MediaFile" class="text-danger small"></span>
            </div>

            <div class="groove-form-actions">
                <button type="submit" class="groove-button groove-button-dark">
                    <i class="bi bi-send"></i> Публикувай
                </button>
                <a asp-action="Index" class="groove-button groove-button-paper">Отказ</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
