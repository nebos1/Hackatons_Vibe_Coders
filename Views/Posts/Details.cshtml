@model PostDetailsViewModel
@{
    ViewData["Title"] = "Post";
}

<div class="mb-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
    @if (Model.CanEdit)
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary ms-1"><i class="bi bi-pencil"></i> Edit</a>
    }
    @if (Model.CanDelete)
    {
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-danger ms-1"><i class="bi bi-trash"></i> Delete</a>
    }
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <div>
                <strong class="fs-5">@Model.OrganizerName</strong>
                <span class="text-muted ms-2 small">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</span>
                @if (Model.UpdatedAt.HasValue)
                {
                    <span class="text-muted small"> (edited @Model.UpdatedAt.Value.ToString("yyyy-MM-dd HH:mm"))</span>
                }
            </div>
        </div>

        @if (Model.EventId.HasValue)
        {
            <div class="mb-3">
                <a asp-controller="Events" asp-action="Details" asp-route-id="@Model.EventId" class="badge bg-secondary text-decoration-none">
                    <i class="bi bi-link-45deg"></i> @Model.EventTitle
                </a>
            </div>
        }

        <p class="lead" style="white-space:pre-wrap;">@Model.Content</p>

        @if (Model.ImageUrls.Count > 0)
        {
            <div class="d-flex flex-wrap gap-2 mb-3">
                @foreach (var url in Model.ImageUrls)
                {
                    <img src="@url" class="rounded img-thumbnail" style="max-height:250px;max-width:100%;object-fit:cover;" alt="post image" />
                }
            </div>
        }

        <div class="d-flex align-items-center gap-3 mb-3">
            <span class="text-muted"><i class="bi bi-heart-fill text-danger"></i> @Model.LikesCount likes</span>
            <span class="text-muted"><i class="bi bi-chat"></i> @Model.Comments.Count comments</span>
        </div>

        @if (User.Identity?.IsAuthenticated == true)
        {
            @if (Model.CurrentUserLiked)
            {
                <form asp-action="Unlike" asp-route-id="@Model.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-danger btn-sm"><i class="bi bi-heart-fill"></i> Unlike</button>
                </form>
            }
            else
            {
                <form asp-action="Like" asp-route-id="@Model.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-outline-danger btn-sm"><i class="bi bi-heart"></i> Like</button>
                </form>
            }
        }

        <hr class="my-4" />
        <h3 class="h5"><i class="bi bi-chat-square-text"></i> Comments (@Model.Comments.Count)</h3>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <form asp-action="AddComment" asp-route-id="@Model.Id" method="post" class="mb-4">
                @Html.AntiForgeryToken()
                <div class="input-group">
                    <input type="text" name="content" class="form-control" placeholder="Write a comment…" maxlength="1000" required />
                    <button class="btn btn-primary" type="submit"><i class="bi bi-send"></i> Post</button>
                </div>
            </form>
        }

        @if (Model.Comments.Count == 0)
        {
            <p class="text-muted">No comments yet.</p>
        }
        else
        {
            @foreach (var c in Model.Comments)
            {
                <div class="d-flex justify-content-between align-items-start mb-3 border-bottom pb-2">
                    <div>
                        <strong>@c.UserName</strong>
                        <span class="text-muted small ms-2">@c.CreatedAt.ToString("yyyy-MM-dd HH:mm")</span>
                        <p class="mb-0 mt-1">@c.Content</p>
                    </div>
                    @if (c.CanDelete)
                    {
                        <form asp-action="DeleteComment" method="post" class="ms-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="commentId" value="@c.Id" />
                            <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                        </form>
                    }
                </div>
            }
        }
    </div>
</div>
