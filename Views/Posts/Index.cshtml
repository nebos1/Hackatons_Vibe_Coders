@model FeedViewModel
@inject EventsApp.Services.IPlatformPermissionService Permissions
@{
    ViewData["Title"] = "Поток";
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var isSignedIn = User.Identity?.IsAuthenticated == true;
    var canCreatePublicContent = await Permissions.CanCreatePostAsync(User);
    var currentUserId = User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier);
    var activeFilter = Model.ActiveFilter ?? "all";
    var activeSort = Model.ActiveSort ?? "recent";
    var feedFilters = new[]
    {
        new { Key = "all", LabelKey = "feed.filter.all", Label = "Всички", Icon = "bi-grid-3x3-gap" },
        new { Key = "following", LabelKey = "feed.filter.following", Label = "Следвани", Icon = "bi-person-heart" },
        new { Key = "events", LabelKey = "feed.filter.events", Label = "За събития", Icon = "bi-calendar-event" },
        new { Key = "media", LabelKey = "feed.filter.media", Label = "С медия", Icon = "bi-image" },
        new { Key = "saved", LabelKey = "feed.filter.saved", Label = "Запазени", Icon = "bi-bookmark" },
        new { Key = "hot", LabelKey = "feed.filter.hot", Label = "Най-активни", Icon = "bi-fire" },
    };
    var mainTitleKey = activeFilter switch
    {
        "following" => "feed.main.following",
        "events" => "feed.main.events",
        "media" => "feed.main.media",
        "saved" => "feed.main.saved",
        "hot" => "feed.main.hot",
        _ => "feed.posts.title",
    };
    var mainTitle = activeFilter switch
    {
        "following" => "Постове от хората и страниците, които следиш.",
        "events" => "Публикации, вързани към събития.",
        "media" => "Постове със снимки и видео.",
        "saved" => "Твоите запазени публикации.",
        "hot" => "Постове с най-много реакции.",
        _ => "Новини от организатори и свежи постове.",
    };
    var emptyPostsKey = activeFilter == "all" ? "profile.no.posts" : "feed.filter.empty";
    var emptyPostsText = activeFilter == "all" ? "Все още няма публикации." : "Няма публикации за този филтър.";
    var showDiscoveryStrip = activeFilter == "all" && (Model.SuggestedProfiles.Any() || Model.RecommendedEvents.Any() || Model.TrendingEvents.Any());
    var discoveryStripRendered = false;
}

<section class="groove-feed-page social-feed-page social-feed-page--stream">
    <header class="social-feed-topbar">
        <div>
            <span class="groove-stamp groove-stamp-teal" data-i18n="feed.kicker">Discover</span>
            <h1 data-i18n="feed.title">Събития, организатори и новини от сцената.</h1>
        </div>
        @if (isSignedIn && canCreatePublicContent)
        {
            <a asp-controller="Account" asp-action="Index" class="groove-button groove-button-paper">
                <i class="bi bi-columns-gap"></i> <span data-i18n="account.overview">Преглед</span>
            </a>
        }
    </header>

    <section id="feed-filter-anchor" class="social-feed-search" data-filter-anchor data-filter-button-label="Филтри">
        <form asp-controller="Posts" asp-action="Index" method="get" class="social-feed-search__form">
            <i class="bi bi-search"></i>
            <input type="text"
                   inputmode="search"
                   name="q"
                   value="@Model.SearchQuery"
                   placeholder="Търси хора, @@username или публична страница..."
                   data-i18n-placeholder="feed.search.placeholder"
                   data-mobile-lazy-input
                   readonly
                   autocomplete="off" />
            <input type="hidden" name="filter" value="@(activeFilter == "all" ? "" : activeFilter)" />
            <input type="hidden" name="sort" value="@activeSort" />
            <button type="submit" class="groove-button groove-button-primary" data-i18n="feed.search.action">Търси</button>
            @if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
            {
                <a asp-controller="Posts" asp-action="Index" class="groove-button groove-button-paper" data-i18n="common.clear">Изчисти</a>
            }
        </form>

        <div class="social-feed-filter-panel">
            <div class="social-feed-filter-rail" aria-label="Feed filters">
                @foreach (var option in feedFilters)
                {
                    var isActive = activeFilter == option.Key;
                    <a asp-controller="Posts"
                       asp-action="Index"
                       asp-route-q="@Model.SearchQuery"
                       asp-route-filter="@(option.Key == "all" ? null : option.Key)"
                       asp-route-sort="@activeSort"
                       class="social-feed-filter-chip @(isActive ? "is-active" : "")">
                        <i class="bi @option.Icon"></i>
                        <span data-i18n="@option.LabelKey">@option.Label</span>
                    </a>
                }
            </div>
            <form asp-controller="Posts" asp-action="Index" method="get" class="social-feed-sort-form">
                <input type="hidden" name="q" value="@Model.SearchQuery" />
                <input type="hidden" name="filter" value="@(activeFilter == "all" ? "" : activeFilter)" />
                <label for="feed-sort" data-i18n="feed.sort.label">Подреди</label>
                <select id="feed-sort" name="sort" onchange="this.form.submit()">
                    <option value="recent" selected="@(activeSort == "recent")" data-i18n="feed.sort.recent">Най-нови</option>
                    <option value="popular" selected="@(activeSort == "popular")" data-i18n="feed.sort.popular">Популярни</option>
                    <option value="discussed" selected="@(activeSort == "discussed")" data-i18n="feed.sort.discussed">С разговор</option>
                </select>
            </form>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
        {
            <div class="social-search-results">
                <div class="social-search-results__head">
                    <span class="groove-kicker" data-i18n="feed.search.results">Резултати</span>
                    <strong>@Model.SearchQuery</strong>
                </div>
                @if (Model.SearchResults.Count == 0)
                {
                    <div class="social-empty-inline" data-i18n="feed.search.empty">Няма намерени профили или публични страници.</div>
                }
                else
                {
                    <div class="social-search-results__grid">
                        @foreach (var result in Model.SearchResults)
                        {
                            var resultInitial = string.IsNullOrWhiteSpace(result.DisplayName) ? "?" : result.DisplayName[..1].ToUpperInvariant();
                            <article class="social-search-card">
                                @if (result.OrganizerProfileId.HasValue)
                                {
                                    <a asp-controller="Profiles" asp-action="Page" asp-route-id="@result.OrganizerProfileId" class="social-search-card__main">
                                        <span class="social-profile-avatar">
                                            @if (!string.IsNullOrWhiteSpace(result.ProfileImageUrl))
                                            {
                                                <img src="@result.ProfileImageUrl" alt="@result.DisplayName" onerror="this.closest('.social-profile-avatar').classList.add('is-fallback');this.remove();" />
                                            }
                                            <span>@resultInitial</span>
                                        </span>
                                        <span class="social-search-card__body">
                                            <strong>@result.DisplayName</strong>
                                            <small>
                                                <span data-i18n="@result.TypeKey">@result.TypeText</span>
                                            </small>
                                            @if (!string.IsNullOrWhiteSpace(result.Bio))
                                            {
                                                <span class="social-search-card__bio">@result.Bio</span>
                                            }
                                            <span class="social-search-card__meta">
                                                @result.FollowersCount <span data-i18n="profile.followers">последователи</span>
                                                · @result.EventsCount <span data-i18n="profile.events">събития</span>
                                                · @result.PostsCount <span data-i18n="profile.posts">поста</span>
                                            </span>
                                        </span>
                                    </a>
                                }
                                else
                                {
                                    <a asp-controller="Profiles" asp-action="Details" asp-route-id="@result.UserId" class="social-search-card__main">
                                    <span class="social-profile-avatar">
                                        @if (!string.IsNullOrWhiteSpace(result.ProfileImageUrl))
                                        {
                                            <img src="@result.ProfileImageUrl" alt="@result.DisplayName" onerror="this.closest('.social-profile-avatar').classList.add('is-fallback');this.remove();" />
                                        }
                                        <span>@resultInitial</span>
                                    </span>
                                    <span class="social-search-card__body">
                                        <strong>@result.DisplayName</strong>
                                        <small>
                                            <span data-i18n="@result.TypeKey">@result.TypeText</span>
                                            @if (!string.IsNullOrWhiteSpace(result.UserName))
                                            {
                                                <span>@@@result.UserName</span>
                                            }
                                        </small>
                                        @if (!string.IsNullOrWhiteSpace(result.Bio))
                                        {
                                            <span class="social-search-card__bio">@result.Bio</span>
                                        }
                                        <span class="social-search-card__meta">
                                            @result.FollowersCount <span data-i18n="profile.followers">последователи</span>
                                            · @result.EventsCount <span data-i18n="profile.events">събития</span>
                                            · @result.PostsCount <span data-i18n="profile.posts">поста</span>
                                        </span>
                                    </span>
                                    </a>
                                }
                                @if (isSignedIn && !result.OrganizerProfileId.HasValue && result.UserId != currentUserId && !result.CurrentUserFollows)
                                {
                                    <form asp-controller="Profiles" asp-action="Follow" asp-route-id="@result.UserId" asp-route-returnUrl="@returnUrl" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-primary" data-i18n="profile.follow">Последвай</button>
                                    </form>
                                }
                            </article>
                        }
                    </div>
                }
            </div>
        }
    </section>

    <div class="social-feed-shell social-feed-shell--stream">
        <main class="social-feed-main">
            @if (activeFilter == "all" && Model.FriendsActivity.Any())
            {
                <section class="social-feed-section social-feed-section--stream">
                    <div class="social-section-heading social-section-heading--compact">
                        <div>
                            <span class="groove-kicker" data-i18n="feed.following.kicker">Следиш</span>
                            <h2 data-i18n="feed.following.title">Съдържание от следвани организатори.</h2>
                        </div>
                    </div>
                    <div class="social-post-list social-post-list--stream" data-progressive-list data-initial-count="4" data-step-count="4">
                        @for (var i = 0; i < Model.FriendsActivity.Count; i++)
                        {
                            var post = Model.FriendsActivity[i];
                            <div data-progressive-item>
                                <partial name="_PostCard" model="post" />
                            </div>
                            if (showDiscoveryStrip && !discoveryStripRendered && i == 1)
                            {
                                discoveryStripRendered = true;
                                <div data-progressive-item class="social-feed-discovery-item">
                                    <partial name="_FeedDiscoveryStrip" model="Model" />
                                </div>
                            }
                        }
                    </div>
                    @if (Model.FriendsActivity.Count > 4)
                    {
                        <div class="evt-load-more evt-load-more--compact">
                            <button type="button" class="evt-btn evt-btn-ghost" data-progressive-more>
                                <i class="bi bi-plus-circle"></i>
                                <span data-i18n="common.show.more">Покажи още</span>
                            </button>
                        </div>
                    }
                </section>
            }

            <section class="social-feed-section social-feed-section--stream">
                <div class="social-section-heading social-section-heading--compact">
                    <div>
                        <span class="groove-kicker" data-i18n="feed.posts.kicker">Публикации</span>
                        <h2 data-i18n="@mainTitleKey">@mainTitle</h2>
                    </div>
                    <span class="social-feed-count-pill" title="@mainTitle">
                        <i class="bi bi-layers"></i>
                        @Model.VisiblePostsCount
                    </span>
                </div>
                @if (Model.OrganizerPosts.Any())
                {
                    <div class="social-post-list social-post-list--stream" data-progressive-list data-initial-count="8" data-step-count="6">
                        @for (var i = 0; i < Model.OrganizerPosts.Count; i++)
                        {
                            var post = Model.OrganizerPosts[i];
                            <div data-progressive-item>
                                <partial name="_PostCard" model="post" />
                            </div>
                            if (showDiscoveryStrip && !discoveryStripRendered && i == 1)
                            {
                                discoveryStripRendered = true;
                                <div data-progressive-item class="social-feed-discovery-item">
                                    <partial name="_FeedDiscoveryStrip" model="Model" />
                                </div>
                            }
                        }
                    </div>
                    @if (Model.OrganizerPosts.Count > 8)
                    {
                        <div class="evt-load-more evt-load-more--compact">
                            <button type="button" class="evt-btn evt-btn-ghost" data-progressive-more>
                                <i class="bi bi-plus-circle"></i>
                                <span data-i18n="common.show.more">Покажи още</span>
                            </button>
                        </div>
                    }
                }
                else
                {
                    if (showDiscoveryStrip && !discoveryStripRendered)
                    {
                        discoveryStripRendered = true;
                        <partial name="_FeedDiscoveryStrip" model="Model" />
                    }
                    <div class="social-empty-panel">
                        <i class="bi bi-journal-text"></i>
                        <span data-i18n="@emptyPostsKey">@emptyPostsText</span>
                    </div>
                }
            </section>
        </main>

        <aside class="social-feed-aside social-feed-aside--overview">
            <section class="social-side-panel social-side-panel--quick">
                <div class="social-side-panel__head">
                    <span class="groove-kicker" data-i18n="profile.events">Събития</span>
                    <a asp-controller="Home" asp-action="Index" class="groove-link" data-i18n="feed.all">Всички</a>
                </div>
                @foreach (var ev in Model.RecommendedEvents.Take(3))
                {
                    <a asp-controller="Events" asp-action="Details" asp-route-id="@ev.Id" class="social-event-mini">
                        <span class="social-event-mini__thumb">
                            @if (!string.IsNullOrWhiteSpace(ev.ImageUrl))
                            {
                                <img src="@ev.ImageUrl" alt="@ev.Title" />
                            }
                            else
                            {
                                <i class="bi bi-calendar-event"></i>
                            }
                        </span>
                        <span>@ev.StartTime.ToString("dd MMM")</span>
                        <span class="social-event-mini__body">
                            <strong>@ev.Title</strong>
                            <small>@ev.City</small>
                        </span>
                    </a>
                }
            </section>

            <section class="social-side-panel social-side-panel--quick">
                <div class="social-side-panel__head">
                    <span class="groove-kicker" data-i18n="home.trending.tab.trend">Тренд</span>
                    <a asp-controller="Events" asp-action="Recommended" class="groove-link" data-i18n="feed.more">Още</a>
                </div>
                @foreach (var ev in Model.TrendingEvents.Take(3))
                {
                    <a asp-controller="Events" asp-action="Details" asp-route-id="@ev.Id" class="social-event-mini">
                        <span class="social-event-mini__thumb">
                            @if (!string.IsNullOrWhiteSpace(ev.ImageUrl))
                            {
                                <img src="@ev.ImageUrl" alt="@ev.Title" />
                            }
                            else
                            {
                                <i class="bi bi-fire"></i>
                            }
                        </span>
                        <span><i class="bi bi-fire"></i></span>
                        <span class="social-event-mini__body">
                            <strong>@ev.Title</strong>
                            <small>@ev.GoingCount <span data-i18n="event.action.going">Отивам</span> · @ev.InterestedCount <span data-i18n="event.action.interested">Интересува ме</span></small>
                        </span>
                    </a>
                }
            </section>

            <section class="social-side-panel">
                <span class="groove-kicker" data-i18n="feed.suggested">Предложени профили</span>
                @foreach (var profile in Model.SuggestedProfiles.Take(5))
                {
                    var profileInitial = string.IsNullOrWhiteSpace(profile.DisplayName) ? "?" : profile.DisplayName[..1].ToUpperInvariant();
                    <article class="social-profile-row">
                        <a asp-controller="Profiles" asp-action="Details" asp-route-id="@profile.Id" class="social-profile-row__main">
                            <span class="social-profile-avatar">
                                @if (!string.IsNullOrWhiteSpace(profile.ProfileImageUrl))
                                {
                                    <img src="@profile.ProfileImageUrl" alt="@profile.DisplayName" onerror="this.closest('.social-profile-avatar').classList.add('is-fallback');this.remove();" />
                                }
                                <span>@profileInitial</span>
                            </span>
                            <div class="social-profile-row__text">
                                <strong>@profile.DisplayName</strong>
                                <small>
                                    @if (profile.IsOrganizer)
                                    {
                                        <span data-i18n="profile.type.organizer">Организатор</span>
                                    }
                                    else
                                    {
                                        <span data-i18n="profile.type.profile">Профил</span>
                                    }
                                    · @profile.FollowersCount <span data-i18n="profile.followers">последователи</span>
                                </small>
                            </div>
                        </a>
                        @if (isSignedIn)
                        {
                            <form asp-controller="Profiles" asp-action="Follow" asp-route-id="@profile.Id" asp-route-returnUrl="@returnUrl" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-primary" data-i18n="profile.follow">Последвай</button>
                            </form>
                        }
                    </article>
                }
            </section>
        </aside>
    </div>
</section>

@section Scripts {
    <script src="~/js/feed-comments.js" asp-append-version="true"></script>
}
