@model PostCreateEditViewModel
@{
    ViewData["Title"] = "Редакция на публикация";
}

<section class="groove-app-page groove-form-shell">
    <div class="groove-page-hero">
        <div class="groove-page-hero__copy">
            <span class="groove-stamp groove-stamp-red">Поток</span>
            <h1>Редактирай <span>публикацията</span>.</h1>
            <p>Обнови текста, свързаното събитие и медията към публикацията.</p>
        </div>
        <div class="groove-page-actions">
            <a asp-action="Details" asp-route-id="@Model.Id" class="groove-button groove-button-paper">
                <i class="bi bi-arrow-left"></i> Към публикацията
            </a>
        </div>
    </div>

    <div class="groove-form-panel">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Content" class="form-label"></label>
                <textarea asp-for="Content" class="form-control" rows="6"></textarea>
                <span asp-validation-for="Content" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="EventId" class="form-label"></label>
                <select asp-for="EventId" asp-items="Model.Events" class="form-select">
                    <option value="">Без свързано събитие</option>
                </select>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.CurrentMediaUrl))
            {
                <div class="mb-3">
                    <label class="form-label">Текуща медия</label>
                    <div><a href="@Model.CurrentMediaUrl" target="_blank" rel="noopener">@Model.CurrentMediaUrl</a></div>
                </div>
            }

            <div class="mb-3">
                <label asp-for="MediaFile" class="form-label">Замени с нов файл</label>
                <input asp-for="MediaFile" class="form-control" type="file"
                       accept="image/jpeg,image/png,image/gif,image/webp,video/mp4,video/webm,video/quicktime" />
                <div class="form-text">Снимка до 5 MB · Видео до 100 MB.</div>
                <span asp-validation-for="MediaFile" class="text-danger small"></span>
            </div>

            <div class="groove-form-actions">
                <button type="submit" class="groove-button groove-button-dark">
                    <i class="bi bi-check-lg"></i> Запази
                </button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="groove-button groove-button-paper">Отказ</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
