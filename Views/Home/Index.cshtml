@model EventsIndexViewModel
@using System.Text.Json
@using System.Text.Json.Serialization
@{
    ViewData["Title"] = "Начало";
    var hasRealEvents = Model.TotalEventsCount > 0;
    var hasRealMapPins = Model.MapMarkers.Count > 0;
    var visibleEventCount = Math.Min(Model.TotalEventsCount, Model.Page * Model.PageSize);

    var mapJsonOptions = new JsonSerializerOptions(JsonSerializerDefaults.Web);
    mapJsonOptions.Converters.Add(new JsonStringEnumConverter());
    var dataPayload = new
    {
        markers = Model.MapMarkers.Select(m => new
        {
            eventId = m.EventId,
            title = m.Title,
            city = m.City,
            address = m.Address,
            startTime = m.StartTime,
            genre = m.Genre.ToString(),
            imageUrl = m.ImageUrl,
            organizerName = m.OrganizerName,
            lat = m.Lat,
            lng = m.Lng,
            isApproximate = m.IsApproximate
        })
    };
    var dataJson = JsonSerializer.Serialize(dataPayload, mapJsonOptions);
    var visibleCityCount = Model.MapMarkers.Select(p => p.City).Distinct().Count();
    var trendingEvents = Model.TrendingEvents.Count > 0
        ? Model.TrendingEvents.Take(4).ToList()
        : Model.Events
            .OrderByDescending(e => e.GoingCount * 2 + e.InterestedCount + e.LikesCount + e.CommentsCount + e.SavesCount)
            .ThenBy(e => e.StartTime)
            .Take(4)
            .ToList();
}

@section Scripts {
    <script id="home-events-data" type="application/json">@Html.Raw(dataJson)</script>
    <partial name="_GoogleMapsLoader" />
    <script src="~/js/home-map.js" asp-append-version="true"></script>
    <script>
        document.body.classList.add('evt-home-bg');
    </script>
}

<div class="evt-shell">

    <div class="evt-marquee" aria-hidden="true">
        <div class="evt-marquee__track">
            <span data-i18n="marquee.live">★ Живи нощи</span><span data-i18n="marquee.diary">★ Дневник на града</span><span data-i18n="marquee.map">★ Карта на България</span><span data-i18n="marquee.tickets">★ Свежи билети</span><span>★ Techno</span><span>★ House</span><span>★ Jazz</span><span data-i18n="marquee.nearme">★ Около мен</span>
            <span data-i18n="marquee.live">★ Живи нощи</span><span data-i18n="marquee.diary">★ Дневник на града</span><span data-i18n="marquee.map">★ Карта на България</span><span data-i18n="marquee.tickets">★ Свежи билети</span><span>★ Techno</span><span>★ House</span><span>★ Jazz</span><span data-i18n="marquee.nearme">★ Около мен</span>
        </div>
    </div>

    <section class="evt-hero">
        <div class="evt-hero__copy">
            <h1 class="evt-hero__title" data-i18n-html="home.hero.h1">
                Открий <span>събития</span> наблизо.
            </h1>

            <p class="evt-hero__lead" data-i18n="home.hero.p">
                Концерти, театър, клубни вечери и фестивали в една компактна карта.
            </p>

            <div class="evt-hero__cta">
                <a asp-controller="Events" asp-action="Recommended" class="evt-btn evt-btn-primary">
                    <i class="bi bi-compass"></i>
                    <span data-i18n="home.viewmap">Препоръчани</span>
                </a>
                <a asp-controller="Home" asp-action="Calendar" class="evt-btn evt-btn-ghost">
                    <i class="bi bi-calendar3"></i>
                    <span data-i18n="home.calendar">Календар</span>
                </a>
                <a asp-controller="Posts" asp-action="Index" class="evt-btn evt-btn-ghost">
                    <i class="bi bi-grid"></i>
                    <span data-i18n="home.openfeed">Поток</span>
                </a>
            </div>

            <div class="evt-hero__stats">
                <span><strong id="home-total-events-count">@Model.TotalEventsCount</strong> <span data-i18n="home.stats.nights">записани нощи</span></span>
                <span><strong id="home-city-count">@visibleCityCount</strong> <span data-i18n="home.stats.cities">града</span></span>
                <span><strong id="home-event-count">@Model.MapMarkers.Count</strong> <span data-i18n="home.stats.pins">карфици</span></span>
            </div>
        </div>

        <div class="evt-hero__map" id="event-map">
            <span class="evt-hero__map-badge">
                <i class="bi bi-broadcast"></i>
                <span data-i18n="@(hasRealMapPins ? "home.map.live" : "home.map.empty")">@(hasRealMapPins ? "жива карта" : "празна карта")</span>
            </span>
            <span class="evt-hero__map-badge evt-hero__map-badge--right notranslate" translate="no">google maps</span>

            <div id="events-map" class="notranslate" translate="no" data-no-i18n="true">
                <div class="map-loading-state">
                    <i class="bi bi-map" style="font-size:1.6rem;"></i>
                    <span data-i18n="home.map.loading">Картата се зарежда...</span>
                </div>
            </div>

            <div id="geo-status" class="evt-geo-status"></div>

            <button id="use-my-location" type="button" class="evt-hero__map-locate">
                <i class="bi bi-crosshair"></i>
                <span data-i18n="home.geo.btn">Около мен</span>
            </button>
        </div>
    </section>

    <!-- Event preview panel — shown when a map pin is clicked -->
    <div id="map-event-preview" class="evt-map-preview" aria-live="polite" style="display:none;">
        <div class="evt-map-preview__inner">
            <img id="map-preview-img" src="" alt="" class="evt-map-preview__img" style="display:none;" />
            <div class="evt-map-preview__body">
                <div class="evt-map-preview__meta">
                    <span id="map-preview-genre" class="evt-card__chip" style="position:static;display:inline-flex;"></span>
                </div>
                <h3 id="map-preview-title" class="evt-map-preview__title"></h3>
                <p id="map-preview-address" class="evt-map-preview__address"></p>
                <p id="map-preview-time" class="evt-map-preview__time"></p>
            </div>
            <a id="map-preview-link" href="#" class="evt-btn evt-btn-primary evt-map-preview__btn">
                <i class="bi bi-arrow-right-circle"></i>
                <span>Виж събитието</span>
            </a>
        </div>
        <button id="map-preview-close" class="evt-map-preview__close" type="button" aria-label="Затвори">
            <i class="bi bi-x-lg"></i>
        </button>
    </div>

    @{
        var today = DateTime.UtcNow.Date;
        var daysUntilSat = ((int)DayOfWeek.Saturday - (int)today.DayOfWeek + 7) % 7;
        if (daysUntilSat == 0) daysUntilSat = 7;
        var nextSat = today.AddDays(daysUntilSat);
        var nextSun = nextSat.AddDays(1);
        // Days until Sunday in current week (0 = today is Sunday → end is today)
        var daysUntilSun = (7 - (int)today.DayOfWeek) % 7;
        var endOfWeek = today.AddDays(daysUntilSun);

        var isTabAll = Model.DateFrom == null && Model.DateTo == null && string.IsNullOrEmpty(Model.Search) && Model.Genre == null;
        var isTabTonight = Model.DateFrom?.Date == today && Model.DateTo?.Date == today;
        var isTabWeekend = Model.DateFrom?.Date == nextSat && Model.DateTo?.Date == nextSun;
        var isTabWeek = Model.DateFrom?.Date == today && Model.DateTo?.Date == endOfWeek;
        var isTabFree = Model.Search == "free";
    }
    <div id="home-filter-anchor" class="evt-search-section" data-filter-anchor data-filter-button-label="Филтри">
        <div id="home-filter-tabs" class="evt-search-tabs-bar">
            <a class="evt-search-tab-link @(isTabAll ? "is-active" : "")" asp-action="Index">
                <i class="bi bi-grid-3x3-gap"></i> <span data-i18n="search.tab.all">Всички</span>
            </a>
            <a class="evt-search-tab-link @(isTabTonight ? "is-active" : "")"
               asp-action="Index"
               asp-route-dateFrom="@today.ToString("yyyy-MM-dd")"
               asp-route-dateTo="@today.ToString("yyyy-MM-dd")">
                <i class="bi bi-calendar-day"></i> <span data-i18n="search.tab.tonight">Днес</span>
            </a>
            <a class="evt-search-tab-link @(isTabWeekend ? "is-active" : "")"
               asp-action="Index"
               asp-route-dateFrom="@nextSat.ToString("yyyy-MM-dd")"
               asp-route-dateTo="@nextSun.ToString("yyyy-MM-dd")">
                <i class="bi bi-stars"></i> <span data-i18n="search.tab.weekend">Уикенд</span>
            </a>
            <a class="evt-search-tab-link @(isTabWeek ? "is-active" : "")"
               asp-action="Index"
               asp-route-dateFrom="@today.ToString("yyyy-MM-dd")"
               asp-route-dateTo="@endOfWeek.ToString("yyyy-MM-dd")">
                <i class="bi bi-calendar-week"></i> <span data-i18n="search.tab.week">Тази седмица</span>
            </a>
            <a class="evt-search-tab-link @(isTabFree ? "is-active" : "")"
               asp-action="Index" asp-route-search="free">
                <i class="bi bi-ticket-perforated"></i> <span data-i18n="chip.free">Безплатни</span>
            </a>
        </div>

        <div class="evt-ai-search-wrap">
            <div class="evt-ai-search__label">
                <i class="bi bi-stars"></i>
                <span data-i18n="home.ai.label">AI Търсене</span>
            </div>
            <form id="home-smart-search-form" class="evt-ai-search-form" autocomplete="off">
                @Html.AntiForgeryToken()
                <div class="evt-ai-search-row">
                    <input id="home-smart-search-input" type="text" name="q"
                           class="evt-ai-search-input"
                           data-i18n-placeholder="home.search.placeholder"
                           placeholder="техно тази вечер в София · джаз през уикенда · безплатен концерт" />
                    <button class="evt-ai-search-btn" type="submit">
                        <i class="bi bi-stars"></i>
                        <span data-i18n="home.search.btn">Търси с AI</span>
                    </button>
                </div>
                <div class="evt-search-status evt-ai-search-status">
                    <span id="home-search-status"></span>
                    <button id="home-smart-clear" class="evt-chip evt-chip--light" type="button" data-i18n="home.clear" style="display:none;">Изчисти</button>
                </div>
            </form>
        </div>
    </div>

    <section id="home-events-surface" class="evt-section" aria-live="polite">
        <div class="evt-section__head">
            <div>
                <h2 class="evt-section__title" data-i18n="home.events.discover">Открий своята вечер</h2>
                <p class="evt-section__sub" data-i18n="home.events.discover.sub">Подбрани събития, фестивали и партита около теб.</p>
            </div>

            <form id="home-events-filter" method="get" class="evt-toolbar" style="gap:8px;">
                <input type="hidden" name="search" value="@Model.Search" />
                <input type="hidden" name="city" value="@Model.City" />
                <input type="hidden" name="genre" value="@Model.Genre" />
                <input type="hidden" name="dateFrom" value="@Model.DateFrom?.ToString("yyyy-MM-dd")" />
                <input type="hidden" name="dateTo" value="@Model.DateTo?.ToString("yyyy-MM-dd")" />
                <div class="evt-sort">
                    <i class="bi bi-arrow-down-up"></i>
                    <select name="sort">
                        <option value="recent" selected="@(Model.Sort == "recent")" data-i18n="sort.recent">Recently added</option>
                        <option value="soon" selected="@(Model.Sort == "soon")" data-i18n="sort.soon">Starting soon</option>
                        <option value="popular" selected="@(Model.Sort == "popular")" data-i18n="sort.popular">Most popular</option>
                    </select>
                </div>
                <button type="submit" class="evt-btn evt-btn-ghost" style="padding:8px 16px;">
                    <i class="bi bi-funnel"></i> <span data-i18n="home.filter.btn">Филтрирай</span>
                </button>
            </form>
        </div>

        <div class="evt-toolbar">
            <div class="evt-chips">
                <a class="evt-chip @(string.IsNullOrEmpty(Model.Search) && Model.DateFrom == null && Model.Genre == null ? "is-active" : "")"
                   asp-action="Index" data-i18n="search.tab.all">Всички</a>
                <a class="evt-chip @(Model.Genre == EventGenre.LiveMusic ? "is-active" : "")"
                   asp-action="Index" asp-route-genre="@EventGenre.LiveMusic" data-i18n="genre.LiveMusic">Live музика</a>
                <a class="evt-chip @(Model.Genre == EventGenre.Festival ? "is-active" : "")"
                   asp-action="Index" asp-route-genre="@EventGenre.Festival" data-i18n="genre.Festival">Фестивал</a>
                <a class="evt-chip @(Model.Genre == EventGenre.Theater ? "is-active" : "")"
                   asp-action="Index" asp-route-genre="@EventGenre.Theater" data-i18n="genre.Theater">Театър</a>
                <a class="evt-chip @(Model.Search == "free" ? "is-active" : "")"
                   asp-action="Index" asp-route-search="free" data-i18n="chip.free">Безплатни</a>
                <a class="evt-chip @(Model.Genre == EventGenre.Kids ? "is-active" : "")"
                   asp-action="Index" asp-route-genre="@EventGenre.Kids" data-i18n="genre.Kids">За деца</a>
                <a class="evt-chip @(Model.Genre == EventGenre.Techno ? "is-active" : "")"
                   asp-action="Index" asp-route-genre="@EventGenre.Techno" data-i18n="genre.Techno">Techno</a>
                <a class="evt-chip @(Model.Genre == EventGenre.House ? "is-active" : "")"
                   asp-action="Index" asp-route-genre="@EventGenre.House" data-i18n="genre.House">House</a>
                <a class="evt-chip @(Model.Genre == EventGenre.Jazz ? "is-active" : "")"
                   asp-action="Index" asp-route-genre="@EventGenre.Jazz" data-i18n="genre.Jazz">Jazz</a>
            </div>
            @if (User.IsInRole(GlobalConstants.Roles.Organizer) || User.IsInRole(GlobalConstants.Roles.Admin))
            {
                <a asp-controller="Events" asp-action="Create" class="evt-btn evt-btn-primary" style="padding:8px 16px;">
                    <i class="bi bi-plus-lg"></i> <span data-i18n="home.events.create">Създай събитие</span>
                </a>
            }
        </div>

        <div class="evt-discover">
            @if (hasRealEvents)
            {
                <div id="event-cards-grid" class="evt-grid">
                    <partial name="_EventGridItems" model="Model.Events" />
                </div>
                @if (Model.HasMoreEvents)
                {
                    var nextEventsUrl = Url.Action("Index", new
                    {
                        search = Model.Search,
                        city = Model.City,
                        genre = Model.Genre,
                        dateFrom = Model.DateFrom?.ToString("yyyy-MM-dd"),
                        dateTo = Model.DateTo?.ToString("yyyy-MM-dd"),
                        sort = Model.Sort,
                        page = Model.Page + 1,
                        partial = true
                    });
                    <div class="evt-load-more" data-home-event-load-more data-page="@Model.Page" data-page-size="@Model.PageSize" data-total="@Model.TotalEventsCount">
                        <span class="evt-load-more__meta">
                            <span data-i18n="common.showing">Показани</span> <strong data-loaded-count>@visibleEventCount</strong> / <strong>@Model.TotalEventsCount</strong>
                        </span>
                        <button type="button" class="evt-btn evt-btn-ghost" data-load-more-url="@nextEventsUrl">
                            <i class="bi bi-plus-circle"></i>
                            <span data-i18n="common.show.more">Покажи още</span>
                        </button>
                    </div>
                }
            }
            else
            {
                <div class="evt-empty">
                    <p data-i18n="home.events.emptytext">Все още няма публикувани събития. Когато организаторите добавят такива, те ще се появят тук.</p>
                    @if (User.Identity?.IsAuthenticated == true && !User.IsInRole(GlobalConstants.Roles.Organizer) && !User.IsInRole(GlobalConstants.Roles.Admin))
                    {
                        <a asp-controller="Account" asp-action="Apply" class="evt-btn evt-btn-primary mt-3" data-i18n="home.events.apply">Кандидатствай за организатор</a>
                    }
                </div>
            }

            <aside class="evt-trending">
                <div class="evt-trending__head">
                    <span class="evt-card__chip evt-card__chip--hot" style="position:static;display:inline-block;">
                        <i class="bi bi-graph-up-arrow"></i> <span data-i18n="home.trending.stamp">Тренд</span>
                    </span>
                    <h3 data-i18n="home.trending.title">Хора следят сега</h3>
                    <p data-i18n="home.trending.sub">Най-нашумелите събития според реакциите.</p>
                </div>
                <div class="evt-trending__list">
                    @foreach (var ev in trendingEvents)
                    {
                        var rank = trendingEvents.IndexOf(ev) + 1;
                        <a asp-controller="Events" asp-action="Details" asp-route-id="@ev.Id" class="evt-trending__row">
                            @if (!string.IsNullOrWhiteSpace(ev.ImageUrl))
                            {
                                <img src="@ev.ImageUrl" alt="@ev.Title" />
                            }
                            else
                            {
                                <span class="evt-trending__placeholder"><i class="bi bi-calendar-event"></i></span>
                            }
                            <div class="evt-trending__body">
                                <strong>@ev.Title</strong>
                                <small>@ev.City · @ev.StartTime.ToString("dd.MM HH:mm")</small>
                            </div>
                            <span class="evt-trending__rank">#@rank</span>
                        </a>
                    }
                    @if (trendingEvents.Count == 0)
                    {
                        <p class="text-muted small mb-0" data-i18n="home.trending.empty">Все още няма достатъчно реакции.</p>
                    }
                </div>
            </aside>
        </div>
    </section>
</div>
