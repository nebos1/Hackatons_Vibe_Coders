@model HomeIndexViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Home";
    var isAuthed = User.Identity?.IsAuthenticated == true;
    var isStaff = User.IsInRole(GlobalConstants.Roles.Organizer) || User.IsInRole(GlobalConstants.Roles.Admin);
    var genres = Enum.GetValues<EventGenre>()
        .Select(g => new { Value = g, Text = g.ToString() })
        .ToList();
    var markersJson = JsonSerializer.Serialize(Model.MapMarkers);
}

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
          integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
            integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script>
        (function () {
            var markers = @Html.Raw(markersJson);
            var mapEl = document.getElementById('events-map');
            if (!mapEl || typeof L === 'undefined') return;

            var defaultCenter = [42.7339, 25.4858]; // Bulgaria
            var map = L.map('events-map').setView(defaultCenter, 7);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 18,
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
            }).addTo(map);

            if (markers && markers.length) {
                var bounds = [];
                markers.forEach(function (m) {
                    var latlng = [m.Lat, m.Lng];
                    bounds.push(latlng);
                    var thumb = m.ImageUrl ? '<img src="' + m.ImageUrl + '" style="width:100%;height:80px;object-fit:cover;border-radius:6px;margin-bottom:6px;" />' : '';
                    var popup = thumb +
                        '<strong>' + m.Title + '</strong><br>' +
                        '<small>' + m.VenueName + ', ' + m.City + '</small><br>' +
                        '<small>' + new Date(m.StartTime).toLocaleString() + '</small><br>' +
                        '<a href="/Events/Details/' + m.EventId + '" class="btn btn-sm btn-primary mt-2">Details</a>';
                    L.marker(latlng).addTo(map).bindPopup(popup);
                });
                if (bounds.length > 1) {
                    map.fitBounds(bounds, { padding: [40, 40] });
                } else {
                    map.setView(bounds[0], 11);
                }
            }
        })();
    </script>
}

<section class="hero text-center mb-4 py-4 rounded bg-dark text-white shadow-sm">
    <h1 class="display-5 fw-bold"><i class="bi bi-music-note-beamed"></i> Открий събития около теб</h1>
    <p class="lead mb-4">
        GrooveOn ти показва концерти, парти-та и фестивали в твоя град. Филтрирай по жанр, град или дата.
    </p>

    <div class="d-flex justify-content-center gap-2 flex-wrap">
        @if (!isAuthed)
        {
            <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-light btn-lg">
                <i class="bi bi-box-arrow-in-right"></i> Login
            </a>
            <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-outline-light btn-lg">
                <i class="bi bi-person-plus"></i> Register
            </a>
        }
        else if (!isStaff)
        {
            <a asp-controller="Events" asp-action="Recommended" class="btn btn-light btn-lg">
                <i class="bi bi-stars"></i> Recommended for you
            </a>
            <a asp-controller="Tickets" asp-action="MyTickets" class="btn btn-outline-light btn-lg">
                <i class="bi bi-ticket-perforated"></i> My Tickets
            </a>
        }
    </div>
</section>

<section class="mb-4">
    <form asp-action="Index" method="get" class="card shadow-sm">
        <div class="card-body">
            <h2 class="h6 mb-3"><i class="bi bi-funnel"></i> Filters</h2>
            <div class="row g-2">
                <div class="col-md-4">
                    <label class="form-label small mb-1">Search</label>
                    <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Event title…" />
                </div>
                <div class="col-md-3">
                    <label class="form-label small mb-1">City</label>
                    <select name="city" class="form-select">
                        <option value="">All cities</option>
                        @foreach (var c in Model.Cities)
                        {
                            if (c.Value == Model.City)
                            {
                                <option value="@c.Value" selected>@c.Text</option>
                            }
                            else
                            {
                                <option value="@c.Value">@c.Text</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Genre</label>
                    <select name="genre" class="form-select">
                        <option value="">All</option>
                        @foreach (var g in genres)
                        {
                            if (Model.Genre.HasValue && Model.Genre.Value == g.Value)
                            {
                                <option value="@g.Value" selected>@g.Text</option>
                            }
                            else
                            {
                                <option value="@g.Value">@g.Text</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small mb-1">From date</label>
                    <input type="date" name="dateFrom" value="@(Model.DateFrom?.ToString("yyyy-MM-dd"))" class="form-control" />
                </div>
            </div>
            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i> Apply filters</button>
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-x-circle"></i> Clear</a>
            </div>
        </div>
    </form>
</section>

<section class="mb-5">
    <div class="d-flex justify-content-between align-items-end mb-3">
        <h2 class="h4 mb-0"><i class="bi bi-geo-alt"></i> Events Map</h2>
        <span class="small text-muted">@Model.MapMarkers.Count on map &middot; OpenStreetMap</span>
    </div>
    <div id="events-map" style="height: 420px; border-radius: 0.5rem; box-shadow: 0 1px 6px rgba(0,0,0,.08);"></div>
    @if (Model.MapMarkers.Count == 0)
    {
        <div class="small text-muted mt-2">
            No mapped events yet. Add events in cities like Sofia, Plovdiv, Varna, Burgas, Ruse to see them here.
        </div>
    }
</section>

<section class="mb-5">
    <div class="d-flex justify-content-between align-items-end mb-3">
        <h2 class="h4 mb-0"><i class="bi bi-calendar2-event"></i> Upcoming events</h2>
        <span class="small text-muted">@Model.LatestEvents.Count results</span>
    </div>
    @if (Model.LatestEvents.Count == 0)
    {
        <div class="alert alert-light border text-center">
            <i class="bi bi-calendar-x"></i> No events match your filters. Try clearing them.
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-3">
            @foreach (var ev in Model.LatestEvents)
            {
                <div class="col"><partial name="_EventCard" model="ev" /></div>
            }
        </div>
    }
</section>
