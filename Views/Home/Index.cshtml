@model HomeIndexViewModel
@{
    ViewData["Title"] = "Home";
}

<section class="hero text-center">
    <h1 class="display-5"><i class="bi bi-music-note-beamed"></i> GrooveOn</h1>
    <p class="lead mb-4">Discover events, venues and organizers — follow the scene in your city.</p>
    <div class="d-flex justify-content-center gap-2 flex-wrap">
        <a asp-controller="Events" asp-action="Index" class="btn btn-primary btn-lg">Browse events</a>
        <a asp-controller="Posts" asp-action="Index" class="btn btn-outline-light btn-lg">Open feed</a>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-controller="Preferences" asp-action="Index" class="btn btn-outline-light btn-lg">My preferences</a>
        }
        @if (User.IsInRole(GlobalConstants.Roles.Organizer) || User.IsInRole(GlobalConstants.Roles.Admin))
        {
            <a asp-controller="Organizer" asp-action="Dashboard" class="btn btn-warning btn-lg">Organizer dashboard</a>
        }
    </div>
</section>

<section class="mb-5">
    <div class="d-flex justify-content-between align-items-end mb-3">
        <h2 class="h4 mb-0"><i class="bi bi-calendar2-event"></i> Upcoming events</h2>
        <a asp-controller="Events" asp-action="Index" class="small">All events →</a>
    </div>
    @if (Model.LatestEvents.Count == 0)
    {
        <div class="empty-state">No upcoming events yet.</div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-3">
            @foreach (var ev in Model.LatestEvents)
            {
                <div class="col"><partial name="_EventCard" model="ev" /></div>
            }
        </div>
    }
</section>

<section class="mb-5">
    <div class="d-flex justify-content-between align-items-end mb-3">
        <h2 class="h4 mb-0"><i class="bi bi-chat-square-text"></i> Latest from organizers</h2>
        <a asp-controller="Posts" asp-action="Index" class="small">All posts →</a>
    </div>
    @if (Model.LatestPosts.Count == 0)
    {
        <div class="empty-state">No posts yet.</div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-3">
            @foreach (var post in Model.LatestPosts)
            {
                <div class="col"><partial name="_PostCard" model="post" /></div>
            }
        </div>
    }
</section>
