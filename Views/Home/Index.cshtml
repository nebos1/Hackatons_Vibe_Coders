@model EventsIndexViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Home";
    var markersJson = JsonSerializer.Serialize(Model.MapMarkers);
    var mappedEventCount = Model.MapMarkers.Sum(m => m.EventCount);
}

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
          integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
            integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script>
        (function () {
            var markers = @Html.Raw(markersJson);
            var mapEl = document.getElementById('events-map');
            if (!mapEl || typeof L === 'undefined') return;

            function escapeHtml(value) {
                return String(value ?? '')
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#39;');
            }

            var bulgariaBounds = L.latLngBounds(
                [41.2354, 22.3571],
                [44.2156, 28.6122]);

            var map = L.map('events-map', {
                maxBoundsViscosity: 0.75
            });

            map.fitBounds(bulgariaBounds, { padding: [12, 12], animate: false });
            map.setMaxBounds(bulgariaBounds.pad(0.2));

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                minZoom: 6,
                maxZoom: 12,
                bounds: bulgariaBounds.pad(0.2),
                noWrap: true,
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
            }).addTo(map);

            if (!markers || !markers.length) return;

            markers.forEach(function (m) {
                var latlng = [m.Lat, m.Lng];
                var eventLabel = m.EventCount === 1 ? 'event' : 'events';
                var icon = L.divIcon({
                    className: 'event-count-marker',
                    html: '<span class="event-count-marker__city">' + escapeHtml(m.City) + '</span>' +
                        '<span class="event-count-marker__number">' + m.EventCount + '</span>' +
                        '<span class="event-count-marker__label">' + eventLabel + '</span>',
                    iconSize: [128, 42],
                    iconAnchor: [64, 21]
                });

                L.marker(latlng, {
                    icon: icon
                })
                    .addTo(map)
                    .bindPopup(
                        '<strong>' + escapeHtml(m.City) + '</strong><br>' +
                        '<small>' + m.EventCount + ' ' + eventLabel + '</small><br>' +
                        '<a href="/?city=' + encodeURIComponent(m.City) + '" class="btn btn-sm btn-primary mt-2">Show events</a>');
            });
        })();
    </script>
}

<section class="hero text-center mb-4">
    <h1 class="display-5"><i class="bi bi-music-note-beamed"></i> GrooveOn</h1>
    <p class="lead mb-4">Discover events and organizers - follow the scene in your city.</p>

    <form asp-controller="Search" asp-action="Index" method="get" class="row g-2 justify-content-center mb-3">
        <div class="col-md-7">
            <div class="input-group input-group-lg">
                <span class="input-group-text bg-white"><i class="bi bi-stars text-primary"></i></span>
                <input type="text" name="q" class="form-control" placeholder="Search events, locations, posts..." />
                <button class="btn btn-primary" type="submit">Search</button>
            </div>
        </div>
    </form>

    <div class="d-flex justify-content-center gap-2 flex-wrap">
        <a asp-controller="Home" asp-action="Index" class="btn btn-light btn-lg">Browse events</a>
        <a asp-controller="Posts" asp-action="Index" class="btn btn-outline-light btn-lg">Open feed</a>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-controller="Events" asp-action="Recommended" class="btn btn-light btn-lg">
                <i class="bi bi-stars"></i> Recommended for you
            </a>
            <a asp-controller="Tickets" asp-action="MyTickets" class="btn btn-outline-light btn-lg">
                <i class="bi bi-ticket-perforated"></i> My Tickets
            </a>
        }
        @if (User.IsInRole(GlobalConstants.Roles.Organizer) || User.IsInRole(GlobalConstants.Roles.Admin))
        {
            <a asp-controller="Organizer" asp-action="Dashboard" class="btn btn-warning btn-lg">Organizer dashboard</a>
        }
    </div>
</section>

<section class="mb-5">
    <div class="d-flex justify-content-between align-items-end mb-3">
        <h2 class="h4 mb-0"><i class="bi bi-map"></i> Events around Bulgaria</h2>
        <span class="small text-muted">@mappedEventCount events in @Model.MapMarkers.Count cities &middot; OpenStreetMap</span>
    </div>
    <div id="events-map"></div>
    @if (Model.MapMarkers.Count == 0)
    {
        <div class="small text-muted mt-2">
            No mapped events yet. Add events in cities like Sofia, Plovdiv, Varna, Burgas, Ruse to see them here.
        </div>
    }
</section>

@if (Model.Events.Count == 0)
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-calendar-x" style="font-size:2rem;"></i>
        <p class="mt-2">No events found.</p>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h4 mb-0"><i class="bi bi-calendar2-event"></i> Events</h2>
        @if (User.IsInRole(GlobalConstants.Roles.Organizer) || User.IsInRole(GlobalConstants.Roles.Admin))
        {
            <a asp-controller="Events" asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> New event</a>
        }
    </div>

    <form method="get" class="card card-body mb-4">
        <div class="row g-2">
            <div class="col-md-4">
                <input type="text" name="search" value="@Model.Search" placeholder="Search by title..." class="form-control" />
            </div>
            <div class="col-md-3">
                <select name="city" class="form-select">
                    <option value="">All cities</option>
                    @foreach (var c in Model.Cities)
                    {
                        <option value="@c" selected="@(Model.City == c)">@c</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <select name="genre" class="form-select">
                    <option value="">All genres</option>
                    @foreach (var g in Enum.GetValues<EventGenre>())
                    {
                        <option value="@((int)g)" selected="@(Model.Genre == g)">@g</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <input type="date" name="dateFrom" value="@Model.DateFrom?.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
        </div>
        <div class="d-flex gap-2 mt-2">
            <button type="submit" class="btn btn-outline-primary"><i class="bi bi-search"></i> Filter</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
        </div>
    </form>

    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-3">
        @foreach (var ev in Model.Events)
        {
            <div class="col"><partial name="_EventCard" model="ev" /></div>
        }
    </div>
}
