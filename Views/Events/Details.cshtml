@model EventDetailsViewModel
@using System.Globalization
@{
    ViewData["Title"] = Model.Title;
    var shareUrl = Url.Action("Details", "Events", new { id = Model.Id }, Context.Request.Scheme) ?? string.Empty;
    var ogDescription = !string.IsNullOrWhiteSpace(Model.Description)
        ? (Model.Description.Length > 200 ? Model.Description[..200] + "…" : Model.Description)
        : $"{Model.City} · {Model.StartTime:dd.MM.yyyy HH:mm}";
    var ogImage = !string.IsNullOrWhiteSpace(Model.ImageUrl)
        ? (Model.ImageUrl.StartsWith("http") ? Model.ImageUrl : $"{Context.Request.Scheme}://{Context.Request.Host}{Model.ImageUrl}")
        : null;
    var chatShareAction = Model.IsApproved ? "ShareEvent" : null;
    int? chatShareId = Model.IsApproved ? Model.Id : null;
}

@section Head {
    <meta property="og:type" content="event" />
    <meta property="og:title" content="@Model.Title" />
    <meta property="og:description" content="@ogDescription" />
    <meta property="og:url" content="@shareUrl" />
    <meta property="og:site_name" content="Evento" />
    @if (!string.IsNullOrWhiteSpace(ogImage))
    {
        <meta property="og:image" content="@ogImage" />
    }
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@Model.Title" />
    <meta name="twitter:description" content="@ogDescription" />
    @if (!string.IsNullOrWhiteSpace(ogImage))
    {
        <meta name="twitter:image" content="@ogImage" />
    }
}

<section class="groove-app-page">
    <div class="groove-page-actions mb-4">
        <a asp-controller="Home" asp-action="Index" class="groove-button groove-button-paper">
            <i class="bi bi-arrow-left"></i> <span data-i18n="common.back">Назад</span>
        </a>
        @if (Model.IsApproved)
        {
            <partial name="_ShareDropdown" model="@(new EventsApp.ViewModels.Shared.ShareModel { Url = shareUrl, Title = Model.Title, ChatShareAction = chatShareAction, ChatShareId = chatShareId })" />
        }
        else
        {
            <button class="groove-button groove-button-paper" type="button" disabled title="Събитието може да се споделя след одобрение.">
                <i class="bi bi-share"></i> Споделяне след одобрение
            </button>
        }
        @if (Model.CanEdit)
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="groove-button groove-button-paper">
                <i class="bi bi-pencil"></i> <span data-i18n="org.btn.edit">Редакция</span>
            </a>
        }
        @if (Model.CanDelete)
        {
            <a asp-action="Delete" asp-route-id="@Model.Id" class="groove-button groove-button-paper">
                <i class="bi bi-trash"></i> <span data-i18n="organizer.pages.delete">Изтрий</span>
            </a>
        }
        @if (Model.CanManageTickets)
        {
            <a asp-controller="Tickets" asp-action="Manage" asp-route-id="@Model.Id" class="groove-button groove-button-dark">
                <i class="bi bi-ticket-perforated"></i> <span data-i18n="org.btn.tickets">Билети</span>
            </a>
        }
    </div>

    @if (!Model.IsApproved)
    {
        <div class="groove-alert groove-alert-warning mb-4">
            <strong data-i18n="event.status.waiting.approval">Това събитие чака одобрение.</strong>
        </div>
    }
    else if (Model.HasPendingChanges && Model.CanEdit)
    {
        <div class="groove-alert groove-alert-warning mb-4">
            <strong>Има изпратени промени за одобрение.</strong>
            <span>Публичната версия остава активна, докато админ ги прегледа.</span>
        </div>
    }

    <div class="groove-split">
        <article class="groove-paper-card">
            @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" class="img-fluid rounded mb-3" alt="@Model.Title" style="max-height:420px;width:100%;object-fit:cover;" />
            }
            @if (Model.ImageUrls.Count > 0)
            {
                <div class="d-flex gap-2 flex-wrap mb-3">
                    @foreach (var url in Model.ImageUrls)
                    {
                        <img src="@url" class="rounded" style="height:80px;width:80px;object-fit:cover;" alt="Event image" />
                    }
                </div>
            }
            <span class="groove-kicker">@Model.Genre.GetDisplayName()</span>
            <h1 class="groove-panel-title">@Model.Title</h1>
            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <p class="groove-panel-intro mt-3">@Model.Description</p>
            }
        </article>

        <aside class="groove-info-card">
            <dl class="groove-data-list">
                <dt data-i18n="event.location">Локация</dt>
                <dd>@Model.Address, @Model.City</dd>
                <dt data-i18n="org.th.start">Начало</dt>
                <dd>@Model.StartTime.ToString("dd.MM.yyyy HH:mm")</dd>
                <dt data-i18n="ticket.end">Край</dt>
                <dd>@Model.EndTime.ToString("dd.MM.yyyy HH:mm")</dd>
                <dt data-i18n="profile.public.page">Публична страница</dt>
                <dd>
                    @if (Model.OrganizerProfileId.HasValue)
                    {
                        <a asp-controller="Profiles" asp-action="Page" asp-route-id="@Model.OrganizerProfileId" class="groove-link">
                            <i class="bi bi-person-badge"></i> @Model.OrganizerName
                        </a>
                    }
                    else
                    {
                        <span class="text-muted">Публична страница</span>
                    }
                </dd>
                <dt data-i18n="event.social">Социално</dt>
                <dd>@Model.LikesCount <span data-i18n="social.likes">харесвания</span> · @Model.SavesCount <span data-i18n="social.saves">запазвания</span></dd>
                <dt data-i18n="event.attendance">Посещения</dt>
                <dd>@Model.GoingCount <span data-i18n="event.action.going">Отивам</span> · @Model.InterestedCount <span data-i18n="event.action.interested">Интересува ме</span></dd>
            </dl>

            <div class="groove-form-actions">
                @if (Model.IsApproved)
                {
                    <button class="groove-button groove-button-paper social-share-button" type="button" data-share-url="@shareUrl" data-share-title="@Model.Title">
                        <i class="bi bi-share"></i> <span data-i18n="social.share">Сподели</span>
                    </button>
                }
                else
                {
                    <button class="groove-button groove-button-paper" type="button" disabled>
                        <i class="bi bi-share"></i> Споделяне след одобрение
                    </button>
                }
                @if (User.Identity?.IsAuthenticated == true && Model.OrganizerProfileId.HasValue && User.FindFirstValue(ClaimTypes.NameIdentifier) != Model.OrganizerId)
                {
                    <form asp-controller="Messages" asp-action="StartPage" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="organizerProfileId" value="@Model.OrganizerProfileId" />
                        <button class="groove-button groove-button-paper" type="submit">
                            <i class="bi bi-chat-dots"></i> <span data-i18n="messages.message.page">Пиши на страницата</span>
                        </button>
                    </form>
                }
            </div>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <hr />
                <div class="groove-form-actions">
                    <form asp-action="@(Model.CurrentUserLiked ? "Unlike" : "Like")" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button class="groove-button @(Model.CurrentUserLiked ? "groove-button-dark" : "groove-button-paper")" type="submit">
                            <i class="bi @(Model.CurrentUserLiked ? "bi-heart-fill" : "bi-heart")"></i>
                            @if (Model.CurrentUserLiked)
                            {
                                <span data-i18n="post.unlike">Премахни харесване</span>
                            }
                            else
                            {
                                <span data-i18n="post.like">Харесай</span>
                            }
                        </button>
                    </form>
                    <form asp-action="@(Model.CurrentUserSaved ? "Unsave" : "Save")" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button class="groove-button groove-button-paper" type="submit">
                            <i class="bi @(Model.CurrentUserSaved ? "bi-bookmark-fill" : "bi-bookmark")"></i>
                            @if (Model.CurrentUserSaved)
                            {
                                <span data-i18n="post.unsave">Премахни запазване</span>
                            }
                            else
                            {
                                <span data-i18n="post.save">Запази</span>
                            }
                        </button>
                    </form>
                    <form asp-action="Attendance" asp-route-id="@Model.Id" asp-route-status="@EventAttendanceStatus.Going" method="post">
                        @Html.AntiForgeryToken()
                        <button class="groove-button @(Model.CurrentUserAttendanceStatus == EventAttendanceStatus.Going ? "groove-button-dark" : "groove-button-paper")" type="submit">
                            <i class="bi bi-check2-circle"></i> <span data-i18n="event.action.going">Отивам</span>
                        </button>
                    </form>
                    <form asp-action="Attendance" asp-route-id="@Model.Id" asp-route-status="@EventAttendanceStatus.Interested" method="post">
                        @Html.AntiForgeryToken()
                        <button class="groove-button @(Model.CurrentUserAttendanceStatus == EventAttendanceStatus.Interested ? "groove-button-dark" : "groove-button-paper")" type="submit">
                            <i class="bi bi-star"></i> <span data-i18n="event.action.interested">Интересува ме</span>
                        </button>
                    </form>
                    <form asp-controller="Profiles" asp-action="@(Model.CurrentUserPinned ? "UnpinEvent" : "PinEvent")" asp-route-eventId="@Model.Id" asp-route-returnUrl="@($"{Context.Request.Path}{Context.Request.QueryString}")" method="post">
                        @Html.AntiForgeryToken()
                        <button class="groove-button groove-button-paper" type="submit">
                            <i class="bi bi-pin-angle"></i>
                            @(Model.CurrentUserPinned ? "Премахни от профила" : "Закачи в профила")
                        </button>
                    </form>
                    <form asp-controller="Profiles" asp-action="@(Model.CurrentUserSharedToProfile ? "RemoveSharedEvent" : "ShareEvent")" asp-route-eventId="@Model.Id" asp-route-returnUrl="@($"{Context.Request.Path}{Context.Request.QueryString}")" method="post">
                        @Html.AntiForgeryToken()
                        <button class="groove-button groove-button-paper" type="submit">
                            <i class="bi bi-person-bounding-box"></i>
                            @(Model.CurrentUserSharedToProfile ? "Премахни от профила" : "Сподели в профила")
                        </button>
                    </form>
                </div>
            }
        </aside>
    </div>

    @if (Model.IsRecurring && Model.Occurrences.Count > 0)
    {
        var selectedOccurrence = Model.Occurrences.FirstOrDefault(o => o.Id == Model.SelectedOccurrenceId) ?? Model.Occurrences.First();
        var firstOccurrence = Model.Occurrences.First();
        var lastOccurrence = Model.Occurrences.Last();
        var showAllOccurrences = Model.CanEdit || Model.OccurrenceDisplayMode == EventOccurrenceDisplayMode.ShowAllDates;
        var selectedStatusText = selectedOccurrence.Status switch
        {
            EventOccurrenceStatus.Cancelled => "Отменена",
            EventOccurrenceStatus.SoldOut => "Разпродадена",
            _ => "Планирана",
        };
        <section class="groove-page-section event-occurrence-selector">
            <div class="groove-section-bar">
                <div>
                    <span class="groove-kicker" data-i18n="event.dates.kicker">Дати</span>
                    <h2>Избери дата.</h2>
                </div>
            </div>
            <div class="groove-info-card event-occurrence-card">
                <div class="event-occurrence-card__head">
                    <div>
                        @if (showAllOccurrences)
                        {
                            <span class="groove-kicker">Период</span>
                            <p class="mb-0">
                                @firstOccurrence.StartDateTime.ToString("dd.MM.yyyy") - @lastOccurrence.StartDateTime.ToString("dd.MM.yyyy")
                                · @Model.Occurrences.Count дати
                            </p>
                        }
                        else
                        {
                            <span class="groove-kicker">Следваща дата</span>
                            <p class="mb-0">Организаторът показва само най-близката предстояща дата.</p>
                        }
                    </div>
                    <div class="event-occurrence-card__selected">
                        <span>@(showAllOccurrences ? "Избрана дата" : "Следваща дата")</span>
                        <strong>@selectedOccurrence.StartDateTime.ToString("dd.MM HH:mm")</strong>
                        <small>@selectedOccurrence.EndDateTime.ToString("HH:mm") · @selectedStatusText</small>
                    </div>
                </div>

                @if (showAllOccurrences)
                {
                    <div class="event-occurrence-pills" aria-label="Избор на дата">
                        @foreach (var occurrence in Model.Occurrences.Take(8))
                        {
                            var isSelected = occurrence.Id == Model.SelectedOccurrenceId;
                            var statusClass = occurrence.Status == EventOccurrenceStatus.Cancelled
                                ? "is-cancelled"
                                : occurrence.Status == EventOccurrenceStatus.SoldOut ? "is-soldout" : "";
                            <a asp-action="Details"
                               asp-route-id="@Model.Id"
                               asp-route-occurrenceId="@occurrence.Id"
                               class="event-occurrence-pill @(isSelected ? "is-selected" : "") @statusClass">
                                <span>@occurrence.StartDateTime.ToString("ddd, dd.MM", CultureInfo.GetCultureInfo("bg-BG"))</span>
                                <strong>@occurrence.StartDateTime.ToString("HH:mm")</strong>
                                @if (occurrence.SoldCount > 0)
                                {
                                    <small>@occurrence.SoldCount продадени</small>
                                }
                            </a>
                        }
                    </div>

                    @if (Model.Occurrences.Count > 8)
                    {
                        <details class="event-occurrence-more mt-3">
                            <summary>Покажи всички дати (@Model.Occurrences.Count)</summary>
                            <div class="event-occurrence-pills mt-3">
                                @foreach (var occurrence in Model.Occurrences.Skip(8))
                                {
                                    var isSelected = occurrence.Id == Model.SelectedOccurrenceId;
                                    var statusClass = occurrence.Status == EventOccurrenceStatus.Cancelled
                                        ? "is-cancelled"
                                        : occurrence.Status == EventOccurrenceStatus.SoldOut ? "is-soldout" : "";
                                    <a asp-action="Details"
                                       asp-route-id="@Model.Id"
                                       asp-route-occurrenceId="@occurrence.Id"
                                       class="event-occurrence-pill @(isSelected ? "is-selected" : "") @statusClass">
                                        <span>@occurrence.StartDateTime.ToString("ddd, dd.MM", CultureInfo.GetCultureInfo("bg-BG"))</span>
                                        <strong>@occurrence.StartDateTime.ToString("HH:mm")</strong>
                                        @if (occurrence.SoldCount > 0)
                                        {
                                            <small>@occurrence.SoldCount продадени</small>
                                        }
                                    </a>
                                }
                            </div>
                        </details>
                    }

                    <form asp-action="Details" asp-route-id="@Model.Id" method="get" class="event-occurrence-select mt-3">
                        <label class="form-label" for="occurrenceId">Бърз избор</label>
                        <select id="occurrenceId" name="occurrenceId" class="form-select" onchange="this.form.submit()">
                            @foreach (var occurrence in Model.Occurrences)
                            {
                                var statusText = occurrence.Status switch
                                {
                                    EventOccurrenceStatus.Cancelled => "отменена",
                                    EventOccurrenceStatus.SoldOut => "разпродадена",
                                    _ => "планирана",
                                };
                                <option value="@occurrence.Id" selected="@(occurrence.Id == Model.SelectedOccurrenceId)">
                                    @occurrence.StartDateTime.ToString("dd.MM.yyyy HH:mm") - @occurrence.EndDateTime.ToString("HH:mm") · @statusText · @occurrence.SoldCount продадени
                                </option>
                            }
                        </select>
                    </form>
                }
                else
                {
                    <div class="event-safe-edit-note">
                        <i class="bi bi-lightning-charge"></i>
                        Организаторът е избрал бърза покупка за най-близката дата. Следващата налична дата е избрана автоматично.
                    </div>
                }

                @if (Model.CanEdit)
                {
                    <div class="event-safe-edit-note mt-3">
                        <i class="bi bi-shield-check"></i>
                        Дати с продадени билети или активни резервации се пазят автоматично. За тях използвай “Отмени дата” или премести датата, вместо да я триеш от серията.
                    </div>
                }
            </div>
            @if (Model.CanEdit && Model.SelectedOccurrenceId.HasValue && Model.SelectedOccurrenceStatus != EventOccurrenceStatus.Cancelled)
            {
                <form asp-action="CancelOccurrence" asp-route-id="@Model.Id" method="post" class="mt-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="occurrenceId" value="@Model.SelectedOccurrenceId" />
                    <button class="groove-button groove-button-paper" type="submit">
                        <i class="bi bi-calendar-x"></i> <span data-i18n="event.dates.cancel">Отмени избраната дата</span>
                    </button>
                </form>
            }
        </section>
    }

    <section class="groove-page-section">
        <div class="groove-section-bar">
            <div>
                <span class="groove-kicker" data-i18n="org.btn.tickets">Билети</span>
                <h2 data-i18n-html="tickets.available">Налични <span>билети</span>.</h2>
            </div>
            @if (Model.CanManageTickets)
            {
                <a asp-controller="Tickets" asp-action="Create" asp-route-id="@Model.Id" class="groove-button groove-button-paper">
                    <i class="bi bi-plus-lg"></i> <span data-i18n="tickets.add">Добави билет</span>
                </a>
            }
        </div>

        @if (Model.HasSeatLayout && Model.SeatMap != null)
        {
            <div class="event-seat-map-panel mb-3" data-seat-map>
                <div class="d-flex justify-content-between align-items-start gap-2 mb-3">
                    <div>
                        <span class="groove-kicker" data-i18n="seat.map.kicker">Схема на местата</span>
                        <h3 class="h5 mt-2 mb-1">@Model.SeatMap.LayoutName</h3>
                        <p class="text-muted mb-0" data-i18n="seat.map.help">Избери свободно място преди покупка.</p>
                    </div>
                    <span class="groove-status-badge groove-status-badge-muted" data-seat-selected-label data-i18n="seat.none">Няма избрано място</span>
                </div>
                @if (Model.SeatMap.Floors.Count > 1)
                {
                    <div class="event-seat-floor-tabs" role="tablist">
                        @for (var i = 0; i < Model.SeatMap.Floors.Count; i++)
                        {
                            var floor = Model.SeatMap.Floors[i];
                            <button type="button" class="@(i == 0 ? "is-active" : "")" data-seat-floor-tab="@floor">@floor</button>
                        }
                    </div>
                }
                <div class="event-seat-stage">
                    @foreach (var seatSection in Model.SeatMap.Sections)
                    {
                        var sectionShape = "shape-" + (seatSection.Shape ?? "Rectangle").ToLowerInvariant();
                        <div class="event-seat-section @sectionShape"
                             data-seat-floor="@seatSection.FloorName"
                             data-section-type="@seatSection.Type"
                             style="left:@(seatSection.X)px;top:@(seatSection.Y)px;width:@(seatSection.Width)px;height:@(seatSection.Height)px;transform:rotate(@(seatSection.Rotation)deg);">
                            <span class="event-seat-section__title">
                                @seatSection.Name
                                @if (seatSection.PriceModifier != 0)
                                {
                                    <span>+@seatSection.PriceModifier.ToTicketPriceDisplay()</span>
                                }
                            </span>
                            @foreach (var seat in seatSection.Seats)
                            {
                                var seatClass = seat.SeatType == SeatType.Table ? "is-table" : "";
                                <button type="button"
                                        class="event-seat-button @seatClass"
                                        data-seat-id="@seat.Id"
                                        data-seat-label="@seat.Label"
                                        data-seat-capacity="@seat.Capacity"
                                        data-seat-unlimited="@seat.IsCapacityUnlimited.ToString().ToLowerInvariant()"
                                        data-seat-type="@seat.SeatType"
                                        data-status="@seat.Status"
                                        style="left:@(seat.X)px;top:@(seat.Y)px;width:@(seat.Radius * 2)px;height:@(seat.Radius * 2)px;transform:rotate(@(seat.Rotation)deg);"
                                        disabled="@(!seat.Selectable)">
                                    <span>@seat.Label</span>
                                    @if (seat.SeatType == SeatType.Table && seat.IsCapacityUnlimited)
                                    {
                                        <small>∞</small>
                                    }
                                    else if (seat.SeatType == SeatType.Table && seat.Capacity > 1)
                                    {
                                        <small>@seat.Capacity</small>
                                    }
                                </button>
                            }
                        </div>
                    }
                </div>
            </div>
        }

        @if (Model.Tickets.Count == 0)
        {
            <div class="groove-empty-card">
                <i class="bi bi-ticket-perforated"></i>
                <h2 class="groove-panel-title" data-i18n="ticket.none">Все още няма билети.</h2>
            </div>
        }
        else
        {
            <div class="groove-ticket-grid mb-3">
                @foreach (var t in Model.Tickets)
                {
                    var ticketStatusClass = t.SoldOut ? "groove-status-badge-danger" : "groove-status-badge-success";
                    var ticketActionText = t.Price.IsFreeTicket() ? "Вземи безплатно" : "Купи";
                    var ticketActionKey = t.Price.IsFreeTicket() ? "ticket.getfree" : "ticket.buy";

                    <article class="groove-ticket-card">
                        <div class="d-flex justify-content-between align-items-start gap-2">
                            <h3>@t.Name</h3>
                            <span class="groove-status-badge @ticketStatusClass">
                                @if (t.SoldOut)
                                {
                                    <span data-i18n="ticket.soldout">Разпродадено</span>
                                }
                                else
                                {
                                    <span>@t.QuantityRemaining</span> <span data-i18n="ticket.left">оставащи</span>
                                }
                            </span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(t.Description))
                        {
                            <p>@t.Description</p>
                        }
                        <div class="groove-ticket-footer">
                            <span class="groove-price">@t.Price.ToTicketPriceDisplay()</span>
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                if (!t.SoldOut && Model.SelectedOccurrenceStatus != EventOccurrenceStatus.Cancelled)
                                {
                                    <form asp-controller="Tickets" asp-action="Buy" asp-route-id="@t.Id" method="post">
                                        @Html.AntiForgeryToken()
                                        @if (Model.SelectedOccurrenceId.HasValue)
                                        {
                                            <input type="hidden" name="occurrenceId" value="@Model.SelectedOccurrenceId" />
                                        }
                                         @if (Model.HasSeatLayout)
                                         {
                                             <input type="hidden" name="seatId" data-seat-input />
                                             <label class="visually-hidden" for="quantity-@t.Id" data-i18n="ticket.quantity">Брой билети</label>
                                             <select id="quantity-@t.Id"
                                                     name="quantity"
                                                     class="form-select form-select-sm groove-ticket-quantity"
                                                     aria-label="Брой билети"
                                                     data-seat-quantity
                                                     data-seat-quantity-max="@t.MaxPurchaseQuantity"
                                                     disabled>
                                                 @for (var q = 1; q <= t.MaxPurchaseQuantity; q++)
                                                 {
                                                     <option value="@q">@q</option>
                                                 }
                                             </select>
                                         }
                                         else
                                         {
                                             <label class="visually-hidden" for="quantity-@t.Id" data-i18n="ticket.quantity">Брой билети</label>
                                             <select id="quantity-@t.Id" name="quantity" class="form-select form-select-sm groove-ticket-quantity" aria-label="Брой билети">
                                                 @for (var q = 1; q <= t.MaxPurchaseQuantity; q++)
                                                 {
                                                     <option value="@q">@q</option>
                                                 }
                                             </select>
                                         }
                                         @if (t.RequiresAttendeeNames)
                                         {
                                             <div class="ticket-attendee-panel" data-attendee-names>
                                                 <div class="ticket-attendee-panel__head">
                                                     <i class="bi bi-person-lines-fill"></i>
                                                     <span>Имена за билетите</span>
                                                 </div>
                                                 <p class="ticket-attendee-panel__hint">Първо избери брой билети, после попълни имената.</p>
                                                 <div class="ticket-attendee-panel__rows" data-attendee-rows></div>
                                             </div>
                                         }
                                         <button type="submit" class="groove-button groove-button-dark">
                                             <i class="bi bi-bag-check"></i> <span data-i18n="@ticketActionKey">@ticketActionText</span>
                                         </button>
                                    </form>
                                }
                                else
                                {
                                    <button class="groove-button groove-button-paper" disabled>
                                        @if (Model.SelectedOccurrenceStatus == EventOccurrenceStatus.Cancelled)
                                        {
                                            <span data-i18n="status.occurrence.Cancelled">Отменена</span>
                                        }
                                        else
                                        {
                                            <span data-i18n="ticket.soldout">Разпродадено</span>
                                        }
                                    </button>
                                }
                            }
                            else
                            {
                                <a asp-area="Identity" asp-page="/Account/Login" class="groove-button groove-button-paper">
                                    <i class="bi bi-box-arrow-in-right"></i> <span data-i18n="common.signin">Вход</span>
                                </a>
                            }
                        </div>
                    </article>
                }
            </div>
        }
    </section>

    <section class="groove-page-section">
        <div class="groove-section-bar">
            <div>
                <span class="groove-kicker" data-i18n="comments.kicker">Разговор</span>
                <h2 id="comments"><span data-i18n="comments.title">Коментари</span> <span>(@Model.CommentsCount)</span>.</h2>
            </div>
        </div>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <form asp-action="AddComment" asp-route-id="@Model.Id" method="post" class="mb-4">
                @Html.AntiForgeryToken()
                @if (Model.ActingIdentities.Count > 1)
                {
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <label for="event-comment-identity" class="form-label small mb-0" data-i18n="identity.commenting.as">Коментираш като</label>
                        <select id="event-comment-identity" name="actingIdentityKey" class="form-select form-select-sm" style="max-width:260px;">
                            @foreach (var identity in Model.ActingIdentities)
                            {
                                if (identity.IsDefault)
                                {
                                    <option value="@identity.Key" selected>@identity.Label</option>
                                }
                                else
                                {
                                    <option value="@identity.Key">@identity.Label</option>
                                }
                            }
                        </select>
                    </div>
                }
                else if (Model.ActingIdentities.Count == 1)
                {
                    <input type="hidden" name="actingIdentityKey" value="@Model.ActingIdentities[0].Key" />
                    <p class="small text-muted mb-2"><span data-i18n="identity.commenting.as">Коментираш като</span>: @Model.ActingIdentities[0].DisplayName</p>
                }
                <div class="input-group">
                    <input type="text" name="content" class="form-control" placeholder="Напиши коментар..." data-i18n-placeholder="comments.placeholder" maxlength="1000" required />
                    <button class="btn btn-primary" type="submit"><i class="bi bi-send"></i> <span data-i18n="common.send">Изпрати</span></button>
                </div>
            </form>
        }

        @if (Model.CommentsCount == 0)
        {
            <div class="groove-empty-card">
                <i class="bi bi-chat-square-text"></i>
                <h2 class="groove-panel-title" data-i18n="comments.empty">Все още няма коментари.</h2>
            </div>
        }
        else
        {
            <div class="groove-info-card">
                <div class="groove-list-stack">
                    @foreach (var c in Model.Comments)
                    {
                        <article class="groove-list-item social-comment-item" id="comment-@c.Id" data-comment-like-surface data-comment-item data-comment-id="@c.Id" data-comment-likes="@c.LikesCount" data-comment-created="@c.CreatedAt.Ticks">
                            <div class="d-flex gap-3">
                                @if (!string.IsNullOrWhiteSpace(c.AuthorImageUrl))
                                {
                                    <img src="@c.AuthorImageUrl" alt="@c.UserName" class="social-avatar-xs" />
                                }
                                else
                                {
                                    <span class="social-avatar-xs social-avatar-xs--fallback">@(string.IsNullOrWhiteSpace(c.UserName) ? "?" : c.UserName[..1].ToUpperInvariant())</span>
                                }
                                <div>
                                    @if (!c.IsOrganizerPageAuthor && !string.IsNullOrWhiteSpace(c.AuthorProfileUserId))
                                    {
                                        <a asp-controller="Profiles" asp-action="Details" asp-route-id="@c.AuthorProfileUserId" class="fw-bold text-decoration-none">@c.UserName</a>
                                    }
                                    else
                                    {
                                        <strong>@c.UserName</strong>
                                    }
                                    <span class="groove-badge ms-2" data-i18n="@c.AuthorBadgeKey">@c.AuthorBadgeText</span>
                                    <p class="groove-list-meta mt-1">@c.CreatedAt.ToString("dd.MM.yyyy HH:mm")</p>
                                    <p id="evctext-@c.Id">@c.Content</p>
                                    <button class="groove-translate-btn" data-target="#evctext-@c.Id" onclick="gtTranslate(this)">
                                        <i class="bi bi-translate"></i> Translate
                                    </button>
                                    <div class="social-comment-toolbar">
                                        @if (User.Identity?.IsAuthenticated == true)
                                        {
                                            var commentLikeAction = c.CurrentUserLiked ? "UnlikeComment" : "LikeComment";
                                            var commentLikeMode = c.CurrentUserLiked ? "unlike" : "like";
                                            <form asp-action="@commentLikeAction" method="post" class="m-0" data-comment-like-form="@commentLikeMode">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="commentId" value="@c.Id" />
                                                <button class="comment-like-button @(c.CurrentUserLiked ? "is-liked" : "")" type="submit" title="Like">
                                                    <i class="bi @(c.CurrentUserLiked ? "bi-heart-fill" : "bi-heart")"></i>
                                                    <span data-comment-like-count>@c.LikesCount</span>
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="comment-like-button is-static"><i class="bi bi-heart"></i> <span>@c.LikesCount</span></span>
                                        }
                                    </div>
                                    @if (User.Identity?.IsAuthenticated == true)
                                    {
                                        <details class="social-comment-reply">
                                            <summary><i class="bi bi-reply"></i> <span data-i18n="comments.reply">Отговори</span></summary>
                                            <form asp-action="AddComment" asp-route-id="@Model.Id" method="post" class="social-comment-reply__form">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="parentCommentId" value="@c.Id" />
                                                @if (Model.ActingIdentities.Count > 1)
                                                {
                                                    <select name="actingIdentityKey" class="form-select form-select-sm">
                                                        @foreach (var identity in Model.ActingIdentities)
                                                        {
                                                            if (identity.IsDefault)
                                                            {
                                                                <option value="@identity.Key" selected>@identity.Label</option>
                                                            }
                                                            else
                                                            {
                                                                <option value="@identity.Key">@identity.Label</option>
                                                            }
                                                        }
                                                    </select>
                                                }
                                                else if (Model.ActingIdentities.Count == 1)
                                                {
                                                    <input type="hidden" name="actingIdentityKey" value="@Model.ActingIdentities[0].Key" />
                                                }
                                                <div class="input-group input-group-sm">
                                                    <input type="text" name="content" class="form-control" placeholder="Напиши отговор..." data-i18n-placeholder="comments.reply.placeholder" maxlength="1000" required />
                                                    <button class="btn btn-primary" type="submit"><i class="bi bi-send"></i></button>
                                                </div>
                                            </form>
                                        </details>
                                    }
                                </div>
                            </div>
                            @if (c.Replies.Count > 0)
                            {
                                <div class="social-comment-replies">
                                    @foreach (var reply in c.Replies)
                                    {
                                        <article class="social-comment-reply-item" id="comment-@reply.Id" data-comment-like-surface data-comment-item data-comment-id="@reply.Id" data-comment-likes="@reply.LikesCount" data-comment-created="@reply.CreatedAt.Ticks">
                                            @if (!string.IsNullOrWhiteSpace(reply.AuthorImageUrl))
                                            {
                                                <img src="@reply.AuthorImageUrl" alt="@reply.UserName" class="social-avatar-xs" />
                                            }
                                            else
                                            {
                                                <span class="social-avatar-xs social-avatar-xs--fallback">@(string.IsNullOrWhiteSpace(reply.UserName) ? "?" : reply.UserName[..1].ToUpperInvariant())</span>
                                            }
                                            <div class="social-comment-reply-item__body">
                                                @if (!reply.IsOrganizerPageAuthor && !string.IsNullOrWhiteSpace(reply.AuthorProfileUserId))
                                                {
                                                    <a asp-controller="Profiles" asp-action="Details" asp-route-id="@reply.AuthorProfileUserId" class="fw-bold text-decoration-none">@reply.UserName</a>
                                                }
                                                else
                                                {
                                                    <strong>@reply.UserName</strong>
                                                }
                                                <span class="groove-badge ms-2" data-i18n="@reply.AuthorBadgeKey">@reply.AuthorBadgeText</span>
                                                <p class="groove-list-meta mt-1">@reply.CreatedAt.ToString("dd.MM.yyyy HH:mm")</p>
                                                <p id="evrtext-@reply.Id">@reply.Content</p>
                                                <button class="groove-translate-btn" data-target="#evrtext-@reply.Id" onclick="gtTranslate(this)">
                                                    <i class="bi bi-translate"></i> Translate
                                                </button>
                                                <div class="social-comment-toolbar">
                                                    @if (User.Identity?.IsAuthenticated == true)
                                                    {
                                                        var replyLikeAction = reply.CurrentUserLiked ? "UnlikeComment" : "LikeComment";
                                                        var replyLikeMode = reply.CurrentUserLiked ? "unlike" : "like";
                                                        <form asp-action="@replyLikeAction" method="post" class="m-0" data-comment-like-form="@replyLikeMode">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="commentId" value="@reply.Id" />
                                                            <button class="comment-like-button @(reply.CurrentUserLiked ? "is-liked" : "")" type="submit" title="Like">
                                                                <i class="bi @(reply.CurrentUserLiked ? "bi-heart-fill" : "bi-heart")"></i>
                                                                <span data-comment-like-count>@reply.LikesCount</span>
                                                            </button>
                                                        </form>
                                                    }
                                                    else
                                                    {
                                                        <span class="comment-like-button is-static"><i class="bi bi-heart"></i> <span>@reply.LikesCount</span></span>
                                                    }
                                                </div>
                                            </div>
                                            @if (reply.CanDelete)
                                            {
                                                <form asp-action="DeleteComment" method="post" class="social-comment-reply-item__delete">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="commentId" value="@reply.Id" />
                                                    <button class="groove-button groove-button-paper" type="submit"><i class="bi bi-trash"></i></button>
                                                </form>
                                            }
                                        </article>
                                    }
                                </div>
                            }
                            @if (c.CanDelete)
                            {
                                <form asp-action="DeleteComment" method="post" class="ms-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="commentId" value="@c.Id" />
                                    <button class="groove-button groove-button-paper"><i class="bi bi-trash"></i> <span data-i18n="organizer.pages.delete">Изтрий</span></button>
                                </form>
                            }
                        </article>
                    }
                </div>
                <div class="comments-progressive-footer">
                    <span>
                        <span data-i18n="common.showing">Показани</span>
                        <strong>@Model.VisibleRootCommentsCount</strong> / <strong>@Model.RootCommentsCount</strong>
                        <span data-i18n="comments.threads">нишки</span>
                    </span>
                    @if (Model.HasMoreComments)
                    {
                        var nextComments = Math.Min(Model.RootCommentsCount, Model.VisibleRootCommentsCount + 8);
                        <a asp-action="Details"
                           asp-route-id="@Model.Id"
                           asp-route-occurrenceId="@Model.SelectedOccurrenceId"
                           asp-route-commentsToShow="@nextComments"
                           asp-fragment="comments"
                           class="groove-button groove-button-paper">
                            <i class="bi bi-chat-left-text"></i>
                            <span data-i18n="comments.show.more">Покажи още коментари</span>
                        </a>
                    }
                </div>
            </div>
        }
    </section>

    @if (Model.SimilarEvents.Count > 0)
    {
        <section class="evt-similar">
            <h2 data-i18n="event.similar">Сходни събития</h2>
            <div class="evt-similar__grid">
                @foreach (var ev in Model.SimilarEvents)
                {
                    <partial name="_EventCard" model="ev" />
                }
            </div>
        </section>
    }
</section>

@section Scripts {
    <script>
        (function () {
            var map = document.querySelector('[data-seat-map]');
            if (!map) return;

            var inputs = document.querySelectorAll('[data-seat-input]');
            var label = document.querySelector('[data-seat-selected-label]');
            var buttons = map.querySelectorAll('.event-seat-button:not([disabled])');
            var floorTabs = map.querySelectorAll('[data-seat-floor-tab]');
            var sections = map.querySelectorAll('[data-seat-floor]');
            var quantitySelects = document.querySelectorAll('[data-seat-quantity]');
            var submitButtons = Array.from(inputs).map(function (input) {
                return input.closest('form') ? input.closest('form').querySelector('button[type="submit"]') : null;
            }).filter(Boolean);

            function setSubmitEnabled(enabled) {
                submitButtons.forEach(function (button) {
                    button.disabled = !enabled;
                });
            }

            function setSeatQuantityLimit(maxQuantity) {
                quantitySelects.forEach(function (select) {
                    var ticketMax = parseInt(select.getAttribute('data-seat-quantity-max') || '1', 10);
                    var limit = Math.max(1, Math.min(maxQuantity || 1, ticketMax, 50));
                    var selected = parseInt(select.value || '1', 10);
                    select.innerHTML = '';
                    for (var i = 1; i <= limit; i += 1) {
                        var option = document.createElement('option');
                        option.value = i.toString();
                        option.textContent = i.toString();
                        select.appendChild(option);
                    }
                    select.value = Math.min(selected || 1, limit).toString();
                    select.disabled = false;
                    select.dispatchEvent(new Event('change', { bubbles: true }));
                });
            }

            setSubmitEnabled(false);

            function showFloor(floorName) {
                if (!floorName) return;
                floorTabs.forEach(function (tab) {
                    tab.classList.toggle('is-active', tab.getAttribute('data-seat-floor-tab') === floorName);
                });
                sections.forEach(function (section) {
                    section.hidden = section.getAttribute('data-seat-floor') !== floorName;
                });
            }

            if (floorTabs.length) {
                floorTabs.forEach(function (tab) {
                    tab.addEventListener('click', function () {
                        showFloor(tab.getAttribute('data-seat-floor-tab'));
                    });
                });
                showFloor(floorTabs[0].getAttribute('data-seat-floor-tab'));
            }

            buttons.forEach(function (button) {
                button.addEventListener('click', function () {
                    buttons.forEach(function (item) { item.classList.remove('is-selected'); });
                    button.classList.add('is-selected');
                    inputs.forEach(function (input) { input.value = button.getAttribute('data-seat-id'); });
                    var seatLabel = button.getAttribute('data-seat-label');
                    var capacity = parseInt(button.getAttribute('data-seat-capacity') || '1', 10);
                    var isTable = button.getAttribute('data-seat-type') === 'Table';
                    var isUnlimited = button.getAttribute('data-seat-unlimited') === 'true';
                    setSeatQuantityLimit(isTable ? (isUnlimited ? 50 : capacity) : 1);
                    if (label) {
                        var lang = (document.querySelector('meta[name="x-app-lang"]') || {}).content === 'en' ? 'en' : 'bg';
                        label.textContent = lang === 'en' ? 'Seat ' + seatLabel + ' selected' : 'Избрано място ' + seatLabel;
                    }
                    if (label && isTable && isUnlimited) {
                        label.textContent = lang === 'en'
                            ? 'Table ' + seatLabel + ' selected for one group'
                            : 'Маса ' + seatLabel + ' избрана за една група';
                    }
                    else if (label && isTable && capacity > 1) {
                        label.textContent = lang === 'en'
                            ? 'Table ' + seatLabel + ' selected for up to ' + capacity
                            : 'Маса ' + seatLabel + ' избрана до ' + capacity + ' души';
                    }
                    setSubmitEnabled(true);
                });
            });
        })();

        (function () {
            document.querySelectorAll('form').forEach(function (form) {
                var panel = form.querySelector('[data-attendee-names]');
                if (!panel) return;

                var rows = panel.querySelector('[data-attendee-rows]');
                var quantity = form.querySelector('select[name="quantity"]');

                function renderRows() {
                    var count = Math.max(1, parseInt(quantity && quantity.value ? quantity.value : '1', 10));
                    rows.innerHTML = '';
                    for (var i = 0; i < count; i += 1) {
                        var label = document.createElement('label');
                        label.className = 'ticket-attendee-row';
                        label.innerHTML = '<span></span><input name="attendeeNames" maxlength="120" autocomplete="name" required />';
                        label.querySelector('span').textContent = 'Билет #' + (i + 1);
                        label.querySelector('input').placeholder = i === 0 ? 'Пълно име' : 'Име на гост';
                        rows.appendChild(label);
                    }
                    panel.classList.toggle('is-multiple', count > 1);
                }

                if (quantity) {
                    quantity.addEventListener('change', renderRows);
                    quantity.addEventListener('input', renderRows);
                }
                renderRows();
            });
        })();
    </script>
}
