@model EventCreateEditViewModel

<section class="event-schedule-panel mb-3" data-event-recurrence-panel>
    <span class="groove-kicker" data-i18n="event.schedule.kicker">График</span>
    <h3 class="h5 mt-2" data-i18n="event.schedule.title">Кога се случва</h3>

    <div class="event-choice-grid event-choice-grid--compact mt-3">
        <label class="event-choice-card">
            <input name="RecurrenceType" type="radio" value="@EventRecurrenceType.None" checked="@(Model.RecurrenceType == EventRecurrenceType.None)" />
            <span>
                <strong>Еднократно</strong>
                <span>Една дата и един начален/краен час.</span>
            </span>
        </label>
        <label class="event-choice-card">
            <input name="RecurrenceType" type="radio" value="@EventRecurrenceType.Weekly" checked="@(Model.RecurrenceType != EventRecurrenceType.None)" />
            <span>
                <strong>Повтарящо се</strong>
                <span>Избери период, дни от седмицата и как клиентът избира дата.</span>
            </span>
        </label>
    </div>

    <div class="event-recurring-fields" data-event-recurring-fields>
        <input asp-for="TimeZone" type="hidden" value="Europe/Sofia" />

        <div class="event-repeat-summary">
            <span>Повтаря се всяка</span>
            <input asp-for="RecurrenceInterval" type="number" min="1" class="form-control" />
            <span>седмица в:</span>
        </div>
        <span asp-validation-for="RecurrenceInterval" class="text-danger small"></span>

        <div class="event-weekday-list mb-3" data-event-weekdays>
            @{
                var days = new[]
                {
                    (DayOfWeek.Monday, "Пон"),
                    (DayOfWeek.Tuesday, "Вто"),
                    (DayOfWeek.Wednesday, "Сря"),
                    (DayOfWeek.Thursday, "Чет"),
                    (DayOfWeek.Friday, "Пет"),
                    (DayOfWeek.Saturday, "Съб"),
                    (DayOfWeek.Sunday, "Нед"),
                };
            }
            @foreach (var (day, text) in days)
            {
                <label>
                    <input type="checkbox"
                           name="SelectedDaysOfWeek"
                           value="@day"
                           checked="@Model.SelectedDaysOfWeek.Contains(day)" />
                    <span data-i18n="@($"day.{day}")">@text</span>
                </label>
            }
        </div>
        <div class="form-text mb-3" data-event-weekdays-help>
            Ако не избереш ден, системата използва деня от началната дата.
        </div>
        <span asp-validation-for="SelectedDaysOfWeek" class="text-danger small"></span>

        <div class="mb-3" data-event-occurrence-visibility>
            <label asp-for="OccurrenceDisplayMode" class="form-label">Как купува клиентът</label>
            <div class="event-choice-grid event-choice-grid--compact">
                <label class="event-choice-card">
                    <input asp-for="OccurrenceDisplayMode" type="radio" value="@EventOccurrenceDisplayMode.ShowAllDates" />
                    <span>
                        <strong>Избира дата</strong>
                        <span>Показват се всички налични дати и клиентът купува за конкретната.</span>
                    </span>
                </label>
                <label class="event-choice-card">
                    <input asp-for="OccurrenceDisplayMode" type="radio" value="@EventOccurrenceDisplayMode.NextAvailableOnly" />
                    <span>
                        <strong>Най-близката автоматично</strong>
                        <span>Ако не искаш избор на дата, покупката отива към следващата налична.</span>
                    </span>
                </label>
            </div>
        </div>

        <div class="groove-form-grid">
            <div class="mb-3">
                <label asp-for="RecurrenceStartDate" class="form-label">Начална дата</label>
                <input asp-for="RecurrenceStartDate" type="date" class="form-control" value="@Model.RecurrenceStartDate?.ToString("yyyy-MM-dd")" />
                <span asp-validation-for="RecurrenceStartDate" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="RecurrenceEndDate" class="form-label">Крайна дата</label>
                <input asp-for="RecurrenceEndDate" type="date" class="form-control" value="@Model.RecurrenceEndDate?.ToString("yyyy-MM-dd")" />
                <span asp-validation-for="RecurrenceEndDate" class="text-danger small"></span>
            </div>
        </div>

        <div class="groove-form-grid">
            <div class="mb-3">
                <label asp-for="RecurrenceStartTime" class="form-label">Начален час</label>
                <input asp-for="RecurrenceStartTime" type="time" class="form-control" value="@Model.RecurrenceStartTime?.ToString(@"hh\:mm")" />
                <span asp-validation-for="RecurrenceStartTime" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="RecurrenceEndTime" class="form-label">Краен час</label>
                <input asp-for="RecurrenceEndTime" type="time" class="form-control" value="@Model.RecurrenceEndTime?.ToString(@"hh\:mm")" />
                <span asp-validation-for="RecurrenceEndTime" class="text-danger small"></span>
            </div>
        </div>

        @if (Model.Id > 0)
        {
            <div class="mb-3">
                <label asp-for="RecurringEditScope" class="form-label"></label>
                <select asp-for="RecurringEditScope" asp-items="Html.GetEnumSelectList<RecurringEditScope>()" class="form-select"></select>
                <div class="form-text">За конкретна дата отвори детайлите и отмени само избраната дата.</div>
            </div>
        }
    </div>
</section>
