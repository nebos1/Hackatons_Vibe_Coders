@model IReadOnlyList<EventCardViewModel>
@{
    ViewData["Title"] = "Recommended Events";
    var hasPrefs = (bool)(ViewBag.HasPreferences ?? false);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0"><i class="bi bi-stars"></i> Recommended for you</h1>
    <a asp-controller="Preferences" asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-sliders"></i> My preferences
    </a>
</div>

@if (!hasPrefs)
{
    <div class="alert alert-info">
        You don't have preferences set yet — showing all upcoming approved events.
        <a asp-controller="Preferences" asp-action="Index" class="alert-link">Set preferences</a> to get better recommendations.
    </div>
}

@if (Model.Count == 0)
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-calendar-x" style="font-size:2rem;"></i>
        <p class="mt-2">No upcoming events match your preferences.</p>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-3">
        @foreach (var ev in Model)
        {
            <div class="col"><partial name="_EventCard" model="ev" /></div>
        }
    </div>
}
