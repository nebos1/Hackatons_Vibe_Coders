@model EventCreateEditViewModel

<section class="event-ticketing-panel mb-3" data-event-ticketing-panel>
    <span class="groove-kicker" data-i18n="event.ticketing.kicker">Билети и места</span>
    <h3 class="h5 mt-2" data-i18n="event.ticketing.title">Как влиза публиката</h3>

    <div class="event-choice-grid mt-3">
        <label class="event-choice-card">
            <input asp-for="TicketingMode" type="radio" value="@EventTicketingMode.GeneralAdmission" />
            <span>
                <strong data-i18n="event.ticketing.ga">Без места</strong>
                <span data-i18n="event.ticketing.ga.desc">Без избор на място. Старият билетен поток остава активен.</span>
            </span>
        </label>
        <label class="event-choice-card">
            <input asp-for="TicketingMode" type="radio" value="@EventTicketingMode.SeatedLayout" />
            <span>
                <strong data-i18n="event.ticketing.seated">Използвай схема с места</strong>
                <span data-i18n="event.ticketing.seated.desc">Всяко събитие или дата получава отделна наличност на места.</span>
            </span>
        </label>
        <label class="event-choice-card">
            <input asp-for="TicketingMode" type="radio" value="@EventTicketingMode.Standing" />
            <span>
                <strong data-i18n="event.ticketing.standing">Правостоящи зони</strong>
                <span data-i18n="event.ticketing.standing.desc">Използвай преизползваеми секции за правостоящи или VIP зони.</span>
            </span>
        </label>
        <label class="event-choice-card">
            <input asp-for="TicketingMode" type="radio" value="@EventTicketingMode.TableZones" />
            <span>
                <strong data-i18n="event.ticketing.tables">Маси / VIP</strong>
                <span data-i18n="event.ticketing.tables.desc">Използвай маси или премиум секции с добавка към цената.</span>
            </span>
        </label>
    </div>

    <div class="event-layout-fields" data-event-layout-fields>
        <div class="groove-form-grid mt-3">
            <div class="mb-3">
                <label asp-for="VenueLayoutId" class="form-label"></label>
                <select asp-for="VenueLayoutId" asp-items="Model.VenueLayouts" class="form-select">
                    <option value="" data-i18n="event.ticketing.choose.layout">-- Избери преизползваем layout --</option>
                </select>
                <span asp-validation-for="VenueLayoutId" class="text-danger small"></span>
            </div>
            <div class="mb-3 d-flex align-items-end">
                <a asp-controller="Layouts" asp-action="Create" class="groove-button groove-button-paper w-100">
                    <i class="bi bi-grid-3x3-gap"></i> <span data-i18n="layout.create">Създай layout</span>
                </a>
            </div>
        </div>
    </div>
</section>
