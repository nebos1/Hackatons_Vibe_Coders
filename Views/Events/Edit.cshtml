@model EventCreateEditViewModel
@{
    ViewData["Title"] = "Редакция на събитие";
}

<section class="groove-app-page groove-form-shell">
    <div class="groove-page-hero">
        <div class="groove-page-hero__copy">
            <span class="groove-stamp groove-stamp-red">Събитие</span>
            <h1>Редактирай <span>събитието</span>.</h1>
            <p>Промени детайлите, датите и визуалното представяне на публикацията.</p>
        </div>
        <div class="groove-page-actions">
            <a asp-action="Details" asp-route-id="@Model.Id" class="groove-button groove-button-paper">
                <i class="bi bi-arrow-left"></i> Към детайлите
            </a>
        </div>
    </div>

    <div class="groove-form-panel">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="OrganizerProfileId" class="form-label"></label>
                <select asp-for="OrganizerProfileId" asp-items="Model.OrganizerProfiles" class="form-select">
                    <option value="">-- Choose public page --</option>
                </select>
                <span asp-validation-for="OrganizerProfileId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <div class="d-flex justify-content-between align-items-end gap-2">
                    <label asp-for="Description" class="form-label mb-0"></label>
                    <button type="button" id="ai-generate-description" class="groove-button groove-button-paper btn-sm">
                        <i class="bi bi-stars"></i> Генерирай с AI
                    </button>
                </div>
                <textarea asp-for="Description" id="event-description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
                <div id="ai-description-status" class="form-text"></div>
            </div>

            <div class="groove-form-grid">
                <div class="mb-3">
                    <label asp-for="City" class="form-label"></label>
                    <input asp-for="City" id="City" class="form-control" autocomplete="off" />
                    <span asp-validation-for="City" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-end gap-2 mb-1">
                        <label asp-for="Address" class="form-label mb-0"></label>
                        <button type="button" id="btn-use-my-location" class="groove-button groove-button-paper btn-sm">
                            <i class="bi bi-geo-alt-fill"></i> My Location
                        </button>
                    </div>
                    <div style="position:relative;">
                        <input asp-for="Address" id="Address" class="form-control"
                               autocomplete="off"
                               placeholder="Започни да пишеш адрес или място..." />
                        <div id="city-address-suggestions" class="list-group" style="position:absolute;z-index:1050;left:0;right:0;max-height:180px;overflow:auto;display:none;"></div>
                    </div>
                    <span asp-validation-for="Address" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label"><i class="bi bi-geo-alt"></i> Маркирай локацията</label>
                <div id="event-location-map" style="height: 300px; border-radius: 0.5rem; overflow: hidden;"></div>
                <div id="event-location-status" class="form-text"></div>
            </div>

            <input asp-for="Latitude" id="Latitude" type="hidden" />
            <input asp-for="Longitude" id="Longitude" type="hidden" />

            <div class="groove-form-grid">
                <div class="mb-3">
                    <label asp-for="StartTime" class="form-label"></label>
                    <input asp-for="StartTime" type="datetime-local" class="form-control"
                           value="@Model.StartTime.ToString("yyyy-MM-ddTHH:mm")" />
                    <span asp-validation-for="StartTime" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="EndTime" class="form-label"></label>
                    <input asp-for="EndTime" type="datetime-local" class="form-control"
                           value="@Model.EndTime.ToString("yyyy-MM-ddTHH:mm")" />
                    <span asp-validation-for="EndTime" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Genre" class="form-label"></label>
                <select asp-for="Genre" asp-items="Html.GetEnumSelectList<EventGenre>()" class="form-select"></select>
                <span asp-validation-for="Genre" class="text-danger small"></span>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
            {
                <div class="mb-3">
                    <label class="form-label">Текуща снимка</label>
                    <div>
                        <img src="@Model.ImageUrl" alt="current" style="max-height:160px;border-radius:6px;" />
                    </div>
                </div>
            }

            <div class="mb-3">
                <label asp-for="Photo" class="form-label"><i class="bi bi-cloud-upload"></i> Качи нова снимка</label>
                <input asp-for="Photo" class="form-control" type="file" accept="image/jpeg,image/png,image/webp,image/gif" />
                <span asp-validation-for="Photo" class="text-danger small"></span>
                <div class="form-text">Остави празно за да запазиш текущата снимка.</div>
            </div>

            @if (Model.CanEditApproval)
            {
                <div class="mb-3 form-check">
                    <input asp-for="IsApproved" class="form-check-input" type="checkbox" />
                    <label asp-for="IsApproved" class="form-check-label"></label>
                </div>
            }

            <div class="groove-form-actions">
                <button type="submit" class="groove-button groove-button-dark">
                    <i class="bi bi-check-lg"></i> Запази
                </button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="groove-button groove-button-paper">Отказ</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_AiDescriptionScript" />
    <partial name="_GoogleMapsLoader" />
    <script src="~/js/event-place-picker.js" asp-append-version="true"></script>
}
