@model VenuesIndexViewModel
@{
    ViewData["Title"] = "Venues";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0"><i class="bi bi-geo-alt"></i> Venues</h1>
    @if (User.IsInRole(GlobalConstants.Roles.Organizer) || User.IsInRole(GlobalConstants.Roles.Admin))
    {
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> New venue</a>
    }
</div>

<form method="get" class="card card-body mb-4">
    <div class="row g-2">
        <div class="col-md-5">
            <input type="text" name="search" value="@Model.Search" placeholder="Search by name…" class="form-control" />
        </div>
        <div class="col-md-4">
            <select name="city" class="form-select">
                <option value="">All cities</option>
                @foreach (var c in Model.Cities)
                {
                    <option value="@c" selected="@(Model.City == c)">@c</option>
                }
            </select>
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-outline-primary w-100"><i class="bi bi-search"></i> Filter</button>
            <a asp-action="Index" class="btn btn-outline-secondary w-100">Clear</a>
        </div>
    </div>
</form>

@if (Model.Venues.Count == 0)
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-geo-alt-fill" style="font-size:2rem;"></i>
        <p class="mt-2">No venues found.</p>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-3">
        @foreach (var v in Model.Venues)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    @if (!string.IsNullOrWhiteSpace(v.ImageUrl))
                    {
                        <img src="@v.ImageUrl" class="card-img-top card-img-top-fixed" alt="@v.Name" />
                    }
                    else
                    {
                        <div class="card-img-top-fixed d-flex align-items-center justify-content-center text-muted">
                            <i class="bi bi-building" style="font-size:2rem;"></i>
                        </div>
                    }
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@v.Name</h5>
                        <p class="card-text text-muted mb-1"><i class="bi bi-geo-alt"></i> @v.City</p>
                        <p class="card-text text-muted small mb-3">@v.Address</p>
                        <p class="card-text small text-muted mb-3"><i class="bi bi-calendar2-event"></i> @v.EventsCount events</p>
                        <a asp-action="Details" asp-route-id="@v.Id" class="btn btn-outline-primary mt-auto">Details</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
