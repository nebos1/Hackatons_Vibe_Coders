@model VenueDetailsViewModel
@{
    ViewData["Title"] = Model.Name;
}

<div class="mb-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
    @if (Model.CanEdit)
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary ms-1"><i class="bi bi-pencil"></i> Edit</a>
    }
    @if (Model.CanDelete)
    {
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-danger ms-1"><i class="bi bi-trash"></i> Delete</a>
    }
</div>

<div class="row">
    <div class="col-lg-5">
        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" class="img-fluid rounded mb-3" alt="@Model.Name" style="max-height:300px;width:100%;object-fit:cover;" />
        }
    </div>
    <div class="col-lg-7">
        <h1 class="h2">@Model.Name</h1>
        <ul class="list-unstyled">
            <li class="mb-1"><i class="bi bi-geo-alt-fill text-primary"></i> @Model.City — @Model.Address</li>
            <li class="mb-1"><i class="bi bi-person-fill text-primary"></i> Organizer: @Model.OrganizerName</li>
        </ul>
        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <p>@Model.Description</p>
        }
    </div>
</div>

<hr class="my-4" />
<h2 class="h5"><i class="bi bi-calendar2-event"></i> Events at this venue (@Model.Events.Count)</h2>

@if (Model.Events.Count == 0)
{
    <p class="text-muted">No events yet.</p>
}
else
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-3">
        @foreach (var ev in Model.Events)
        {
            <div class="col"><partial name="_EventCard" model="ev" /></div>
        }
    </div>
}
