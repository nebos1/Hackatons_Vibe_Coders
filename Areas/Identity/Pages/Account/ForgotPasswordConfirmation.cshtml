@page "/password-reset-sent"
@model ForgotPasswordConfirmationModel
@{
    ViewData["Title"] = "Провери имейла си";
}

<section class="auth-zine-page">
    <div class="auth-zine-shell">
        <div class="auth-zine-copy">
            <span class="auth-zine-stamp auth-zine-stamp-teal">Изпратено</span>
            <h1>Провери имейла си</h1>
            <p>Ако има акаунт с този имейл, ще получиш линк за смяна на паролата.</p>
        </div>

        <p class="auth-zine-alt">
            <a asp-page="./Login">Обратно към вход</a>
        </p>
    </div>
</section>
