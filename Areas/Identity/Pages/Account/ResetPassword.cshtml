@page "/reset-password"
@model ResetPasswordModel
@{
    ViewData["Title"] = "Нова парола";
}

<section class="auth-zine-page">
    <div class="auth-zine-shell">
        <div class="auth-zine-copy">
            <span class="auth-zine-stamp auth-zine-stamp-teal">Парола</span>
            <h1>Нова парола</h1>
            <p>Въведи нова парола за акаунта си.</p>
        </div>

        <div class="auth-zine-card">
            <form method="post" class="auth-zine-form">
                <div asp-validation-summary="ModelOnly" class="auth-zine-validation" role="alert"></div>
                <input asp-for="Input.Code" type="hidden" />

                <div class="auth-zine-field">
                    <label asp-for="Input.Email"></label>
                    <input asp-for="Input.Email" autocomplete="email" />
                    <span asp-validation-for="Input.Email"></span>
                </div>

                <div class="auth-zine-field">
                    <label asp-for="Input.Password"></label>
                    <input asp-for="Input.Password" autocomplete="new-password" />
                    <span asp-validation-for="Input.Password"></span>
                </div>

                <div class="auth-zine-field">
                    <label asp-for="Input.ConfirmPassword"></label>
                    <input asp-for="Input.ConfirmPassword" autocomplete="new-password" />
                    <span asp-validation-for="Input.ConfirmPassword"></span>
                </div>

                <button type="submit" class="auth-zine-button auth-zine-button-red">
                    <i class="bi bi-key"></i> Запази паролата
                </button>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
