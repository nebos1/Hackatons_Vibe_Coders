@page "/password-reset-done"
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Паролата е сменена";
}

<section class="auth-zine-page">
    <div class="auth-zine-shell">
        <div class="auth-zine-copy">
            <span class="auth-zine-stamp auth-zine-stamp-teal">Готово</span>
            <h1>Паролата е сменена</h1>
            <p>Вече можеш да влезеш с новата си парола.</p>
        </div>

        <p class="auth-zine-alt">
            <a asp-page="./Login">Към вход</a>
        </p>
    </div>
</section>
