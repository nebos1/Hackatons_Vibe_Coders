@page "/confirm-email"
@model ConfirmEmailModel
@{
    ViewData["Title"] = "Потвърден имейл";
}

<section class="auth-zine-page">
    <div class="auth-zine-shell">
        <div class="auth-zine-copy">
            <span class="auth-zine-stamp">Имейл</span>
            <h1>@Model.Title</h1>
            <p>@Model.Message</p>
            @if (!string.IsNullOrWhiteSpace(Model.ContinueUrl))
            {
                <p class="mt-4">
                    <a href="@Model.ContinueUrl" class="auth-zine-button auth-zine-button-teal">@Model.ContinueText</a>
                </p>
            }
        </div>

        <p class="auth-zine-alt">
            <a asp-area="Identity" asp-page="/Account/Login">Към вход</a>
        </p>
    </div>
</section>
