@page "/forgot-password"
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Забравена парола";
}

<section class="auth-zine-page">
    <div class="auth-zine-shell">
        <div class="auth-zine-copy">
            <span class="auth-zine-stamp auth-zine-stamp-teal">Парола</span>
            <h1>Забравена парола</h1>
            <p>Въведи имейла си и ще ти изпратим линк за смяна на паролата.</p>
        </div>

        <div class="auth-zine-card">
            <form method="post" class="auth-zine-form">
                <div asp-validation-summary="ModelOnly" class="auth-zine-validation" role="alert"></div>

                <div class="auth-zine-field">
                    <label asp-for="Input.Email"></label>
                    <input asp-for="Input.Email" autocomplete="email" placeholder="you@evento.app" />
                    <span asp-validation-for="Input.Email"></span>
                </div>

                <button type="submit" class="auth-zine-button auth-zine-button-red">
                    <i class="bi bi-envelope"></i> Изпрати линк
                </button>
            </form>
        </div>

        <p class="auth-zine-alt">
            <a asp-page="./Login">Обратно към вход</a>
        </p>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
